{
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "SeedData": {
    "Enabled": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "EmailSettings": {
    "Enabled": false,
    "SmtpHost": "",
    "SmtpPort": 587,
    "SmtpUser": "",
    "SmtpPassword": "",
    "SenderEmail": "no-reply@pawconnect.local",
    "SenderName": "PawConnect",
    "EnableSsl": true,
    "OpenLocalInboxOnStartup": false,
    "LocalInboxUrl": ""
  },
  "ScheduledReports": {
    "Enabled": false,
    "RunOnStartupInDevelopment": false,
    "ShelterReportIntervalMinutes": 1440
  },
  "VisitReminders": {
    "Enabled": false,
    "CheckIntervalMinutes": 60,
    "ReminderHoursBeforeVisit": 24
  },
  "DogImageStorage": {
    "Provider": "Local",
    "MaxFileSizeBytes": 5242880,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ],
    "LocalRoot": "uploads/dogs"
  },
  "OpenAI": {
    "Enabled": false,
    "ApiKey": "",
    "Model": "gpt-5.4-mini",
    "ChatModel": "gpt-5.4-mini",
    "EmbeddingModel": "text-embedding-3-small",
    "DogProfileQualityEnabled": false,
    "ReportSummariesEnabled": false,
    "ShelterOperationsAssistantEnabled": false,
    "ShelterOperationsAssistantModel": ""
  }
}
