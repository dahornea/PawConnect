# PawConnect local Docker demo settings.
# Copy this file to .env before running docker compose.
# Do not commit .env.

# SQL Server requires a strong password with uppercase, lowercase, digits, and symbols.
SQL_PASSWORD=Change_this_Strong_Password_123!
SQL_DATABASE=PawConnect

# Local host ports. Change these if a port is already used on your machine.
APP_HTTP_PORT=8080
SQLSERVER_HOST_PORT=1433
SMTP4DEV_WEB_PORT=5001
SMTP4DEV_SMTP_HOST_PORT=2525

# Docker app environment and local database setup.
ASPNETCORE_ENVIRONMENT=Docker
DATABASE_APPLY_MIGRATIONS_ON_STARTUP=true
SEED_DATA_ENABLED=true

# Optional AI features are disabled by default so the local demo is zero-cost.
OPENAI_ENABLED=false
OPENAI_API_KEY=

# Local email goes to the smtp4dev container.
EMAIL_ENABLED=true
SMTP_HOST=smtp4dev
SMTP_PORT=25

# Scheduled email jobs are disabled for the local demo to avoid surprise background email traffic.
SCHEDULED_REPORTS_ENABLED=false
VISIT_REMINDERS_ENABLED=false
