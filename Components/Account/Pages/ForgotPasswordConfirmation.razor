@page "/Account/ForgotPasswordConfirmation"

<PageTitle>Forgot password confirmation</PageTitle>

<div class="auth-page">
    <MudCard Class="auth-card">
        <MudCardContent>
            <MudStack Spacing="3" AlignItems="AlignItems.Center">
                <span class="auth-brand-icon"><MudIcon Icon="@Icons.Material.Filled.MarkEmailRead" /></span>
                <MudStack Spacing="1" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h4">Check your email</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center" role="alert">
                        If an account exists for that email, a password reset link has been sent.
                    </MudText>
                </MudStack>
                <MudButton Href="/Account/Login" Variant="Variant.Filled" Color="Color.Primary">Back to login</MudButton>
            </MudStack>
        </MudCardContent>
    </MudCard>
</div>
