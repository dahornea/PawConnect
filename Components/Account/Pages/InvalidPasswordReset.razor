@page "/Account/InvalidPasswordReset"

<PageTitle>Invalid password reset</PageTitle>

<div class="auth-page">
    <MudCard Class="auth-card">
        <MudCardContent>
            <MudStack Spacing="3" AlignItems="AlignItems.Center">
                <span class="auth-brand-icon"><MudIcon Icon="@Icons.Material.Filled.ErrorOutline" /></span>
                <MudStack Spacing="1" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h4">Reset link expired</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center" role="alert">
                        This password reset link is invalid or has expired. Please request a new one.
                    </MudText>
                </MudStack>
                <MudStack Row="true" Spacing="2" Justify="Justify.Center">
                    <MudButton Href="/Account/ForgotPassword" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.LockReset">Request new link</MudButton>
                    <MudButton Href="/Account/Login" Variant="Variant.Text" Color="Color.Default">Back to login</MudButton>
                </MudStack>
            </MudStack>
        </MudCardContent>
    </MudCard>
</div>
