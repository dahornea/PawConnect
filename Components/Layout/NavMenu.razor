<MudNavMenu Rounded="true" Margin="Margin.Dense" Color="Color.Primary" Class="paw-nav pa-3">
    <div class="nav-brand">
        <span class="nav-brand-icon"><MudIcon Icon="@Icons.Material.Filled.Pets" /></span>
        <div>
            <MudText Typo="Typo.subtitle1">PawConnect</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">Adoption and shelter management</MudText>
        </div>
    </div>

    <div class="nav-group">
        <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
        <MudNavLink Href="/dogs" Icon="@Icons.Material.Filled.Pets">Dogs</MudNavLink>
        <MudNavLink Href="/success-stories" Icon="@Icons.Material.Filled.EmojiEvents">Success Stories</MudNavLink>
    </div>

    <AuthorizeView Roles="Adopter">
        <div class="nav-group">
            <MudDivider Class="my-3" />
            <MudText Typo="Typo.caption" Class="px-4 nav-section-label">Adopter</MudText>
            <MudNavLink Href="/adopter/dashboard" Icon="@Icons.Material.Filled.Dashboard">Adopter Dashboard</MudNavLink>
            <MudNavLink Href="/adopter/profile" Icon="@Icons.Material.Filled.AccountCircle">My Profile</MudNavLink>
            <MudNavLink Href="/dogs" Icon="@Icons.Material.Filled.Search">Browse Dogs</MudNavLink>
            <MudNavLink Href="/favorites" Icon="@Icons.Material.Filled.Favorite">Favorite Dogs</MudNavLink>
            <MudNavLink Href="/my-adoption-requests" Icon="@Icons.Material.Filled.Assignment">My Adoption Requests</MudNavLink>
        </div>
    </AuthorizeView>

    <AuthorizeView Roles="Shelter">
        <div class="nav-group">
            <MudDivider Class="my-3" />
            <MudText Typo="Typo.caption" Class="px-4 nav-section-label">Shelter</MudText>
            <MudNavLink Href="/shelter/dashboard" Icon="@Icons.Material.Filled.Dashboard">Shelter Dashboard</MudNavLink>
            <MudNavLink Href="/shelter/dogs" Icon="@Icons.Material.Filled.Edit">Manage Dogs</MudNavLink>
            <MudNavLink Href="/shelter/adoption-requests" Icon="@Icons.Material.Filled.MarkEmailRead">Adoption Requests</MudNavLink>
            <MudNavLink Href="/shelter/resources" Icon="@Icons.Material.Filled.Inventory">Resources</MudNavLink>
        </div>
    </AuthorizeView>

    <AuthorizeView Roles="Admin">
        <div class="nav-group">
            <MudDivider Class="my-3" />
            <MudText Typo="Typo.caption" Class="px-4 nav-section-label">Admin</MudText>
            <MudNavLink Href="/admin/dashboard" Icon="@Icons.Material.Filled.AdminPanelSettings">Admin Dashboard</MudNavLink>
            <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.People">Users</MudNavLink>
            <MudNavLink Href="/admin/shelters" Icon="@Icons.Material.Filled.Business">Shelters</MudNavLink>
            <MudNavLink Href="/admin/dogs" Icon="@Icons.Material.Filled.Pets">Dogs</MudNavLink>
            <MudNavLink Href="/admin/adoption-requests" Icon="@Icons.Material.Filled.FactCheck">Adoption Requests</MudNavLink>
        </div>
    </AuthorizeView>
</MudNavMenu>
