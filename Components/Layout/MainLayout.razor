@inherits LayoutComponentBase
@implements IDisposable
@using Microsoft.AspNetCore.Identity
@using PawConnect.Data

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Color="Color.Primary" Class="app-shell-bar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <a href="/" class="app-brand-link ms-2" aria-label="Go to PawConnect home">
            <span class="brand-mark">
                <MudIcon Icon="@Icons.Material.Filled.Pets" Color="Color.Inherit" />
            </span>
            <MudText Typo="Typo.h6">PawConnect</MudText>
        </a>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                @{
                    var displayName = GetDisplayName(context.User.Identity?.Name);
                    var displayEmail = GetDisplayEmail(context.User.Identity?.Name);
                }
                <div class="topbar-auth-actions">
                    <NotificationBell />
                    <div class="user-display">
                        <span class="user-avatar">
                            <MudIcon Icon="@CurrentUserIcon" Color="Color.Inherit" />
                        </span>
                        <span class="user-copy">
                            <span class="user-name">@displayName</span>
                            @if (!string.IsNullOrWhiteSpace(displayEmail))
                            {
                                <span class="user-email">@displayEmail</span>
                            }
                        </span>
                    </div>
                    <MudButton ButtonType="ButtonType.Button" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Logout" OnClick="ConfirmLogoutAsync">Logout</MudButton>
                </div>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/Account/Login" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Login">Login</MudButton>
                <MudButton Href="/Account/Register" Variant="Variant.Text" Color="Color.Inherit" StartIcon="@Icons.Material.Filled.PersonAdd">Register</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0" Variant="DrawerVariant.Responsive" Class="drawer-shell">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="app-main">
        <MudContainer MaxWidth="MaxWidth.Large" Class="app-content">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

