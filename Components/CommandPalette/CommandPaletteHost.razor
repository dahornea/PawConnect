@implements IAsyncDisposable
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ICommandPaletteService CommandPaletteService
@inject IJSRuntime JsRuntime
@inject NavigationManager NavigationManager

<button type="button"
        class="command-palette-trigger"
        aria-label="Open command palette"
        @onclick="OpenAsync">
    <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" />
    <span class="command-palette-trigger-text">Search or jump to...</span>
    <span class="command-palette-shortcut">Ctrl K</span>
</button>

@if (_isOpen)
{
    <div class="command-palette-overlay" role="presentation" @onclick="CloseAsync">
        <section class="command-palette-panel"
                 role="dialog"
                 aria-modal="true"
                 aria-label="Command palette"
                 @onclick:stopPropagation="true">
            <div class="command-palette-search-row">
                <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" />
                <input @ref="_searchInput"
                       class="command-palette-input"
                       value="@_query"
                       placeholder="Search pages, dogs, requests, notifications..."
                       aria-label="Search commands"
                       @oninput="OnQueryChangedAsync"
                       @onkeydown="HandleKeyDownAsync" />
            </div>

            <div class="command-palette-results" role="listbox" aria-label="Command results">
                @if (_isLoading)
                {
                    <div class="command-palette-state">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        <span>Searching PawConnect...</span>
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <div class="command-palette-state command-palette-error">
                        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Small" />
                        <span>@_errorMessage</span>
                    </div>
                }
                else if (DisplayCommands.Count == 0)
                {
                    <div class="command-palette-empty">
                        <MudIcon Icon="@Icons.Material.Filled.SearchOff" />
                        <strong>No commands found.</strong>
                        <span>Try searching for dogs, applications, notifications or pages.</span>
                    </div>
                }
                else
                {
                    var index = 0;
                    foreach (var group in DisplayCommands.GroupBy(command => command.Category))
                    {
                        <div class="command-palette-group">
                            <div class="command-palette-group-title">@group.Key</div>
                            @foreach (var command in group)
                            {
                                var currentIndex = index;
                                var selected = currentIndex == _selectedIndex;
                                <button type="button"
                                        class="command-palette-item @(selected ? "is-selected" : null)"
                                        role="option"
                                        aria-selected="@selected"
                                        @onclick="() => ExecuteAsync(command)">
                                    <span class="command-palette-item-icon">
                                        <MudIcon Icon="@command.Icon" Size="Size.Small" />
                                    </span>
                                    <span class="command-palette-item-copy">
                                        <span class="command-palette-item-title">@command.Title</span>
                                        <span class="command-palette-item-description">@command.Description</span>
                                    </span>
                                    @if (!string.IsNullOrWhiteSpace(command.Badge))
                                    {
                                        <span class="command-palette-badge">@command.Badge</span>
                                    }
                                </button>
                                index++;
                            }
                        </div>
                    }
                }
            </div>

            <footer class="command-palette-footer">
                <span><kbd>Enter</kbd> open</span>
                <span><kbd>Esc</kbd> close</span>
                <span><kbd>↑</kbd><kbd>↓</kbd> move</span>
            </footer>
        </section>
    </div>
}

@code {
    private const int RecentLimit = 8;
    private const string RecentCategory = "Recent";
    private ElementReference _searchInput;
    private IJSObjectReference? _module;
    private DotNetObjectReference<CommandPaletteHost>? _dotNetReference;
    private CancellationTokenSource? _searchCancellation;
    private List<CommandPaletteCommand> _commands = [];
    private List<CommandPaletteCommand> _recentCommands = [];
    private bool _isOpen;
    private bool _isLoading;
    private string _query = string.Empty;
    private string? _errorMessage;
    private int _selectedIndex;

    private List<CommandPaletteCommand> DisplayCommands
    {
        get
        {
            var commands = string.IsNullOrWhiteSpace(_query)
                ? _recentCommands.Select(command => command with { Category = RecentCategory }).Concat(_commands)
                : _commands;

            return commands
                .GroupBy(command => command.Id, StringComparer.OrdinalIgnoreCase)
                .Select(group => group.First())
                .ToList();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./Components/CommandPalette/CommandPaletteHost.razor.js");
        _dotNetReference = DotNetObjectReference.Create(this);
        await _module.InvokeVoidAsync("registerCommandPaletteShortcuts", _dotNetReference);
    }

    [JSInvokable]
    public Task OpenFromShortcut()
    {
        return OpenAsync();
    }

    private async Task OpenAsync()
    {
        _isOpen = true;
        _errorMessage = null;
        _query = string.Empty;
        await LoadRecentCommandsAsync();
        await SearchAsync();
        await FocusSearchAsync();
    }

    private async Task CloseAsync()
    {
        _isOpen = false;
        _query = string.Empty;
        _searchCancellation?.Cancel();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnQueryChangedAsync(ChangeEventArgs args)
    {
        _query = args.Value?.ToString() ?? string.Empty;
        _searchCancellation?.Cancel();
        _searchCancellation?.Dispose();
        _searchCancellation = new CancellationTokenSource();
        var token = _searchCancellation.Token;

        try
        {
            await Task.Delay(180, token);
            await SearchAsync(token);
        }
        catch (OperationCanceledException)
        {
            // Another keystroke started a newer search.
        }
    }

    private async Task SearchAsync(CancellationToken cancellationToken = default)
    {
        _isLoading = true;
        _errorMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var currentPath = GetCurrentPath();
            var results = await CommandPaletteService.SearchAsync(new CommandPaletteSearchRequest(
                authState.User,
                _query,
                currentPath,
                CancellationToken: cancellationToken));

            _commands = results.ToList();
            _selectedIndex = 0;
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch
        {
            _commands = [];
            _errorMessage = "Command search could not be loaded right now.";
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
        {
            await CloseAsync();
            return;
        }

        if (DisplayCommands.Count == 0)
        {
            return;
        }

        if (args.Key == "ArrowDown")
        {
            _selectedIndex = Math.Min(_selectedIndex + 1, DisplayCommands.Count - 1);
        }
        else if (args.Key == "ArrowUp")
        {
            _selectedIndex = Math.Max(_selectedIndex - 1, 0);
        }
        else if (args.Key == "Enter")
        {
            await ExecuteAsync(DisplayCommands[_selectedIndex]);
        }
    }

    private async Task ExecuteAsync(CommandPaletteCommand command)
    {
        if (_module is not null)
        {
            await _module.InvokeVoidAsync("saveRecentCommand", command, RecentLimit);
        }

        _isOpen = false;
        NavigationManager.NavigateTo(command.Route);
    }

    private async Task LoadRecentCommandsAsync()
    {
        if (_module is null)
        {
            _recentCommands = [];
            return;
        }

        try
        {
            var commands = await _module.InvokeAsync<CommandPaletteCommand[]>("getRecentCommands");
            _recentCommands = commands
                .Where(command => !string.IsNullOrWhiteSpace(command.Id) && !string.IsNullOrWhiteSpace(command.Route))
                .Take(RecentLimit)
                .ToList();
        }
        catch
        {
            _recentCommands = [];
        }
    }

    private async Task FocusSearchAsync()
    {
        if (_module is null)
        {
            return;
        }

        await Task.Yield();
        await _module.InvokeVoidAsync("focusElement", _searchInput);
    }

    private string GetCurrentPath()
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        return string.IsNullOrWhiteSpace(relativePath) ? "/" : $"/{relativePath}";
    }

    public async ValueTask DisposeAsync()
    {
        _searchCancellation?.Cancel();
        _searchCancellation?.Dispose();
        _dotNetReference?.Dispose();

        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("unregisterCommandPaletteShortcuts");
                await _module.DisposeAsync();
            }
            catch
            {
                // The circuit may already be disposed during shutdown.
            }
        }
    }
}
