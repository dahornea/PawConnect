@page "/my-adoption-requests"
@using System.Security.Claims
@attribute [Authorize(Roles = "Adopter")]

<PageTitle>My Adoption Requests</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">My Adoption Requests</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Track the adoption requests you have submitted.</MudText>
        </div>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading adoption requests...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_requests.Count == 0)
        {
            <MudPaper Elevation="0" Class="empty-state pa-5">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h6">No adoption requests yet</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">When you submit a request, you can track its status here.</MudText>
                    <MudButton Href="/dogs" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search">Browse Dogs</MudButton>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudGrid Spacing="2" Class="request-summary-grid">
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="summary-card pa-3"><MudText Typo="Typo.caption" Color="Color.Secondary">Total</MudText><MudText Typo="Typo.h5">@_requests.Count</MudText></MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="summary-card pa-3"><MudText Typo="Typo.caption" Color="Color.Secondary">Pending</MudText><MudText Typo="Typo.h5">@PendingCount</MudText></MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="summary-card pa-3"><MudText Typo="Typo.caption" Color="Color.Secondary">Visits Confirmed</MudText><MudText Typo="Typo.h5">@VisitConfirmedCount</MudText></MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="summary-card pa-3"><MudText Typo="Typo.caption" Color="Color.Secondary">Completed/Closed</MudText><MudText Typo="Typo.h5">@(AcceptedCount + ClosedCount)</MudText></MudPaper>
                </MudItem>
            </MudGrid>

            <MudStack Spacing="2" Class="request-list">
                @foreach (var request in _requests)
                {
                    var imageUrl = GetImageUrl(request.Dog);

                    <MudCard Class="request-card">
                        <MudCardContent Class="request-card-content">
                            <div class="request-card-layout">
                                <section class="request-dog-section" aria-label="Dog information">
                                    <div class="request-dog-image" aria-label="@GetDogImageLabel(request)">
                                        <MudIcon Icon="@Icons.Material.Filled.Pets" Class="dog-placeholder-icon" />
                                        @if (imageUrl is not null)
                                        {
                                            <img src="@imageUrl" alt="@GetDogImageAlt(request)" loading="lazy" onerror="this.style.display='none';" />
                                        }
                                    </div>
                                    <div class="request-dog-copy">
                                        <MudText Typo="Typo.h6" Class="request-dog-name">@DisplayOrFallback(request.Dog?.Name, "Unknown dog")</MudText>
                                        <MudText Typo="Typo.body2" Class="request-shelter-name">@DisplayOrFallback(request.Dog?.Shelter?.Name, "Shelter not available")</MudText>
                                        <MudStack Row="true" Spacing="1" Class="request-dog-tags">
                                            @if (request.Dog is not null)
                                            {
                                                <span class="dog-mini-tag">@DogBreedFormatter.Format(request.Dog)</span>
                                            }
                                            @if (request.Dog is not null)
                                            {
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@GetDogStatusColor(request.Dog.Status)" Class="compact-chip">@GetDogStatusLabel(request.Dog.Status)</MudChip>
                                            }
                                        </MudStack>
                                    </div>
                                </section>

                                <section class="request-details-section" aria-label="Request details">
                                    <div class="request-detail-row">
                                        <span class="request-detail-label">Reason</span>
                                        <span class="request-detail-value">@GetRequestSummary(request)</span>
                                    </div>
                                    <div class="request-detail-row">
                                        <span class="request-detail-label">Hours alone</span>
                                        <span class="request-detail-value">@FormatHoursAlone(request.HoursAlonePerDay)</span>
                                    </div>
                                    <div class="request-detail-row">
                                        <span class="request-detail-label">Preferred visit</span>
                                        <span class="request-detail-value">@FormatVisitDateTime(request.PreferredVisitDateTime)</span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(request.AdditionalInformation))
                                    {
                                        <div class="request-detail-row">
                                            <span class="request-detail-label">Note</span>
                                            <span class="request-detail-value">@TrimText(request.AdditionalInformation, 120)</span>
                                        </div>
                                    }
                                    @if (request.VisitReminderSentAt.HasValue)
                                    {
                                        <div class="request-detail-row">
                                            <span class="request-detail-label">Reminder</span>
                                            <span class="request-detail-value">@FormatDateTime(request.VisitReminderSentAt.Value)</span>
                                        </div>
                                    }
                                    <MudAlert Severity="@GetProgressSeverity(request)" Variant="Variant.Outlined" Dense="true" Class="request-progress-note">
                                        @GetRequestProgressText(request)
                                    </MudAlert>
                                </section>

                                <aside class="request-status-section" aria-label="Request status and actions">
                                    <MudStack Row="true" Spacing="1" Class="request-chip-row">
                                        <MudChip T="string" Color="@GetStatusColor(request.Status)" Size="Size.Small" Class="compact-chip status-chip">@GetRequestStatusLabel(request.Status)</MudChip>
                                        @if (ShouldShowVisitStatus(request.VisitStatus))
                                        {
                                            <MudChip T="string" Color="@GetVisitStatusColor(request.VisitStatus)" Size="Size.Small" Variant="Variant.Outlined" Class="compact-chip">@GetVisitStatusLabel(request.VisitStatus)</MudChip>
                                        }
                                    </MudStack>

                                    <div class="request-date-stack">
                                        <div>
                                            <span class="request-date-label">Created</span>
                                            <span class="request-date-value">@FormatDateTime(request.CreatedAt)</span>
                                        </div>
                                        <div>
                                            <span class="request-date-label">Updated</span>
                                            <span class="request-date-value">@FormatDateTime(request.UpdatedAt)</span>
                                        </div>
                                    </div>

                                    @if (CanCancelRequest(request))
                                    {
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.Cancel"
                                                   Class="cancel-request-button"
                                                   OnClick="@(() => CancelRequestAsync(request))">
                                            Cancel Request
                                        </MudButton>
                                    }
                                </aside>
                            </div>
                        </MudCardContent>
                    </MudCard>
                }
            </MudStack>
        }
    </MudStack>
</MudContainer>

