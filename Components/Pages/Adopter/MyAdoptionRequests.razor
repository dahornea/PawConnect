@page "/my-adoption-requests"
@using Microsoft.AspNetCore.Identity
@using PawConnect.Data
@attribute [Authorize(Roles = "Adopter")]
@inject IAdoptionRequestService AdoptionRequestService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject ISnackbar Snackbar

<PageTitle>My Adoption Requests</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">My Adoption Requests</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Track the adoption requests you have submitted.</MudText>
        </div>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading adoption requests...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_requests.Count == 0)
        {
            <MudAlert Severity="Severity.Info">You have not submitted any adoption requests yet.</MudAlert>
            <MudButton Href="/dogs" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search">Browse Dogs</MudButton>
        }
        else
        {
            <MudTable Items="_requests" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Dog</MudTh>
                    <MudTh>Shelter</MudTh>
                    <MudTh>Message</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Created</MudTh>
                    <MudTh>Updated</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Dog">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Size="Size.Large">
                                <MudImage Src="@GetImageUrl(context.Dog)" Alt="@context.Dog?.Name" />
                            </MudAvatar>
                            <MudText Typo="Typo.body2">@context.Dog?.Name</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Shelter">@context.Dog?.Shelter?.Name</MudTd>
                    <MudTd DataLabel="Message">@(string.IsNullOrWhiteSpace(context.Message) ? "-" : context.Message)</MudTd>
                    <MudTd DataLabel="Status"><MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip></MudTd>
                    <MudTd DataLabel="Created">@context.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</MudTd>
                    <MudTd DataLabel="Updated">@context.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</MudTd>
                    <MudTd>
                        @if (context.Status == AdoptionRequestStatus.Pending)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Cancel" OnClick="@(() => CancelRequestAsync(context))">Cancel</MudButton>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudStack>
</MudContainer>

@code {
    private List<AdoptionRequest> _requests = [];
    private bool _isLoading = true;
    private string? _error;
    private string? _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(authState.User);
            _currentUserId = user?.Id;

            if (string.IsNullOrWhiteSpace(_currentUserId))
            {
                _error = "Current adopter account could not be found.";
                return;
            }

            _requests = await AdoptionRequestService.GetRequestsForAdopterAsync(_currentUserId);
        }
        catch
        {
            _error = "Adoption requests could not be loaded right now.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CancelRequestAsync(AdoptionRequest request)
    {
        if (string.IsNullOrWhiteSpace(_currentUserId))
        {
            Snackbar.Add("Current adopter account could not be found.", Severity.Error);
            return;
        }

        try
        {
            await AdoptionRequestService.CancelRequestAsync(request.Id, _currentUserId);
            request.Status = AdoptionRequestStatus.Cancelled;
            request.UpdatedAt = DateTime.UtcNow;
            Snackbar.Add("Adoption request cancelled.", Severity.Success);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
        catch
        {
            Snackbar.Add("Adoption request could not be cancelled right now.", Severity.Error);
        }
    }

    private static string GetImageUrl(Dog? dog)
    {
        return dog?.Images.FirstOrDefault(i => i.IsMainImage)?.ImageUrl
            ?? dog?.Images.FirstOrDefault()?.ImageUrl
            ?? "https://placehold.co/100x100?text=Dog";
    }

    private static Color GetStatusColor(AdoptionRequestStatus status)
    {
        return status switch
        {
            AdoptionRequestStatus.Pending => Color.Warning,
            AdoptionRequestStatus.Accepted => Color.Success,
            AdoptionRequestStatus.Rejected => Color.Error,
            AdoptionRequestStatus.Cancelled => Color.Default,
            _ => Color.Default
        };
    }
}
