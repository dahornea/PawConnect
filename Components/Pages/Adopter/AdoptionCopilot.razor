@page "/adopter/copilot"
@using Microsoft.AspNetCore.Identity
@using PawConnect.Data
@using PawConnect.Entities
@attribute [Authorize(Roles = "Adopter")]

<PageTitle>Adoption Copilot</PageTitle>

<div class="adoption-copilot-page">
<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Adoption Copilot</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Describe the kind of dog you are looking for, and PawConnect will suggest suitable real matches.</MudText>
        </div>

        <MudPaper Elevation="0" Class="section-surface copilot-search-card pa-4">
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_query"
                              Label="What kind of dog are you looking for?"
                              Placeholder="Example: calm medium dog for apartment living near Cluj"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Lines="3"
                              Immediate="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.AutoAwesome"
                              UserAttributes="@CopilotInputAttributes" />

                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="copilot-actions">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Search"
                               Disabled="@(!CanAsk)"
                               OnClick="AskCopilotAsync">
                        @(_isAsking ? "Searching..." : "Ask Copilot")
                    </MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Default" Disabled="_isAsking" OnClick="ClearConversation">Clear</MudButton>
                    <MudSpacer />
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Results are checked against PawConnect dog data before display.</MudText>
                </MudStack>

                <div class="suggested-prompts" aria-label="Suggested Copilot prompts">
                    @foreach (var prompt in SuggestedPrompts)
                    {
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   Size="Size.Small"
                                   Disabled="_isAsking"
                                   OnClick="@(() => UsePromptAsync(prompt))">
                            @prompt
                        </MudButton>
                    }
                </div>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="0" Class="section-surface copilot-history-card pa-4">
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Primary" />
                    <div>
                        <MudText Typo="Typo.h6">Previous Copilot searches</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Recent searches are private to your adopter account.</MudText>
                    </div>
                    <MudSpacer />
                    @if (_isLoadingHistory)
                    {
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary" />
                    }
                </MudStack>

                @if (_recentSessions.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">No Copilot searches saved yet.</MudText>
                }
                else
                {
                    <div class="copilot-history-list">
                        @foreach (var session in _recentSessions)
                        {
                            <div class="copilot-history-item">
                                <div class="copilot-history-main">
                                    <MudText Typo="Typo.body2" Class="history-query">@session.QuerySummary</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatSessionMeta(session)</MudText>
                                </div>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Disabled="_isAsking"
                                           OnClick="@(() => RerunSessionAsync(session))">
                                    Run again
                                </MudButton>
                            </div>
                        }
                    </div>
                }
            </MudStack>
        </MudPaper>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }

        @if (_isAsking)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Finding PawConnect matches...</MudText>
            </MudStack>
        }
        else if (_response is not null)
        {
            <MudPaper Elevation="0" Class="section-surface copilot-response-card pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="2">
                    <span class="copilot-response-icon"><MudIcon Icon="@Icons.Material.Filled.Assistant" /></span>
                    <div>
                        <MudText Typo="Typo.h6">Copilot suggestions</MudText>
                        <MudText Typo="Typo.body2" Class="copilot-message">@_response.AssistantMessage</MudText>
                        <MudStack Row="true" Spacing="1" Class="copilot-source-chips">
                            @if (_response.UsedAiEnhancement)
                            {
                                <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Outlined">AI-assisted explanation</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">Rule-based fallback</MudChip>
                            }
                            @if (_response.UsedSemanticSearch)
                            {
                                <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">Semantic search</MudChip>
                            }
                            @if (_response.UsedToolCalling)
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Outlined">Used PawConnect data</MudChip>
                            }
                        </MudStack>
                        @if (!string.IsNullOrWhiteSpace(_response.FallbackReason))
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-2">@_response.FallbackReason</MudAlert>
                        }
                        @if (_response.AppliedConstraints?.Count > 0)
                        {
                            <MudStack Row="true" Spacing="1" Class="copilot-source-chips mt-2">
                                @foreach (var constraint in _response.AppliedConstraints)
                                {
                                    <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">@FormatConstraintChip(constraint)</MudChip>
                                }
                            </MudStack>
                        }
                    </div>
                </MudStack>
            </MudPaper>

            @if (_response.Results.Count == 0)
            {
                <MudPaper Elevation="0" Class="empty-state pa-5">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Color="Color.Secondary" Size="Size.Large" />
                        <MudText Typo="Typo.h6">No matching dogs found</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Try a broader request or browse the full dog list.</MudText>
                        <MudButton Href="/dogs" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Pets">Browse Dogs</MudButton>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudGrid Spacing="3">
                    @foreach (var result in _response.Results)
                    {
                        var dog = result.Dog;
                        var imageUrl = GetDogImageUrl(dog);
                        var matchedLabels = result.MatchedCriteria?.Select(criteria => criteria.Label).ToHashSet(StringComparer.OrdinalIgnoreCase) ?? [];
                        var evidenceDisplays = GetEvidenceDisplays(result.DisplayTags, result.Reasons, matchedLabels);
                        var cautionDisplays = GetCautionDisplays(result.CautionTags, dog.Status);
                        var chipReasons = evidenceDisplays.Where(IsShortReasonChip).Take(3).ToList();
                        var textReasons = evidenceDisplays.Where(reason => !IsShortReasonChip(reason)).Take(2).ToList();

                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Class="copilot-dog-card h-100">
                                <a class="dog-image-link" href="@GetDogDetailsUrl(dog.Id)" aria-label="@($"View details for {dog.Name}")">
                                    @if (imageUrl is null)
                                    {
                                        <div class="dog-image dog-image-placeholder">
                                            <MudIcon Icon="@Icons.Material.Filled.Pets" Color="Color.Primary" />
                                            <MudText Typo="Typo.caption">No image available</MudText>
                                        </div>
                                    }
                                    else
                                    {
                                        <MudCardMedia Image="@imageUrl" Class="dog-image dog-card-image" />
                                    }
                                </a>

                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" AlignItems="AlignItems.Start">
                                            <div>
                                                <MudText Typo="Typo.h6">@dog.Name</MudText>
                                                <MudText Typo="Typo.body2">@DogBreedFormatter.Format(dog), @DogAgeFormatter.Format(dog)</MudText>
                                            </div>
                                            <MudSpacer />
                                            <MudChip T="string" Color="@GetStatusColor(dog.Status)" Size="Size.Small">@dog.Status</MudChip>
                                        </MudStack>

                                        <MudText Typo="Typo.body2" Class="dog-shelter-line">@GetShelterLine(dog)</MudText>
                                        @if (result.DistanceKm.HasValue)
                                        {
                                            <MudText Typo="Typo.caption" Class="distance-line">@($"{result.DistanceKm.Value:0.#} km away")</MudText>
                                        }

                                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="match-chip-row">
                                            @if (!IsFilterMatchLabel(result.MatchLabel))
                                            {
                                                <span class="match-score-badge">@result.ScorePercent% match</span>
                                            }
                                            <MudChip T="string" Color="@GetMatchColor(result.MatchLabel)" Size="Size.Small">@result.MatchLabel</MudChip>
                                        </MudStack>

                                        <MudText Typo="Typo.body2" Class="next-action">@result.SuggestedNextAction</MudText>
                                        @if (chipReasons.Count > 0)
                                        {
                                            <div class="reason-list">
                                                @foreach (var reason in chipReasons)
                                                {
                                                    <span>@reason</span>
                                                }
                                            </div>
                                        }
                                        @if (textReasons.Count > 0)
                                        {
                                            <ul class="reason-text-list">
                                            @foreach (var reason in textReasons)
                                            {
                                                <li>@reason</li>
                                            }
                                            </ul>
                                        }
                                        @if (cautionDisplays.Count > 0)
                                        {
                                            <div class="reason-list caution-list">
                                                @foreach (var caution in cautionDisplays)
                                                {
                                                    <span>@caution</span>
                                                }
                                            </div>
                                        }
                                    </MudStack>
                                </MudCardContent>

                                <MudCardActions>
                                    <MudButton Href="@GetDogDetailsUrl(dog.Id)" Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Visibility">View Details</MudButton>
                                    <MudButton Variant="Variant.Text"
                                               Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.FactCheck"
                                               OnClick="@(() => ShowExplanationAsync(result))">
                                        Why this match?
                                    </MudButton>
                                    <MudSpacer />
                                    <MudTooltip Text="Helpful suggestion">
                                        <MudIconButton Icon="@Icons.Material.Filled.ThumbUp"
                                                       Variant="Variant.Text"
                                                       Color="@(IsFeedbackSelected(dog.Id, CopilotFeedbackType.Positive) ? Color.Success : Color.Default)"
                                                       Size="Size.Small"
                                                       OnClick="@(() => SubmitFeedbackAsync(result, CopilotFeedbackType.Positive))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Not helpful">
                                        <MudIconButton Icon="@Icons.Material.Filled.ThumbDown"
                                                       Variant="Variant.Text"
                                                       Color="@(IsFeedbackSelected(dog.Id, CopilotFeedbackType.Negative) ? Color.Warning : Color.Default)"
                                                       Size="Size.Small"
                                                       OnClick="@(() => SubmitFeedbackAsync(result, CopilotFeedbackType.Negative))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Not relevant">
                                        <MudIconButton Icon="@Icons.Material.Filled.Block"
                                                       Variant="Variant.Text"
                                                       Color="@(IsFeedbackSelected(dog.Id, CopilotFeedbackType.NotRelevant) ? Color.Error : Color.Default)"
                                                       Size="Size.Small"
                                                       OnClick="@(() => SubmitFeedbackAsync(result, CopilotFeedbackType.NotRelevant))" />
                                    </MudTooltip>
                                    <MudButton Variant="Variant.Text"
                                               Color="@GetFavoriteColor(dog.Id)"
                                               StartIcon="@GetFavoriteIcon(dog.Id)"
                                               OnClick="@(() => ToggleFavoriteAsync(dog))">
                                        @GetFavoriteText(dog.Id)
                                    </MudButton>
                                </MudCardActions>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            }
        }
    </MudStack>
</MudContainer>
</div>

