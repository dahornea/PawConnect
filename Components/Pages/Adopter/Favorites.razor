@page "/favorites"
@using Microsoft.AspNetCore.Identity
@using PawConnect.Data
@attribute [Authorize(Roles = "Adopter")]

<PageTitle>Favorite Dogs</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Favorite Dogs</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Dogs saved to your adopter profile.</MudText>
        </div>

        @if (_isLoading)
        {
            <AppLoadingState Message="Loading favorites..." />
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <AppErrorState Title="Favorite dogs could not be loaded" Message="@_error" OnRetry="LoadFavoritesAsync" />
        }
        else if (_favorites.Count == 0)
        {
            <AppEmptyState Title="No favorite dogs yet"
                           Message="Save dogs you want to compare or revisit before submitting an adoption request."
                           Icon="@Icons.Material.Filled.FavoriteBorder"
                           PrimaryActionText="Browse dogs"
                           PrimaryActionHref="/dogs"
                           PrimaryActionIcon="@Icons.Material.Filled.Search"
                           SecondaryActionText="Ask Copilot"
                           SecondaryActionHref="/adopter/copilot"
                           SecondaryActionIcon="@Icons.Material.Filled.Assistant"
                           Tips="@(new[] { "Use the heart icon on dog cards to save a profile.", "Favorites also help recommendations understand what you like." })" />
        }
        else
        {
            <MudGrid Spacing="3">
                @foreach (var favorite in _favorites)
                {
                    var dog = favorite.Dog;
                    if (dog is null)
                    {
                        continue;
                    }

                    var imageUrl = GetImageUrl(dog);

                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Class="favorite-card h-100">
                            <a class="dog-image-link" href="@($"/dogs/{dog.Id}")" aria-label="@($"View details for {dog.Name}")">
                                @if (imageUrl is null)
                                {
                                    <div class="dog-image dog-image-placeholder">
                                        <MudIcon Icon="@Icons.Material.Filled.Pets" Color="Color.Primary" />
                                        <MudText Typo="Typo.caption">No image available</MudText>
                                    </div>
                                }
                                else
                                {
                                    <MudCardMedia Image="@imageUrl" Class="dog-image dog-card-image" />
                                }
                            </a>
                            <MudCardContent>
                                <MudStack Spacing="1">
                                    <MudStack Row="true" AlignItems="AlignItems.Start">
                                        <MudText Typo="Typo.h6">@dog.Name</MudText>
                                        <MudSpacer />
                                        <MudChip T="string" Color="@GetStatusColor(dog.Status)" Size="Size.Small">@dog.Status</MudChip>
                                    </MudStack>
                                    <MudText Typo="Typo.body2">@DogBreedFormatter.Format(dog), @DogAgeFormatter.Format(dog)</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@dog.Size dog in @dog.Location</MudText>
                                </MudStack>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Href="@($"/dogs/{dog.Id}")" Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward">View Details</MudButton>
                                <MudSpacer />
                                <MudButton Variant="Variant.Text" Color="Color.Error" StartIcon="@Icons.Material.Filled.Favorite" OnClick="@(() => RemoveFavoriteAsync(dog))">Remove</MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudStack>
</MudContainer>

