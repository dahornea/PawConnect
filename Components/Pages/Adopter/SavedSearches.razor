@page "/adopter/saved-searches"
@attribute [Authorize(Roles = "Adopter")]

<PageTitle>Saved Searches</PageTitle>

<div class="saved-searches-page">
<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <div>
                    <MudText Typo="Typo.h4">Saved Searches</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Track dog searches and get notified when new public dogs match.</MudText>
                </div>
                <MudSpacer />
                <MudButton Href="/dogs" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search">Browse Dogs</MudButton>
            </MudStack>
        </div>

        @if (_isLoading)
        {
            <AppLoadingState Message="Loading saved searches..." />
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <AppErrorState Title="Saved searches could not be loaded" Message="@_error" OnRetry="LoadAsync" />
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="0" Class="section-surface pa-4 stat-card-soft">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Saved searches</MudText>
                        <MudText Typo="Typo.h4">@_stats.SavedSearches</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="0" Class="section-surface pa-4 stat-card-soft">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Alerts enabled</MudText>
                        <MudText Typo="Typo.h4">@_stats.SearchesWithAlerts</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="0" Class="section-surface pa-4 stat-card-soft">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">New matches</MudText>
                        <MudText Typo="Typo.h4">@_stats.NewMatches</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudPaper Elevation="0" Class="section-surface pa-4">
                @if (_searches.Count == 0)
                {
                    <AppEmptyState Title="No saved searches yet"
                                   Message="Save your dog search criteria to get matching alerts later. Start from the dog list, choose filters, then save the search."
                                   Icon="@Icons.Material.Filled.SavedSearch"
                                   IconColor="Color.Primary">
                        <MudButton Href="/dogs" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Search">Create from dog filters</MudButton>
                    </AppEmptyState>
                }
                else
                {
                    <MudTable Items="_searches" Hover="true" Dense="false" Class="table-shell" Breakpoint="Breakpoint.Sm">
                        <HeaderContent>
                            <MudTh>Name</MudTh>
                            <MudTh>Criteria</MudTh>
                            <MudTh>Matches</MudTh>
                            <MudTh>Alerts</MudTh>
                            <MudTh>Last checked</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Name">
                                <MudText Typo="Typo.subtitle2">@context.Name</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Created @FormatDate(context.CreatedAtUtc)</MudText>
                            </MudTd>
                            <MudTd DataLabel="Criteria">
                                <MudStack Row="true" Spacing="1" Class="criteria-chip-row">
                                    @foreach (var label in context.CriteriaLabels.Take(4))
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">@label</MudChip>
                                    }
                                    @if (context.CriteriaLabels.Count > 4)
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text">+@(context.CriteriaLabels.Count - 4)</MudChip>
                                    }
                                </MudStack>
                            </MudTd>
                            <MudTd DataLabel="Matches">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudChip T="string" Color="Color.Primary" Size="Size.Small">@context.TotalMatches total</MudChip>
                                    @if (context.NewMatches > 0)
                                    {
                                        <MudChip T="string" Color="Color.Warning" Size="Size.Small">@context.NewMatches new</MudChip>
                                    }
                                </MudStack>
                            </MudTd>
                            <MudTd DataLabel="Alerts">
                                <MudSwitch T="bool" Value="context.AlertsEnabled" ValueChanged="@(enabled => ToggleAlertsAsync(context, enabled))" Color="Color.Primary" />
                            </MudTd>
                            <MudTd DataLabel="Last checked">@FormatDate(context.LastEvaluatedAtUtc)</MudTd>
                            <MudTd>
                                <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                                    <MudButton Href="@($"/adopter/saved-searches/{context.Id}")" Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Visibility">Matches</MudButton>
                                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Primary" OnClick="@(() => EvaluateAsync(context.Id))" aria-label="Refresh matches" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeleteAsync(context))" aria-label="Delete saved search" />
                                </MudStack>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        }
    </MudStack>
</MudContainer>
</div>


