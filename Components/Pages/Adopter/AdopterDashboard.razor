@page "/adopter/dashboard"
@using Microsoft.AspNetCore.Identity
@using PawConnect.Data
@attribute [Authorize(Roles = "Adopter")]

<PageTitle>Adopter Dashboard</PageTitle>

<div class="adopter-dashboard">
<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading dashboard...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else
        {
            <section class="dashboard-hero pa-5">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudAvatar Size="Size.Large" Class="profile-avatar">
                        @if (string.IsNullOrWhiteSpace(_profile?.ProfileImageUrl))
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Person" />
                        }
                        else
                        {
                            <MudImage Src="@_profile.ProfileImageUrl" Alt="@DisplayName" />
                        }
                    </MudAvatar>
                    <div>
                        <MudText Typo="Typo.caption" Class="dashboard-kicker">Adopter workspace</MudText>
                        <MudText Typo="Typo.h4">Welcome, @DisplayName</MudText>
                        <MudText Typo="Typo.body1">Track saved dogs, recent views, and adoption requests from one calm place.</MudText>
                    </div>
                </MudStack>
            </section>

            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Class="stat-card">
                        <MudCardContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <span class="stat-icon"><MudIcon Icon="@Icons.Material.Filled.Favorite" /></span>
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Favorite dogs</MudText>
                                    <MudText Typo="Typo.h4">@_favoriteCount</MudText>
                                </div>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Class="stat-card">
                        <MudCardContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <span class="stat-icon"><MudIcon Icon="@Icons.Material.Filled.Assignment" /></span>
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Requests</MudText>
                                    <MudText Typo="Typo.h4">@_requestSummary.Total</MudText>
                                </div>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Class="stat-card">
                        <MudCardContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <span class="stat-icon warning"><MudIcon Icon="@Icons.Material.Filled.HourglassTop" /></span>
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Pending</MudText>
                                    <MudText Typo="Typo.h4">@_requestSummary.Pending</MudText>
                                </div>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Class="stat-card">
                        <MudCardContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <span class="stat-icon success"><MudIcon Icon="@Icons.Material.Filled.CheckCircle" /></span>
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Accepted</MudText>
                                    <MudText Typo="Typo.h4">@_requestSummary.Accepted</MudText>
                                </div>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>

            <MudPaper Elevation="0" Class="section-surface pa-4">
                <MudText Typo="Typo.h5" Class="section-title mb-3">Quick Actions</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Href="/dogs" Class="quick-action-button" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Search">Browse Dogs</MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Href="/favorites" Class="quick-action-button" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Favorite">View Favorites</MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Href="/my-adoption-requests" Class="quick-action-button" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Assignment">My Requests</MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Href="/adopter/profile" Class="quick-action-button" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.AccountCircle">Edit Profile</MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudPaper Elevation="0" Class="section-surface pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3 recommendation-header">
                    <div>
                        <MudText Typo="Typo.h5" Class="section-title">Recommended for you</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">A small shortlist based on your adopter profile.</MudText>
                    </div>
                    <MudSpacer />
                    <MudButton Href="/adopter/recommendations" Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward">View all recommendations</MudButton>
                </MudStack>

                @if (_profile is null)
                {
                    <MudPaper Elevation="0" Class="empty-state pa-4">
                        <MudText Typo="Typo.body1">Complete your profile to get better recommendations.</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Housing, city, and experience help PawConnect suggest better matches.</MudText>
                        <MudButton Href="/adopter/profile" Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AccountCircle">Edit Profile</MudButton>
                    </MudPaper>
                }
                else if (_recommendedDogs.Count == 0)
                {
                    <MudPaper Elevation="0" Class="empty-state pa-4">
                        <MudText Typo="Typo.body1">No recommendations found yet.</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Try browsing all dogs or updating your profile details.</MudText>
                    </MudPaper>
                }
                else
                {
                    <MudGrid Spacing="2">
                        @foreach (var recommendation in _recommendedDogs)
                        {
                            var dog = recommendation.Dog;
                            var imageUrl = GetDogImageUrl(dog);

                            <MudItem xs="12" sm="6" md="4">
                                <MudCard Class="preview-card recommendation-preview-card h-100">
                                    <a class="dog-image-link" href="@($"/dogs/{dog.Id}")" aria-label="@($"View details for {dog.Name}")">
                                        @if (imageUrl is null)
                                        {
                                            <div class="preview-image dog-image-placeholder">
                                                <MudIcon Icon="@Icons.Material.Filled.Pets" Color="Color.Primary" />
                                                <MudText Typo="Typo.caption">No image available</MudText>
                                            </div>
                                        }
                                        else
                                        {
                                            <MudCardMedia Image="@imageUrl" Class="preview-image dog-card-image" />
                                        }
                                    </a>
                                    <MudCardContent>
                                        <MudStack Spacing="1">
                                            <MudStack Row="true" AlignItems="AlignItems.Start">
                                                <div>
                                                    <MudText Typo="Typo.subtitle1">@dog.Name</MudText>
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@DogBreedFormatter.Format(dog), @DogAgeFormatter.Format(dog)</MudText>
                                                </div>
                                                <MudSpacer />
                                                <span class="match-score-badge">@recommendation.MatchPercentage% match</span>
                                            </MudStack>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@GetBestRecommendationReason(recommendation)</MudText>
                                        </MudStack>
                                    </MudCardContent>
                                    <MudCardActions>
                                        <MudButton Href="@($"/dogs/{dog.Id}")" Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Visibility">View Details</MudButton>
                                    </MudCardActions>
                                </MudCard>
                            </MudItem>
                        }
                    </MudGrid>
                }
            </MudPaper>

            <MudGrid Spacing="3">
                <MudItem xs="12" md="7">
                    <MudPaper Elevation="0" Class="section-surface pa-4 h-100">
                        <MudText Typo="Typo.h5" Class="section-title mb-3">Recent Adoption Requests</MudText>
                        @if (_recentRequests.Count == 0)
                        {
                            <MudPaper Elevation="0" Class="empty-state pa-4">
                                <MudText Typo="Typo.body1">You have not submitted any adoption requests yet.</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">When you apply for a dog, the latest updates will appear here.</MudText>
                            </MudPaper>
                        }
                        else
                        {
                            <MudTable Items="_recentRequests" Dense="true" Hover="true">
                                <HeaderContent>
                                    <MudTh>Dog</MudTh>
                                    <MudTh>Shelter</MudTh>
                                    <MudTh>Status</MudTh>
                                    <MudTh>Created</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Dog">@context.Dog?.Name</MudTd>
                                    <MudTd DataLabel="Shelter">@(context.Dog?.Shelter?.Name ?? "-")</MudTd>
                                    <MudTd DataLabel="Status">
                                        <MudChip T="string" Color="@GetRequestStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Created">@context.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="5">
                    <MudPaper Elevation="0" Class="section-surface pa-4 h-100">
                        <MudText Typo="Typo.h5" Class="section-title mb-3">Favorite Dogs</MudText>
                        @if (_recentFavorites.Count == 0)
                        {
                            <MudPaper Elevation="0" Class="empty-state pa-4">
                                <MudText Typo="Typo.body1">No favorite dogs yet.</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Save dogs from the public listing to build a shortlist.</MudText>
                            </MudPaper>
                        }
                        else
                        {
                            <MudStack Spacing="2">
                                @foreach (var favorite in _recentFavorites)
                                {
                                    @if (favorite.Dog is not null)
                                    {
                                        var favoriteImageUrl = GetDogImageUrl(favorite.Dog);

                                        <MudCard Class="preview-card">
                                            <MudCardContent>
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                                    <a class="avatar-link" href="@($"/dogs/{favorite.Dog.Id}")" aria-label="@($"View details for {favorite.Dog.Name}")">
                                                        <MudAvatar Size="Size.Large">
                                                            @if (favoriteImageUrl is null)
                                                            {
                                                                <MudIcon Icon="@Icons.Material.Filled.Pets" />
                                                            }
                                                            else
                                                            {
                                                                <MudImage Src="@favoriteImageUrl" Alt="@favorite.Dog.Name" />
                                                            }
                                                        </MudAvatar>
                                                    </a>
                                                    <div>
                                                        <MudText Typo="Typo.subtitle1">@favorite.Dog.Name</MudText>
                                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@DogBreedFormatter.Format(favorite.Dog) | @favorite.Dog.Location</MudText>
                                                    </div>
                                                    <MudSpacer />
                                                    <MudButton Href="@($"/dogs/{favorite.Dog.Id}")" Variant="Variant.Text" Color="Color.Primary">View Details</MudButton>
                                                </MudStack>
                                            </MudCardContent>
                                        </MudCard>
                                    }
                                }
                            </MudStack>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudPaper Elevation="0" Class="section-surface pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudText Typo="Typo.h5" Class="section-title">Recently Viewed Dogs</MudText>
                    <MudSpacer />
                    @if (_recentlyViewedDogs.Count > 0)
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Clear" Disabled="_isClearingRecentlyViewed" OnClick="ClearRecentlyViewedAsync">Clear Recently Viewed</MudButton>
                    }
                </MudStack>

                @if (_recentlyViewedDogs.Count == 0)
                {
                    <MudPaper Elevation="0" Class="empty-state pa-4">
                        <MudText Typo="Typo.body1">Recently viewed dogs will appear here.</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Open a dog profile to add it to your private recent history.</MudText>
                    </MudPaper>
                }
                else
                {
                    <MudGrid Spacing="2">
                        @foreach (var recentView in _recentlyViewedDogs)
                        {
                            @if (recentView.Dog is not null)
                            {
                                var recentImageUrl = GetDogImageUrl(recentView.Dog);

                                <MudItem xs="12" sm="6" md="4">
                                    <MudCard Class="preview-card h-100">
                                        <a class="dog-image-link" href="@($"/dogs/{recentView.Dog.Id}")" aria-label="@($"View details for {recentView.Dog.Name}")">
                                            @if (recentImageUrl is null)
                                            {
                                                <div class="preview-image dog-image-placeholder">
                                                    <MudIcon Icon="@Icons.Material.Filled.Pets" Color="Color.Primary" />
                                                    <MudText Typo="Typo.caption">No image available</MudText>
                                                </div>
                                            }
                                            else
                                            {
                                                <MudCardMedia Image="@recentImageUrl" Class="preview-image dog-card-image" />
                                            }
                                        </a>
                                        <MudCardContent>
                                            <MudStack Spacing="1">
                                                <MudStack Row="true" AlignItems="AlignItems.Start">
                                                    <div>
                                                        <MudText Typo="Typo.subtitle1">@recentView.Dog.Name</MudText>
                                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@DogBreedFormatter.Format(recentView.Dog) | @recentView.Dog.Location</MudText>
                                                    </div>
                                                    <MudSpacer />
                                                    <MudChip T="string" Color="@GetDogStatusColor(recentView.Dog.Status)" Size="Size.Small">@recentView.Dog.Status</MudChip>
                                                </MudStack>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Viewed @recentView.ViewedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</MudText>
                                            </MudStack>
                                        </MudCardContent>
                                        <MudCardActions>
                                            <MudButton Href="@($"/dogs/{recentView.Dog.Id}")" Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Visibility">View Details</MudButton>
                                        </MudCardActions>
                                    </MudCard>
                                </MudItem>
                            }
                        }
                    </MudGrid>
                }
            </MudPaper>
        }
    </MudStack>
</MudContainer>
</div>

