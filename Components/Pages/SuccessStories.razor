@page "/success-stories"
@inject IDogService DogService

<PageTitle>Success Stories</PageTitle>

<div class="success-stories-page">
<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <section class="success-hero pa-5">
            <MudText Typo="Typo.caption" Class="success-kicker">Positive outcomes</MudText>
            <MudText Typo="Typo.h4">Adoption Success Stories</MudText>
            <MudText Typo="Typo.body1">Celebrate dogs who found loving homes through PawConnect.</MudText>
        </section>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading success stories...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_adoptedDogs.Count == 0)
        {
            <MudPaper Elevation="0" Class="empty-state pa-6">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h6">No adoption success stories yet</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Adopted dogs will appear here when shelters add their success story details.</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudGrid Spacing="3">
                @foreach (var dog in _adoptedDogs)
                {
                    var imageUrl = GetDogImageUrl(dog);

                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Class="success-card h-100">
                            @if (imageUrl is null)
                            {
                                <div class="success-image dog-image-placeholder">
                                    <MudIcon Icon="@Icons.Material.Filled.Pets" Color="Color.Primary" />
                                    <MudText Typo="Typo.caption">No image available</MudText>
                                </div>
                            }
                            else
                            {
                                <MudCardMedia Image="@imageUrl" Class="success-image" />
                            }
                            <MudCardContent>
                                <MudStack Spacing="2">
                                    <MudStack Row="true" AlignItems="AlignItems.Start">
                                        <div>
                                            <MudText Typo="Typo.h6">@dog.Name</MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">@dog.Breed</MudText>
                                        </div>
                                        <MudSpacer />
                                        <MudChip T="string" Color="Color.Default" Size="Size.Small">Adopted</MudChip>
                                    </MudStack>

                                    <MudDivider />

                                    <MudText Typo="Typo.body2">Shelter: @(dog.Shelter?.Name ?? "-")</MudText>

                                    @if (dog.AdoptedAt.HasValue)
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Adopted: @dog.AdoptedAt.Value.ToLocalTime().ToString("dd MMM yyyy")</MudText>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(dog.Description))
                                    {
                                        <MudText Typo="Typo.body2">@dog.Description</MudText>
                                    }

                                    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
                                        @(string.IsNullOrWhiteSpace(dog.SuccessStoryText)
                                            ? "This dog has found a loving home through PawConnect."
                                            : dog.SuccessStoryText)
                                    </MudAlert>
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudStack>
</MudContainer>
</div>

@code {
    private List<Dog> _adoptedDogs = [];
    private bool _isLoading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _adoptedDogs = await DogService.GetAdoptedDogsAsync();
        }
        catch
        {
            _error = "Success stories could not be loaded right now.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string? GetDogImageUrl(Dog dog)
    {
        return dog.Images
            .Where(i => IsValidImageUrl(i.ImageUrl))
            .OrderByDescending(i => i.IsMainImage)
            .ThenBy(i => i.Id)
            .Select(i => i.ImageUrl)
            .FirstOrDefault();
    }

    private static bool IsValidImageUrl(string? imageUrl)
    {
        if (string.IsNullOrWhiteSpace(imageUrl) ||
            imageUrl.Contains("placehold.co", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        return Uri.TryCreate(imageUrl, UriKind.Absolute, out var uri) &&
            (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);
    }
}
