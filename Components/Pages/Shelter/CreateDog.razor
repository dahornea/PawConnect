@page "/shelter/dogs/create"
@using Microsoft.AspNetCore.Identity
@using PawConnect.Data
@attribute [Authorize(Roles = "Shelter")]

<PageTitle>Create Dog</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Create Dog</MudText>
            <MudText Typo="Typo.body2">Add a new dog profile for your shelter.</MudText>
        </div>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Preparing form...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else
        {
            <MudCard Class="form-card">
                <MudCardContent>
                    @if (!string.IsNullOrWhiteSpace(_formError))
                    {
                        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-3">
                            @_formError
                        </MudAlert>
                    }
                    <MudForm @ref="_form">
                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <MudTextField Label="Name"
                                              @bind-Value="_model.Name"
                                              @bind-Value:after="ClearDogNameError"
                                              Required="true"
                                              RequiredError="Name is required."
                                              Error="@HasNameError"
                                              ErrorText="@_nameError"
                                              Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudStack Spacing="1">
                                    <MudAutocomplete T="DogBreed"
                                                     Label="Breed"
                                                     Value="_selectedBreed"
                                                     ValueChanged="OnBreedSelected"
                                                     SearchFunc="SearchBreedOptionsAsync"
                                                     ToStringFunc="FormatBreedOption"
                                                     Clearable="true"
                                                     CoerceText="true"
                                                     ResetValueOnEmptyText="true"
                                                     Required="@(!_useCustomBreed)"
                                                     RequiredError="Select a breed or use a custom breed name."
                                                     Error="@HasBreedError"
                                                     ErrorText="@_breedError"
                                                     Variant="Variant.Outlined"
                                                     Disabled="@_useCustomBreed"
                                                     Adornment="Adornment.Start"
                                                     AdornmentIcon="@Icons.Material.Filled.Pets"
                                                     Placeholder="Search breed" />
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudCheckBox T="bool"
                                                     Label="Mixed breed"
                                                     Value="_model.IsMixedBreed"
                                                     ValueChanged="OnMixedBreedChanged"
                                                     Disabled="@IsMixedBreedDisabled"
                                                     Color="Color.Primary" />
                                        <MudCheckBox T="bool"
                                                     Label="Use custom breed name"
                                                     Value="_useCustomBreed"
                                                     ValueChanged="OnUseCustomBreedChanged"
                                                     Color="Color.Primary" />
                                    </MudStack>
                                    @if (CanUseSecondaryBreed)
                                    {
                                        <MudAutocomplete T="DogBreed"
                                                         Label="Secondary breed (optional)"
                                                         Value="_selectedSecondaryBreed"
                                                         ValueChanged="OnSecondaryBreedSelected"
                                                         SearchFunc="SearchSecondaryBreedOptionsAsync"
                                                         ToStringFunc="FormatBreedOption"
                                                         Clearable="true"
                                                         CoerceText="true"
                                                         ResetValueOnEmptyText="true"
                                                         Variant="Variant.Outlined"
                                                         Adornment="Adornment.Start"
                                                         AdornmentIcon="@Icons.Material.Filled.Pets"
                                                         Placeholder="Optional second known breed" />
                                    }
                                    @if (_useCustomBreed)
                                    {
                                        <MudTextField Label="Custom breed name"
                                                      @bind-Value="_model.CustomBreedName"
                                                      @bind-Value:after="ClearBreedError"
                                                      Required="true"
                                                      RequiredError="Custom breed name is required."
                                                      Error="@HasBreedError"
                                                      ErrorText="@_breedError"
                                                      Variant="Variant.Outlined"
                                                      HelperText="Use this only when the breed is not available in the list." />
                                    }
                                </MudStack>
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudNumericField T="int" Label="Age Years"
                                                 @bind-Value="_model.AgeYears"
                                                 @bind-Value:after="ClearAgeErrors"
                                                 Min="0"
                                                 Max="30"
                                                 Error="@HasAgeYearsError"
                                                 ErrorText="@_ageYearsError"
                                                 Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudNumericField T="int" Label="Age Months"
                                                 @bind-Value="_model.AgeMonths"
                                                 @bind-Value:after="ClearAgeErrors"
                                                 Min="0"
                                                 Max="11"
                                                 Error="@HasAgeMonthsError"
                                                 ErrorText="@_ageMonthsError"
                                                 Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="DogSize" Label="Size" @bind-Value="_model.Size" Required="true" Variant="Variant.Outlined">
                                    @foreach (var size in Enum.GetValues<DogSize>())
                                    {
                                        <MudSelectItem Value="@size">@size</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="DogStatus" Label="Status" @bind-Value="_model.Status" Required="true" Variant="Variant.Outlined">
                                    @foreach (var status in Enum.GetValues<DogStatus>())
                                    {
                                        <MudSelectItem Value="@status">@status</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="string" Label="Coat color" @bind-Value="_model.CoatColor" Clearable="true" Variant="Variant.Outlined">
                                    @foreach (var coatColor in DogCoatColorOptions.Values)
                                    {
                                        <MudSelectItem Value="@coatColor">@coatColor</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="Location"
                                              @bind-Value="_model.Location"
                                              @bind-Value:after="ClearLocationError"
                                              Required="true"
                                              RequiredError="Location is required."
                                              Error="@HasLocationError"
                                              ErrorText="@_locationError"
                                              Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="int?" Label="Preferred Food Type" @bind-Value="_model.PreferredFoodTypeId" Clearable="true" Variant="Variant.Outlined">
                                    @foreach (var foodType in _foodTypes)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)foodType.Id)">@foodType.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField T="int?" Label="Daily Food Amount (grams)"
                                                 @bind-Value="_model.DailyFoodAmountGrams"
                                                 @bind-Value:after="ClearDailyFoodAmountError"
                                                 Min="0"
                                                 Max="10000"
                                                 Error="@HasDailyFoodAmountError"
                                                 ErrorText="@_dailyFoodAmountError"
                                                 Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="Description" @bind-Value="_model.Description" Lines="4" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="Behavior Description" @bind-Value="_model.BehaviorDescription" Lines="3" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="Medical Status" @bind-Value="_model.MedicalStatus" Lines="3" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudDivider Class="my-2" />
                                <MudText Typo="Typo.h6" Class="content-title">Dog Images</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">Optionally add external image URLs or upload local dog photos. The first saved image becomes the main image.</MudText>
                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="9">
                                        <MudTextField Label="Image URL"
                                                      @bind-Value="_newImageUrl"
                                                      @bind-Value:after="ClearImageUrlError"
                                                      Error="@HasImageUrlError"
                                                      ErrorText="@_imageUrlError"
                                                      Variant="Variant.Outlined"
                                                      HelperText="Use a direct .jpg, .jpeg, .png, .webp, or .gif image link."
                                                      Placeholder="https://example.com/dog-photo.jpg" />
                                    </MudItem>
                                    <MudItem xs="12" md="3">
                                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddPhotoAlternate" OnClick="AddPendingImageUrl">Add Image</MudButton>
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudPaper Elevation="0" Class="dog-upload-panel pa-3">
                                            <MudStack Spacing="1">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudIcon Icon="@Icons.Material.Filled.UploadFile" Color="Color.Primary" />
                                                    <MudText Typo="Typo.subtitle2">Upload image files</MudText>
                                                </MudStack>
                                                <InputFile OnChange="OnImageFilesSelected"
                                                           multiple
                                                           accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp"
                                                           class="dog-upload-input" />
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Supported files: JPG, PNG, WEBP. Maximum file size is configured by the server.</MudText>
                                                @if (HasImageUploadError)
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Error">@_imageUploadError</MudText>
                                                }
                                            </MudStack>
                                        </MudPaper>
                                    </MudItem>
                                </MudGrid>
                                @if (_pendingImageUrls.Count > 0)
                                {
                                    <MudGrid Spacing="2" Class="mt-2">
                                        @foreach (var imageUrl in _pendingImageUrls)
                                        {
                                            <MudItem xs="12" sm="6" md="4">
                                                <MudCard Class="image-card">
                                                    <MudCardMedia Image="@imageUrl" Height="150" />
                                                    <MudCardActions>
                                                        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@(() => RemovePendingImageUrl(imageUrl))">Remove</MudButton>
                                                    </MudCardActions>
                                                </MudCard>
                                            </MudItem>
                                        }
                                    </MudGrid>
                                }
                                @if (_pendingImageFiles.Count > 0)
                                {
                                    <MudStack Spacing="1" Class="mt-2">
                                        <MudText Typo="Typo.subtitle2">Selected upload files</MudText>
                                        @foreach (var file in _pendingImageFiles)
                                        {
                                            <MudPaper Elevation="0" Class="pending-upload-file pa-2">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                    <MudIcon Icon="@Icons.Material.Filled.Image" Color="Color.Primary" />
                                                    <MudText Typo="Typo.body2">@file.Name</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@($"{file.Size / 1024d:0.#} KB")</MudText>
                                                    <MudSpacer />
                                                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                                   Size="Size.Small"
                                                                   Color="Color.Default"
                                                                   OnClick="@(() => RemovePendingImageFile(file))"
                                                                   aria-label="@($"Remove {file.Name}")" />
                                                </MudStack>
                                            </MudPaper>
                                        }
                                    </MudStack>
                                }
                            </MudItem>
                        </MudGrid>
                    </MudForm>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" Disabled="_isSaving" OnClick="SaveAsync">Save</MudButton>
                    <MudButton Href="/shelter/dogs" Variant="Variant.Text" Disabled="_isSaving">Cancel</MudButton>
                </MudCardActions>
            </MudCard>
        }
    </MudStack>
</MudContainer>

