@page "/shelter/dogs/create"
@using Microsoft.AspNetCore.Identity
@using PawConnect.Data
@attribute [Authorize(Roles = "Shelter")]
@inject IDogService DogService
@inject IDogImageService DogImageService
@inject IFoodTypeService FoodTypeService
@inject IShelterService ShelterService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Create Dog</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Create Dog</MudText>
            <MudText Typo="Typo.body2">Add a new dog profile for your shelter.</MudText>
        </div>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Preparing form...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else
        {
            <MudCard Class="form-card">
                <MudCardContent>
                    <MudForm @ref="_form">
                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <MudTextField Label="Name" @bind-Value="_model.Name" Required="true" RequiredError="Name is required." Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Label="Breed" @bind-Value="_model.Breed" Required="true" RequiredError="Breed is required." Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudNumericField T="int" Label="Age Years" @bind-Value="_model.AgeYears" Min="0" Max="30" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="2">
                                <MudNumericField T="int" Label="Age Months" @bind-Value="_model.AgeMonths" Min="0" Max="11" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="DogSize" Label="Size" @bind-Value="_model.Size" Required="true" Variant="Variant.Outlined">
                                    @foreach (var size in Enum.GetValues<DogSize>())
                                    {
                                        <MudSelectItem Value="@size">@size</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="DogStatus" Label="Status" @bind-Value="_model.Status" Required="true" Variant="Variant.Outlined">
                                    @foreach (var status in Enum.GetValues<DogStatus>())
                                    {
                                        <MudSelectItem Value="@status">@status</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="Location" @bind-Value="_model.Location" Required="true" RequiredError="Location is required." Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="int?" Label="Preferred Food Type" @bind-Value="_model.PreferredFoodTypeId" Clearable="true" Variant="Variant.Outlined">
                                    @foreach (var foodType in _foodTypes)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)foodType.Id)">@foodType.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudNumericField T="int?" Label="Daily Food Amount (grams)" @bind-Value="_model.DailyFoodAmountGrams" Min="0" Max="10000" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="Description" @bind-Value="_model.Description" Lines="4" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="Behavior Description" @bind-Value="_model.BehaviorDescription" Lines="3" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField Label="Medical Status" @bind-Value="_model.MedicalStatus" Lines="3" Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudDivider Class="my-2" />
                                <MudText Typo="Typo.h6" Class="content-title">Dog Images</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">Optional image URLs saved with this dog profile.</MudText>
                                <MudGrid Spacing="2">
                                    <MudItem xs="12" md="9">
                                        <MudTextField Label="Image URL" @bind-Value="_newImageUrl" Variant="Variant.Outlined" Placeholder="https://example.com/dog-photo.jpg" />
                                    </MudItem>
                                    <MudItem xs="12" md="3">
                                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddPhotoAlternate" OnClick="AddPendingImageUrl">Add Image</MudButton>
                                    </MudItem>
                                </MudGrid>

                                @if (!string.IsNullOrWhiteSpace(_imageUrlError))
                                {
                                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">@_imageUrlError</MudAlert>
                                }

                                @if (_pendingImageUrls.Count > 0)
                                {
                                    <MudGrid Spacing="2" Class="mt-2">
                                        @foreach (var imageUrl in _pendingImageUrls)
                                        {
                                            <MudItem xs="12" sm="6" md="4">
                                                <MudCard Class="image-card">
                                                    <MudCardMedia Image="@imageUrl" Height="150" />
                                                    <MudCardActions>
                                                        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@(() => RemovePendingImageUrl(imageUrl))">Remove</MudButton>
                                                    </MudCardActions>
                                                </MudCard>
                                            </MudItem>
                                        }
                                    </MudGrid>
                                }
                            </MudItem>
                        </MudGrid>
                    </MudForm>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" Disabled="_isSaving" OnClick="SaveAsync">Save</MudButton>
                    <MudButton Href="/shelter/dogs" Variant="Variant.Text" Disabled="_isSaving">Cancel</MudButton>
                </MudCardActions>
            </MudCard>
        }
    </MudStack>
</MudContainer>

@code {
    private readonly Dog _model = new() { Size = DogSize.Medium, Status = DogStatus.Available };
    private List<FoodType> _foodTypes = [];
    private MudForm? _form;
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _error;
    private string? _newImageUrl;
    private string? _imageUrlError;
    private int? _shelterId;
    private List<string> _pendingImageUrls = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _shelterId = await GetCurrentShelterIdAsync();
            if (_shelterId is null)
            {
                _error = "No shelter profile is linked to this account.";
                return;
            }

            _foodTypes = await FoodTypeService.GetAllAsync();
        }
        catch
        {
            _error = "The dog form could not be loaded right now.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        if (_shelterId is null)
        {
            Snackbar.Add("Current shelter profile could not be found.", Severity.Error);
            return;
        }

        if (_form is not null)
        {
            await _form.ValidateAsync();
            if (!_form.IsValid)
            {
                return;
            }
        }

        _isSaving = true;

        try
        {
            if (!AddPendingImageUrlIfPresent())
            {
                return;
            }

            await DogService.CreateDogAsync(_model, _shelterId.Value);
            await SavePendingImagesAsync();
            Snackbar.Add("Dog profile saved.", Severity.Success);
            NavigationManager.NavigateTo("/shelter/dogs");
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
        catch
        {
            Snackbar.Add("Could not save dog profile. Please try again.", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void AddPendingImageUrl()
    {
        AddPendingImageUrlIfPresent(showEmptyMessage: true);
    }

    private bool AddPendingImageUrlIfPresent(bool showEmptyMessage = false)
    {
        _imageUrlError = null;

        if (string.IsNullOrWhiteSpace(_newImageUrl))
        {
            if (showEmptyMessage)
            {
                _imageUrlError = "Enter an image URL first.";
            }

            return true;
        }

        var imageUrl = _newImageUrl.Trim();
        if (!IsValidImageUrl(imageUrl))
        {
            _imageUrlError = "Image URL must be a valid http or https web address.";
            return false;
        }

        if (_pendingImageUrls.Contains(imageUrl, StringComparer.OrdinalIgnoreCase))
        {
            _imageUrlError = "This image has already been added for this dog.";
            return false;
        }

        _pendingImageUrls.Add(imageUrl);
        _newImageUrl = null;
        return true;
    }

    private void RemovePendingImageUrl(string imageUrl)
    {
        _pendingImageUrls.Remove(imageUrl);
    }

    private async Task SavePendingImagesAsync()
    {
        for (var index = 0; index < _pendingImageUrls.Count; index++)
        {
            await DogImageService.AddDogImageAsync(_model.Id, _shelterId!.Value, new DogImage
            {
                ImageUrl = _pendingImageUrls[index],
                IsMainImage = index == 0
            });
        }
    }

    private static bool IsValidImageUrl(string imageUrl)
    {
        return Uri.TryCreate(imageUrl, UriKind.Absolute, out var uri) &&
            (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);
    }

    private async Task<int?> GetCurrentShelterIdAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);
        if (user is null)
        {
            return null;
        }

        var shelter = await ShelterService.GetShelterForUserAsync(user.Id);
        return shelter?.Id;
    }
}
