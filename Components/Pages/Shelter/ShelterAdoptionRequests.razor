@page "/shelter/adoption-requests"
@attribute [Authorize(Roles = "Shelter")]

<PageTitle>Shelter Adoption Requests</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">Adoption Requests</MudText>
    <MudTable Items="_requests" Dense="true" Hover="true">
        <HeaderContent>
            <MudTh>Dog</MudTh>
            <MudTh>Adopter</MudTh>
            <MudTh>Status</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Dog">@context.DogName</MudTd>
            <MudTd DataLabel="Adopter">@context.AdopterEmail</MudTd>
            <MudTd DataLabel="Status"><MudChip T="string" Color="Color.Warning" Size="Size.Small">@context.Status</MudChip></MudTd>
            <MudTd><MudButton Variant="Variant.Text" Color="Color.Primary">Review</MudButton></MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">There are no adoption requests yet.</MudText>
        </NoRecordsContent>
    </MudTable>
</MudStack>

@code {
    private readonly List<RequestRow> _requests = [];

    private sealed record RequestRow(string DogName, string AdopterEmail, string Status);
}
