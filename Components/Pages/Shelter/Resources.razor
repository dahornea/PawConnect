@page "/shelter/resources"
@using Microsoft.AspNetCore.Identity
@using PawConnect.Data
@attribute [Authorize(Roles = "Shelter")]

<PageTitle>Resources</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Resources</MudText>
            <MudText Typo="Typo.body2">Manage shelter stock, categories, food types, and low-stock thresholds.</MudText>
        </div>

        <MudPaper Elevation="0" Class="section-surface import-export-card pa-4">
            <MudStack Spacing="3">
                <div>
                    <MudText Typo="Typo.h6" Class="content-title">Resource records</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Import or export resource stock records for your shelter only.</MudText>
                </div>
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="7">
                        <MudStack Spacing="2" Class="tool-section">
                            <div>
                                <MudText Typo="Typo.subtitle2" Class="tool-section-title">Import CSV</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Preview and validate stock records before importing.</MudText>
                            </div>
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="tool-actions">
                                <div class="file-picker-shell">
                                    <InputFile @key="_resourceImportInputKey" OnChange="OnResourceCsvSelectedAsync" accept=".csv" />
                                </div>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.FileUpload"
                                           Disabled="@(_isLoading || _isImporting || _shelterId is null)"
                                           OnClick="PreviewSelectedResourceFileAsync">
                                    Preview Import
                                </MudButton>
                                <MudButton Variant="Variant.Text"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Download"
                                           OnClick="DownloadResourceTemplateAsync">
                                    Download Template
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" md="5">
                        <MudStack Spacing="2" Class="tool-section">
                            <div>
                                <MudText Typo="Typo.subtitle2" Class="tool-section-title">Export</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Download stock records as CSV or a formatted PDF.</MudText>
                            </div>
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="tool-actions">
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.FileDownload"
                                           Disabled="@(_isLoading || _isExporting || _shelterId is null)"
                                           OnClick="ExportResourcesCsvAsync">
                                    Export CSV
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Secondary"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.PictureAsPdf"
                                           Disabled="@(_isLoading || _isExporting || _shelterId is null)"
                                           OnClick="ExportResourcesPdfAsync">
                                    Export PDF
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudStack>
        </MudPaper>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading resources...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else
        {
            @if (_importResult is not null)
            {
                <MudPaper Elevation="0" Class="section-surface pa-4">
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="flex-wrap">
                            <div>
                                <MudText Typo="Typo.h6">Resource CSV Preview</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @_importResult.TotalRows rows found, @_importResult.ValidRows valid, @_importResult.InvalidRows invalid.
                                </MudText>
                            </div>
                            <MudSpacer />
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Check"
                                       Disabled="@(_isImporting || _importResult.HasErrors || _importResult.ValidRows == 0 || _resourceImportFile is null)"
                                       OnClick="ConfirmResourceImportAsync">
                                Confirm Import
                            </MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Default" Disabled="_isImporting" OnClick="ClearResourceImportPreview">
                                Clear
                            </MudButton>
                        </MudStack>

                        @if (_importResult.HasErrors)
                        {
                            <MudAlert Severity="Severity.Warning">CSV contains validation errors. Please fix them and try again.</MudAlert>
                        }

                        <MudTable Items="_importResult.RowResults" Dense="true" Hover="true" Class="table-shell">
                            <HeaderContent>
                                <MudTh>Row</MudTh>
                                <MudTh>Action</MudTh>
                                <MudTh>Name</MudTh>
                                <MudTh>Category</MudTh>
                                <MudTh>Quantity</MudTh>
                                <MudTh>Status</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="row">
                                <MudTd DataLabel="Row">@row.RowNumber</MudTd>
                                <MudTd DataLabel="Action">@row.Action</MudTd>
                                <MudTd DataLabel="Name">@GetImportValue(row, "Name")</MudTd>
                                <MudTd DataLabel="Category">@GetImportValue(row, "Category")</MudTd>
                                <MudTd DataLabel="Quantity">@GetImportValue(row, "Quantity") @GetImportValue(row, "Unit")</MudTd>
                                <MudTd DataLabel="Status">
                                    @if (row.IsValid)
                                    {
                                        <MudChip T="string" Color="Color.Success" Size="Size.Small">Valid</MudChip>
                                    }
                                    else
                                    {
                                        <MudTooltip Text="@FormatImportErrors(row)">
                                            <MudChip T="string" Color="Color.Error" Size="Size.Small">Invalid</MudChip>
                                        </MudTooltip>
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudStack>
                </MudPaper>
            }

            <MudPaper Elevation="0" Class="section-surface resource-form pa-4">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">@(_model.Id == 0 ? "Add Resource" : "Edit Resource")</MudText>
                    @if (!string.IsNullOrWhiteSpace(_resourceFormError))
                    {
                        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                            @_resourceFormError
                        </MudAlert>
                    }
                    <MudForm @ref="_form" @key="_resourceFormKey">
                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="4">
                                <MudTextField Label="Name"
                                              @bind-Value="_model.Name"
                                              @bind-Value:after="ClearResourceNameError"
                                              Required="true"
                                              RequiredError="Name is required."
                                              Error="@HasResourceNameError"
                                              ErrorText="@_resourceNameError"
                                              Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="int?" Label="Category"
                                           Value="_selectedCategoryId"
                                           ValueChanged="OnCategoryChanged"
                                           Required="true"
                                           RequiredError="Category is required."
                                           Placeholder="Select category"
                                           Error="@HasResourceCategoryError"
                                           ErrorText="@_resourceCategoryError"
                                           Variant="Variant.Outlined">
                                    @foreach (var category in _categories)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)category.Id)">@category.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="int?" Label="Food Type"
                                           @bind-Value="_model.FoodTypeId"
                                           @bind-Value:after="ClearFoodTypeError"
                                           Clearable="true"
                                           Disabled="@(!IsFoodCategorySelected)"
                                           Error="@HasFoodTypeError"
                                           ErrorText="@_foodTypeError"
                                           Variant="Variant.Outlined">
                                    @foreach (var foodType in _foodTypes)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)foodType.Id)">@foodType.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudNumericField T="int?" Label="Quantity"
                                                 @bind-Value="_quantity"
                                                 @bind-Value:after="ClearQuantityError"
                                                 Required="true"
                                                 RequiredError="Quantity is required."
                                                 Placeholder="Enter quantity"
                                                 Min="1"
                                                 Error="@HasQuantityError"
                                                 ErrorText="@_quantityError"
                                                 Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudTextField Label="Unit"
                                              @bind-Value="_model.Unit"
                                              @bind-Value:after="ClearUnitError"
                                              Required="true"
                                              RequiredError="Unit is required."
                                              Error="@HasUnitError"
                                              ErrorText="@_unitError"
                                              Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudNumericField T="int?" Label="Low-Stock Threshold"
                                                 @bind-Value="_lowStockThreshold"
                                                 @bind-Value:after="ClearLowStockThresholdError"
                                                 Required="true"
                                                 RequiredError="Low-stock threshold is required."
                                                 Placeholder="Enter threshold"
                                                 Min="0"
                                                 Error="@HasLowStockThresholdError"
                                                 ErrorText="@_lowStockThresholdError"
                                                 Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="3">
                                <MudStack Row="true" Spacing="2" Class="mt-2">
                                    <MudButton ButtonType="ButtonType.Button" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" Disabled="_isSaving" OnClick="SaveAsync">@(_model.Id == 0 ? "Add" : "Save")</MudButton>
                                    @if (_model.Id != 0)
                                    {
                                        <MudButton ButtonType="ButtonType.Button" Variant="Variant.Text" Color="Color.Default" Disabled="_isSaving" OnClick="ResetFormAsync">Cancel</MudButton>
                                    }
                                </MudStack>
                            </MudItem>
                        </MudGrid>
                    </MudForm>
                </MudStack>
            </MudPaper>

            @if (_resources.Count == 0)
            {
                <MudPaper Elevation="0" Class="empty-state pa-5">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory" Color="Color.Secondary" Size="Size.Large" />
                        <MudText Typo="Typo.h6">No resources added yet</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Add food, medicine, blankets, or cleaning supplies to start tracking stock.</MudText>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudTable Items="_resources" Dense="true" Hover="true" Class="table-shell">
                    <HeaderContent>
                        <MudTh>Name</MudTh>
                        <MudTh>Category</MudTh>
                        <MudTh>Food Type</MudTh>
                        <MudTh>Quantity</MudTh>
                        <MudTh>Low Stock</MudTh>
                        <MudTh>Last Updated</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Name">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudText Typo="Typo.body2">@context.Name</MudText>
                                @if (IsLowStock(context))
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small">Low Stock</MudChip>
                                }
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Category">@context.ResourceCategory?.Name</MudTd>
                        <MudTd DataLabel="Food Type">@(context.FoodType?.Name ?? "-")</MudTd>
                        <MudTd DataLabel="Quantity">
                            <MudText Typo="Typo.body2" Color="@(IsLowStock(context) ? Color.Error : Color.Default)">@context.Quantity @context.Unit</MudText>
                        </MudTd>
                        <MudTd DataLabel="Low Stock">@context.LowStockThreshold @context.Unit</MudTd>
                        <MudTd DataLabel="Last Updated">@context.LastUpdatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</MudTd>
                        <MudTd>
                            <MudStack Row="true" Spacing="1">
                                <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" OnClick="@(() => EditResource(context))">Edit</MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Disabled="_isSaving" OnClick="@(() => ConfirmDeleteAsync(context))">Delete</MudButton>
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        }
    </MudStack>
</MudContainer>

