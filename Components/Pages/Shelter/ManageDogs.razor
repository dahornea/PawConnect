@page "/shelter/dogs"
@using Microsoft.AspNetCore.Identity
@using PawConnect.Data
@attribute [Authorize(Roles = "Shelter")]

<PageTitle>Manage Dogs</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Manage Dogs</MudText>
            <MudText Typo="Typo.body2">Create, edit, and review dogs assigned to your shelter.</MudText>
        </div>

        <MudPaper Elevation="0" Class="section-surface records-action-card pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2" Class="flex-wrap">
                <div>
                    <MudText Typo="Typo.h6" Class="content-title">Dog records</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Add, import, or export dog records for your shelter only.</MudText>
                </div>
                <MudButton Href="/shelter/dogs/create"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add">
                    Add Dog
                </MudButton>
            </MudStack>
        </MudPaper>

        @if (_completenessSummary is not null)
        {
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="section-surface pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Average completeness</MudText>
                        <MudText Typo="Typo.h5">@_completenessSummary.AverageScorePercent.ToString("0.#")%</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="section-surface pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Excellent profiles</MudText>
                        <MudText Typo="Typo.h5">@_completenessSummary.ExcellentCount</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="section-surface pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Need work</MudText>
                        <MudText Typo="Typo.h5">@(_completenessSummary.NeedsWorkCount + _completenessSummary.IncompleteCount)</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="section-surface pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Profiles reviewed</MudText>
                        <MudText Typo="Typo.h5">@_completenessSummary.TotalDogs</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }

        <MudPaper Elevation="0" Class="section-surface import-export-card pa-4">
            <MudGrid Spacing="3">
                <MudItem xs="12" md="7">
                    <MudStack Spacing="2" Class="tool-section">
                        <div>
                            <MudText Typo="Typo.subtitle2" Class="tool-section-title">Import CSV</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Preview and validate dog records before importing.</MudText>
                        </div>
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="tool-actions">
                            <div class="file-picker-shell">
                                <InputFile @key="_dogImportInputKey" OnChange="OnDogCsvSelectedAsync" accept=".csv" />
                            </div>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.FileUpload"
                                       Disabled="@(_isLoading || _isImporting || _shelterId is null)"
                                       OnClick="PreviewSelectedDogFileAsync">
                                Preview Import
                            </MudButton>
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Download"
                                       OnClick="DownloadDogTemplateAsync">
                                Download Template
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudItem>
                <MudItem xs="12" md="5">
                    <MudStack Spacing="2" Class="tool-section">
                        <div>
                            <MudText Typo="Typo.subtitle2" Class="tool-section-title">Export</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Download the current shelter dog list as CSV.</MudText>
                        </div>
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="tool-actions">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.FileDownload"
                                       Disabled="@(_isLoading || _isExporting || _shelterId is null)"
                                       OnClick="ExportDogsCsvAsync">
                                Export CSV
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Elevation="0" Class="section-surface filter-panel pa-3">
            <MudGrid Spacing="2">
                <MudItem xs="12" md="4">
                    <MudTextField Label="Search by name" @bind-Value="_searchTerm" Immediate="true" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudSelect T="DogStatus?" Label="Status" @bind-Value="_statusFilter" Clearable="true" Variant="Variant.Outlined">
                        @foreach (var status in Enum.GetValues<DogStatus>())
                        {
                            <MudSelectItem T="DogStatus?" Value="@((DogStatus?)status)">@status</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudSelect T="DogSize?" Label="Size" @bind-Value="_sizeFilter" Clearable="true" Variant="Variant.Outlined">
                        @foreach (var size in Enum.GetValues<DogSize>())
                        {
                            <MudSelectItem T="DogSize?" Value="@((DogSize?)size)">@size</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudSelect T="string" Label="Completeness" @bind-Value="_completenessFilter" Clearable="true" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Incomplete")">Incomplete</MudSelectItem>
                        <MudSelectItem Value="@("Needs Work")">Needs Work</MudSelectItem>
                        <MudSelectItem Value="@("Good")">Good</MudSelectItem>
                        <MudSelectItem Value="@("Excellent")">Excellent</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudSelect T="string" Label="Sort" @bind-Value="_sortOption" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("Name")">Name A-Z</MudSelectItem>
                        <MudSelectItem Value="@("CompletenessAsc")">Completeness low-high</MudSelectItem>
                        <MudSelectItem Value="@("CompletenessDesc")">Completeness high-low</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @if (_isLoading)
        {
            <AppLoadingState Message="Loading shelter dogs..." />
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else
        {
            @if (_importResult is not null)
            {
                <MudPaper Elevation="0" Class="section-surface pa-4">
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="flex-wrap">
                            <div>
                                <MudText Typo="Typo.h6">Dog CSV Preview</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @_importResult.TotalRows rows found, @_importResult.ValidRows valid, @_importResult.InvalidRows invalid.
                                </MudText>
                            </div>
                            <MudSpacer />
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Check"
                                       Disabled="@(_isImporting || _importResult.HasErrors || _importResult.ValidRows == 0 || _dogImportFile is null)"
                                       OnClick="ConfirmDogImportAsync">
                                Confirm Import
                            </MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Default" Disabled="_isImporting" OnClick="ClearDogImportPreview">
                                Clear
                            </MudButton>
                        </MudStack>

                        @if (_importResult.HasErrors)
                        {
                            <MudAlert Severity="Severity.Warning">CSV contains validation errors. Please fix them and try again.</MudAlert>
                        }

                        <MudTable Items="_importResult.RowResults" Dense="true" Hover="true" Class="table-shell">
                            <HeaderContent>
                                <MudTh>Row</MudTh>
                                <MudTh>Name</MudTh>
                                <MudTh>Breed</MudTh>
                                <MudTh>Age</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>Validation</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="row">
                                <MudTd DataLabel="Row">@row.RowNumber</MudTd>
                                <MudTd DataLabel="Name">@GetImportValue(row, "Name")</MudTd>
                                <MudTd DataLabel="Breed">@GetImportValue(row, "Breed")</MudTd>
                                <MudTd DataLabel="Age">@GetImportValue(row, "AgeYears") years, @GetImportValue(row, "AgeMonths") months</MudTd>
                                <MudTd DataLabel="Status">@GetImportValue(row, "Status")</MudTd>
                                <MudTd DataLabel="Validation">
                                    @if (row.IsValid)
                                    {
                                        <MudChip T="string" Color="Color.Success" Size="Size.Small">Valid</MudChip>
                                    }
                                    else
                                    {
                                        <MudTooltip Text="@FormatImportErrors(row)">
                                            <MudChip T="string" Color="Color.Error" Size="Size.Small">Invalid</MudChip>
                                        </MudTooltip>
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudStack>
                </MudPaper>
            }

            @if (!FilteredDogs.Any())
            {
                <AppEmptyState Title="@ManageDogsEmptyTitle"
                               Message="@ManageDogsEmptyMessage"
                               Icon="@ManageDogsEmptyIcon"
                               PrimaryActionText="@ManageDogsPrimaryActionText"
                               PrimaryActionHref="@ManageDogsPrimaryActionHref"
                               PrimaryActionIcon="@ManageDogsPrimaryActionIcon"
                               OnPrimaryAction="ManageDogsPrimaryActionAsync"
                               Tips="@ManageDogsEmptyTips" />
            }
            else
            {
                <MudTable Items="FilteredDogs" Dense="true" Hover="true" Class="table-shell">
                    <HeaderContent>
                        <MudTh>Dog</MudTh>
                        <MudTh>Breed</MudTh>
                        <MudTh>Age</MudTh>
                        <MudTh>Size</MudTh>
                        <MudTh>Location</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Profile Quality</MudTh>
                        <MudTh>Food</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Dog">
                            @{
                                var imageUrl = GetImageUrl(context);
                            }
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudAvatar Size="Size.Large">
                                    @if (imageUrl is null)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Pets" />
                                    }
                                    else
                                    {
                                        <MudImage Src="@imageUrl" Alt="@context.Name" />
                                    }
                                </MudAvatar>
                                <MudText Typo="Typo.body2">@context.Name</MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Breed">@DogBreedFormatter.Format(context)</MudTd>
                        <MudTd DataLabel="Age">@DogAgeFormatter.Format(context)</MudTd>
                        <MudTd DataLabel="Size">@context.Size</MudTd>
                        <MudTd DataLabel="Location">@context.Location</MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Profile Quality">
                            @if (TryGetCompleteness(context.Id, out var completeness))
                            {
                                <DogProfileCompletenessBadge Result="completeness" />
                                @if (completeness.ScorePercent < 70)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-1">
                                        @completeness.MissingItems.FirstOrDefault()?.Label
                                    </MudText>
                                }
                            }
                        </MudTd>
                        <MudTd DataLabel="Food">
                            <MudText Typo="Typo.body2">@(context.PreferredFoodType?.Name ?? "-")</MudText>
                            @if (context.DailyFoodAmountGrams.HasValue)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.DailyFoodAmountGrams.Value g/day</MudText>
                            }
                        </MudTd>
                        <MudTd>
                            <MudStack Row="true" Spacing="1">
                                <MudButton Href="@($"/shelter/dogs/edit/{context.Id}")" Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit">Edit</MudButton>
                                @if (TryGetCompleteness(context.Id, out var actionCompleteness) && actionCompleteness.ScorePercent < 70)
                                {
                                    <MudButton Href="@($"/shelter/dogs/edit/{context.Id}")" Variant="Variant.Text" Color="Color.Warning" StartIcon="@Icons.Material.Filled.FactCheck">Improve</MudButton>
                                }
                                <MudButton Href="@($"/shelter/transfers?dogId={context.Id}")" Variant="Variant.Text" Color="Color.Info" StartIcon="@Icons.Material.Filled.SwapHoriz">Transfer</MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Disabled="_isDeleting" OnClick="@(() => ConfirmDeleteAsync(context))">Delete</MudButton>
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        }
    </MudStack>
</MudContainer>

