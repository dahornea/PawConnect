@page "/shelter/dogs"
@attribute [Authorize(Roles = "Shelter")]
@inject IDogService DogService

<PageTitle>Manage Dogs</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Manage Dogs</MudText>
        <MudSpacer />
        <MudButton Href="/shelter/dogs/create" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">Add Dog</MudButton>
    </MudStack>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
    }

    <MudTable Items="_dogs" Dense="true" Hover="true" Loading="_isLoading">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Breed</MudTh>
            <MudTh>Size</MudTh>
            <MudTh>Status</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Breed">@context.Breed</MudTd>
            <MudTd DataLabel="Size">@context.Size</MudTd>
            <MudTd DataLabel="Status"><MudChip T="string" Color="Color.Primary" Size="Size.Small">@context.Status</MudChip></MudTd>
            <MudTd><MudButton Href="@($"/shelter/dogs/edit/{context.Id}")" Variant="Variant.Text" Color="Color.Primary">Edit</MudButton></MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">No dogs found.</MudText>
        </NoRecordsContent>
    </MudTable>
</MudStack>

@code {
    private List<Dog> _dogs = [];
    private bool _isLoading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _dogs = await DogService.GetAllDogsAsync();
        }
        catch
        {
            _error = "Dog data could not be loaded. Check migrations and database connection.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
