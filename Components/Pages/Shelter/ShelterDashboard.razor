@page "/shelter/dashboard"
@using Microsoft.AspNetCore.Identity
@using PawConnect.Data
@attribute [Authorize(Roles = "Shelter")]

<PageTitle>Shelter Dashboard</PageTitle>

<div class="shelter-dashboard">
<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <section class="shelter-hero pa-5">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <span class="hero-icon"><MudIcon Icon="@Icons.Material.Filled.Business" /></span>
                <div>
                    <MudText Typo="Typo.caption" Class="dashboard-kicker">Shelter operations</MudText>
                    <MudText Typo="Typo.h4">Shelter Dashboard</MudText>
                    <MudText Typo="Typo.body1">Monitor dogs, requests, and low-stock resources from one operational overview.</MudText>
                </div>
            </MudStack>
        </section>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading dashboard...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="3">
                    <MudCard Class="stat-card">
                        <MudCardContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <span class="stat-icon"><MudIcon Icon="@Icons.Material.Filled.Pets" /></span>
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Total dogs</MudText>
                                    <MudText Typo="Typo.h4">@_dogCount</MudText>
                                </div>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudCard Class="stat-card">
                        <MudCardContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <span class="stat-icon success"><MudIcon Icon="@Icons.Material.Filled.CheckCircle" /></span>
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Available</MudText>
                                    <MudText Typo="Typo.h4">@_availableDogCount</MudText>
                                </div>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudCard Class="stat-card">
                        <MudCardContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <span class="stat-icon warning"><MudIcon Icon="@Icons.Material.Filled.MarkEmailUnread" /></span>
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Pending requests</MudText>
                                    <MudText Typo="Typo.h4">@_pendingRequestCount</MudText>
                                </div>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudCard Class="stat-card">
                        <MudCardContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <span class="stat-icon danger"><MudIcon Icon="@Icons.Material.Filled.Inventory2" /></span>
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Low stock</MudText>
                                    <MudText Typo="Typo.h4">@_lowStockResources.Count</MudText>
                                </div>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>

            <MudPaper Elevation="0" Class="section-surface pa-4">
                <MudText Typo="Typo.h5" Class="section-title mb-3">Quick Actions</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudButton Href="/shelter/dogs" Class="quick-action-button" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Pets">Manage Dogs</MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudButton Href="/shelter/adoption-requests" Class="quick-action-button" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.MarkEmailRead">View Requests</MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudButton Href="/shelter/resources" Class="quick-action-button" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Inventory">Manage Resources</MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudPaper Elevation="0" Class="section-surface pa-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="report-card-stack">
                    <span class="stat-icon"><MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" /></span>
                    <div>
                        <MudText Typo="Typo.h5" Class="section-title">Shelter Summary Report</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Generate and email a PDF summary of your adoption requests, dog statuses, and resource stock.</MudText>
                    </div>
                    <MudSpacer />
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Send"
                               Disabled="@(_isSendingReport || _shelterId is null)"
                               OnClick="SendSummaryReportAsync">
                        @(_isSendingReport ? "Sending..." : "Send Summary Report")
                    </MudButton>
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="0" Class="section-surface pa-4">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h5" Class="section-title">Recent Reports</MudText>
                        <MudSpacer />
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Metadata only</MudText>
                    </MudStack>

                    @if (_recentReports.Count == 0)
                    {
                        <MudPaper Elevation="0" Class="empty-state pa-4">
                            <MudText Typo="Typo.body1">No reports have been generated yet.</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Sent shelter reports and exports will appear here as metadata.</MudText>
                        </MudPaper>
                    }
                    else
                    {
                        <MudTable Items="_recentReports" Dense="true" Hover="true" Class="table-shell">
                            <HeaderContent>
                                <MudTh>Report</MudTh>
                                <MudTh>Generated</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>Triggered by</MudTh>
                                <MudTh>Recipient</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Report">
                                    <MudText Typo="Typo.body2">@FormatReportType(context.ReportType)</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@(context.FileName ?? "No file stored")</MudText>
                                </MudTd>
                                <MudTd DataLabel="Generated">@FormatDateTime(context.GeneratedAt)</MudTd>
                                <MudTd DataLabel="Status">
                                    <MudChip T="string" Size="Size.Small" Color="@GetReportStatusColor(context)" Variant="Variant.Outlined">
                                        @GetReportStatusText(context)
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="Triggered by">@ReportHistoryTriggerLabels.Format(context.TriggeredBy)</MudTd>
                                <MudTd DataLabel="Recipient">@(context.RecipientEmail ?? "-")</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="0" Class="section-surface pa-4">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h5" Class="section-title">Low-Stock Resources</MudText>
                        <MudSpacer />
                        <MudButton Href="/shelter/resources" Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward">Manage Resources</MudButton>
                    </MudStack>

                    @if (_lowStockResources.Count == 0)
                    {
                        <MudPaper Elevation="0" Class="empty-state pa-4">
                            <MudText Typo="Typo.body1">All resource stock items are above their low-stock thresholds.</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Your shelter inventory looks healthy right now.</MudText>
                        </MudPaper>
                    }
                    else
                    {
                        <MudGrid Spacing="2">
                            @foreach (var resource in _lowStockResources)
                            {
                                <MudItem xs="12" md="6" lg="4">
                                    <MudAlert Class="resource-alert" Severity="Severity.Warning" Variant="Variant.Outlined">
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.subtitle1">@resource.Name</MudText>
                                            <MudText Typo="Typo.body2">@resource.ResourceCategory?.Name</MudText>
                                            <MudText Typo="Typo.body2">
                                                Current: @resource.Quantity @resource.Unit | Threshold: @resource.LowStockThreshold @resource.Unit
                                            </MudText>
                                        </MudStack>
                                    </MudAlert>
                                </MudItem>
                            }
                        </MudGrid>
                    }
                </MudStack>
            </MudPaper>
        }
    </MudStack>
</MudContainer>
</div>

