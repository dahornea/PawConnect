@page "/volunteer/tasks"
@attribute [Authorize(Roles = "Volunteer")]
@using PawConnect.Entities
@using PawConnect.Services

<PageTitle>Volunteer Tasks</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Volunteer Task Board</MudText>
            <MudText Typo="Typo.body2">Browse open shelter tasks, accept work, and update tasks assigned to you.</MudText>
        </div>

        @if (_isLoading)
        {
            <AppLoadingState Message="Loading volunteer tasks..." />
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <AppErrorState Title="Volunteer tasks could not be loaded" Message="@_error" OnRetry="LoadAsync" />
        }
        else if (_profile is null)
        {
            <AppEmptyState Title="Volunteer profile not active yet"
                           Message="No volunteer profile is linked to this account yet. Ask an administrator or shelter team to activate your volunteer profile."
                           Icon="@Icons.Material.Filled.Badge"
                           IconColor="Color.Info"
                           Tips="@(new[] { "Volunteer access is enabled by staff so task assignments stay controlled.", "Once active, open tasks and assigned work appear on this board." })" />
        }
        else
        {
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Available to accept</MudText>
                        <MudText Typo="Typo.h5">@_openTasks.Count</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Assigned to me</MudText>
                        <MudText Typo="Typo.h5">@_stats?.AssignedTasks</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">In progress</MudText>
                        <MudText Typo="Typo.h5">@_stats?.InProgressTasks</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Completed this week</MudText>
                        <MudText Typo="Typo.h5">@_stats?.CompletedThisWeek</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudPaper Elevation="0" Class="section-surface pa-3">
                @if (_openTasks.Count > 0)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3">
                        @_openTasks.Count available task@(_openTasks.Count == 1 ? " is" : "s are") ready to accept. Open tasks are shown first.
                    </MudAlert>
                }

                <MudTabs Rounded="true" Elevation="0" @bind-ActivePanelIndex="_activeTabIndex">
                    <MudTabPanel Text="@($"Available tasks ({_openTasks.Count})")">
                        @RenderTaskTable(
                            _openTasks,
                            showAccept: true,
                            "No available tasks right now",
                            "Open shelter tasks that match your volunteer profile will appear here.",
                            "Check back later",
                            "Shelter teams can publish walking, event, and support tasks.")
                    </MudTabPanel>
                    <MudTabPanel Text="@($"Assigned to me ({AssignedTaskCount})")">
                        @RenderTaskTable(
                            _myTasks.Where(task => task.Status is VolunteerTaskStatus.Assigned or VolunteerTaskStatus.InProgress).ToList(),
                            showAccept: false,
                            "No assigned tasks",
                            "Tasks you accept or shelter teams assign to you will appear here.",
                            "Start from Available tasks",
                            "Accepted tasks move into this tab automatically.")
                    </MudTabPanel>
                    <MudTabPanel Text="@($"Completed history ({CompletedTaskCount})")">
                        @RenderTaskTable(
                            _myTasks.Where(task => task.Status == VolunteerTaskStatus.Completed).ToList(),
                            showAccept: false,
                            "No completed tasks yet",
                            "Completed volunteer work will appear here for your history.",
                            "Complete assigned tasks",
                            "This history helps shelters track volunteer contribution.")
                    </MudTabPanel>
                </MudTabs>
            </MudPaper>
        }
    </MudStack>
</MudContainer>

@code {
    private RenderFragment RenderTaskTable(IReadOnlyList<VolunteerTaskDto> tasks, bool showAccept, string emptyTitle, string emptyDescription, string emptyHint, string emptyTip) => @<div class="pt-3">
        @if (tasks.Count == 0)
        {
            <AppEmptyState Title="@emptyTitle"
                           Message="@emptyDescription"
                           Icon="@Icons.Material.Filled.EventAvailable"
                           Compact="true"
                           Tips="@(new[] { emptyHint, emptyTip })" />
        }
        else
        {
            <MudTable Items="tasks" Dense="true" Hover="true" Class="table-shell" RowsPerPage="8" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Task</MudTh>
                    <MudTh>Shelter</MudTh>
                    <MudTh>Schedule</MudTh>
                    <MudTh>Priority</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate Context="task">
                    <MudTd DataLabel="Task">
                        <MudText Typo="Typo.body2">@task.Title</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatCategory(task.Category) @(!string.IsNullOrWhiteSpace(task.DogName) ? $"for {task.DogName}" : string.Empty)</MudText>
                    </MudTd>
                    <MudTd DataLabel="Shelter">@task.ShelterName</MudTd>
                    <MudTd DataLabel="Schedule">@FormatDateTime(task.ScheduledStartUtc) - @FormatTime(task.ScheduledEndUtc)</MudTd>
                    <MudTd DataLabel="Priority">
                        <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(task.Priority)" Variant="Variant.Outlined">@task.Priority</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(task.Status)">@FormatStatus(task.Status)</MudChip>
                    </MudTd>
                    <MudTd>
                        <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd" Class="flex-wrap">
                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => ViewTaskAsync(task.Id))">View</MudButton>
                            @if (showAccept && task.CanAccept)
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Disabled="_isSaving" OnClick="@(() => AcceptAsync(task.Id))">Accept</MudButton>
                            }
                            @if (task.CanStart)
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" Disabled="_isSaving" OnClick="@(() => StartAsync(task.Id))">Start</MudButton>
                            }
                            @if (task.CanComplete)
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success" Disabled="_isSaving" OnClick="@(() => CompleteAsync(task.Id))">Complete</MudButton>
                            }
                            @if (!showAccept && task.Status is VolunteerTaskStatus.Assigned or VolunteerTaskStatus.InProgress)
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Disabled="_isSaving" OnClick="@(() => AddCommentAsync(task.Id))">Note</MudButton>
                            }
                        </MudStack>
                    </MudTd>
                </RowTemplate>
                <PagerContent><MudTablePager /></PagerContent>
            </MudTable>
        }
    </div>;
}
