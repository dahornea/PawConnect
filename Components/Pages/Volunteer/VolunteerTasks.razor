@page "/volunteer/tasks"
@attribute [Authorize(Roles = "Volunteer")]
@using PawConnect.Entities
@using PawConnect.Services

<PageTitle>My Volunteer Tasks</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">My Volunteer Tasks</MudText>
            <MudText Typo="Typo.body2">Accept open shelter tasks and update work assigned to you.</MudText>
        </div>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading volunteer tasks...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_profile is null)
        {
            <MudAlert Severity="Severity.Info">
                No volunteer profile is linked to this account yet. Ask an administrator or shelter team to activate your volunteer profile.
            </MudAlert>
        }
        else
        {
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Assigned</MudText>
                        <MudText Typo="Typo.h5">@_stats?.AssignedTasks</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">In progress</MudText>
                        <MudText Typo="Typo.h5">@_stats?.InProgressTasks</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Completed this week</MudText>
                        <MudText Typo="Typo.h5">@_stats?.CompletedThisWeek</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Open tasks</MudText>
                        <MudText Typo="Typo.h5">@_openTasks.Count</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudPaper Elevation="0" Class="section-surface pa-3">
                <MudTabs Rounded="true" Elevation="0">
                    <MudTabPanel Text="Assigned to me">
                        @RenderTaskTable(_myTasks.Where(task => task.Status is VolunteerTaskStatus.Assigned or VolunteerTaskStatus.InProgress).ToList(), showAccept: false)
                    </MudTabPanel>
                    <MudTabPanel Text="Available tasks">
                        @RenderTaskTable(_openTasks, showAccept: true)
                    </MudTabPanel>
                    <MudTabPanel Text="Completed history">
                        @RenderTaskTable(_myTasks.Where(task => task.Status == VolunteerTaskStatus.Completed).ToList(), showAccept: false)
                    </MudTabPanel>
                </MudTabs>
            </MudPaper>
        }
    </MudStack>
</MudContainer>

@code {
    private RenderFragment RenderTaskTable(IReadOnlyList<VolunteerTaskDto> tasks, bool showAccept) => @<div class="pt-3">
        @if (tasks.Count == 0)
        {
            <MudPaper Elevation="0" Class="empty-state pa-5">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.EventAvailable" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h6">No tasks in this section</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Volunteer tasks will appear here when shelters schedule or assign them.</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudTable Items="tasks" Dense="true" Hover="true" Class="table-shell" RowsPerPage="8">
                <HeaderContent>
                    <MudTh>Task</MudTh>
                    <MudTh>Shelter</MudTh>
                    <MudTh>Schedule</MudTh>
                    <MudTh>Priority</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate Context="task">
                    <MudTd DataLabel="Task">
                        <MudText Typo="Typo.body2">@task.Title</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatCategory(task.Category) @(!string.IsNullOrWhiteSpace(task.DogName) ? $"for {task.DogName}" : string.Empty)</MudText>
                    </MudTd>
                    <MudTd DataLabel="Shelter">@task.ShelterName</MudTd>
                    <MudTd DataLabel="Schedule">@FormatDateTime(task.ScheduledStartUtc) - @FormatTime(task.ScheduledEndUtc)</MudTd>
                    <MudTd DataLabel="Priority">
                        <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(task.Priority)" Variant="Variant.Outlined">@task.Priority</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(task.Status)">@FormatStatus(task.Status)</MudChip>
                    </MudTd>
                    <MudTd>
                        <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd" Class="flex-wrap">
                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => ViewTaskAsync(task.Id))">View</MudButton>
                            @if (showAccept && task.CanAccept)
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Disabled="_isSaving" OnClick="@(() => AcceptAsync(task.Id))">Accept</MudButton>
                            }
                            @if (task.CanStart)
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" Disabled="_isSaving" OnClick="@(() => StartAsync(task.Id))">Start</MudButton>
                            }
                            @if (task.CanComplete)
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success" Disabled="_isSaving" OnClick="@(() => CompleteAsync(task.Id))">Complete</MudButton>
                            }
                            @if (!showAccept && task.Status is VolunteerTaskStatus.Assigned or VolunteerTaskStatus.InProgress)
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Disabled="_isSaving" OnClick="@(() => AddCommentAsync(task.Id))">Note</MudButton>
                            }
                        </MudStack>
                    </MudTd>
                </RowTemplate>
                <PagerContent><MudTablePager /></PagerContent>
            </MudTable>
        }
    </div>;
}
