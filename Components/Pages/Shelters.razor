@page "/shelters"
@using PawConnect.Data
@inject IShelterService ShelterService

<PageTitle>Shelters</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Shelters</MudText>
            <MudText Typo="Typo.body2">Find PawConnect demo shelter locations and public contact details.</MudText>
        </div>

        <AuthorizeView Context="shelterApplyContext">
            <Authorized>
                @if (!shelterApplyContext.User.IsInRole(IdentitySeedData.AdminRole) &&
                                !shelterApplyContext.User.IsInRole(IdentitySeedData.ShelterRole))
                {
                    <MudPaper Elevation="0" Class="section-surface pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Primary" />
                            <div>
                                <MudText Typo="Typo.subtitle1">Is your shelter missing from PawConnect?</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Submit a shelter application and our admin team will review it.</MudText>
                            </div>
                            <MudSpacer />
                            <MudButton Href="/shelters/apply" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Send">Apply as a Shelter</MudButton>
                        </MudStack>
                    </MudPaper>
                }
            </Authorized>
            <NotAuthorized>
                <MudPaper Elevation="0" Class="section-surface pa-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Primary" />
                        <div>
                            <MudText Typo="Typo.subtitle1">Is your shelter missing from PawConnect?</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Submit a shelter application and our admin team will review it.</MudText>
                        </div>
                        <MudSpacer />
                        <MudButton Href="/shelters/apply" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Send">Apply as a Shelter</MudButton>
                    </MudStack>
                </MudPaper>
            </NotAuthorized>
        </AuthorizeView>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading shelters...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_shelters.Count == 0)
        {
            <MudPaper Elevation="0" Class="empty-state pa-5">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h6">No shelters available yet</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Shelter profiles will appear here after they are added.</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudGrid Spacing="3">
                @foreach (var shelter in _shelters)
                {
                    <MudItem xs="12" md="6" lg="4">
                        <MudCard Class="shelter-card">
                            <MudCardContent>
                                <MudStack Spacing="2">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <span class="shelter-icon"><MudIcon Icon="@Icons.Material.Filled.Business" /></span>
                                        <div>
                                            <MudText Typo="Typo.h6">@shelter.Name</MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">@shelter.City</MudText>
                                        </div>
                                    </MudStack>
                                    <MudText Typo="Typo.body2">@shelter.Address</MudText>
                                    @if (!string.IsNullOrWhiteSpace(shelter.Description))
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@shelter.Description</MudText>
                                    }
                                    <MudStack Row="true" AlignItems="AlignItems.Center">
                                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">@shelter.Dogs.Count dogs</MudChip>
                                        @if (shelter.Latitude.HasValue && shelter.Longitude.HasValue)
                                        {
                                            <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">Map available</MudChip>
                                        }
                                    </MudStack>
                                </MudStack>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Href="@($"/shelters/{shelter.Id}")" Variant="Variant.Filled" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward">
                                    View Shelter
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudStack>
</MudContainer>

@code {
    private List<PawConnect.Entities.Shelter> _shelters = [];
    private bool _isLoading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _shelters = await ShelterService.GetAllSheltersAsync();
        }
        catch
        {
            _error = "Shelters could not be loaded right now.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
