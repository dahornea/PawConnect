@page "/shelters"
@using PawConnect.Data

<PageTitle>Shelters</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Shelters</MudText>
            <MudText Typo="Typo.body2">Find PawConnect shelter locations and public contact details.</MudText>
        </div>

        <MudPaper Elevation="0" Class="section-surface shelters-intro pa-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="shelters-intro-content">
                <span class="intro-icon"><MudIcon Icon="@Icons.Material.Filled.Business" /></span>
                <div>
                    <MudText Typo="Typo.h6" Class="content-title">Browse approved shelters</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">View each shelter's public contact details, location information, and currently listed dogs.</MudText>
                </div>
            </MudStack>
        </MudPaper>

        <AuthorizeView Context="shelterApplyContext">
            <Authorized>
                @if (!shelterApplyContext.User.IsInRole(IdentitySeedData.AdminRole) &&
                                !shelterApplyContext.User.IsInRole(IdentitySeedData.ShelterRole))
                {
                    <MudPaper Elevation="0" Class="section-surface shelter-cta pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="shelter-cta-content">
                            <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Primary" />
                            <div>
                                <MudText Typo="Typo.subtitle1">Is your shelter missing from PawConnect?</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Submit a shelter application and our admin team will review it.</MudText>
                            </div>
                            <MudSpacer />
                            <MudButton Href="/shelters/apply" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Send">Apply as a Shelter</MudButton>
                        </MudStack>
                    </MudPaper>
                }
            </Authorized>
            <NotAuthorized>
                <MudPaper Elevation="0" Class="section-surface shelter-cta pa-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="shelter-cta-content">
                        <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Primary" />
                        <div>
                            <MudText Typo="Typo.subtitle1">Is your shelter missing from PawConnect?</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Submit a shelter application and our admin team will review it.</MudText>
                        </div>
                        <MudSpacer />
                        <MudButton Href="/shelters/apply" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Send">Apply as a Shelter</MudButton>
                    </MudStack>
                </MudPaper>
            </NotAuthorized>
        </AuthorizeView>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading shelters...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_shelters.Count == 0)
        {
            <MudPaper Elevation="0" Class="empty-state pa-5">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h6">No shelters available yet</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Shelter profiles will appear here after they are added.</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            var filteredShelters = GetFilteredShelters().ToList();

            <MudPaper Elevation="0" Class="section-surface shelter-search-panel filter-toolbar pa-3">
                <MudStack Spacing="2">
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="filter-toolbar-row">
                        <MudButton Variant="@(_filtersOpen ? Variant.Filled : Variant.Outlined)"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.FilterList"
                                   OnClick="ToggleFilters">
                            @FilterButtonText
                        </MudButton>
                        <MudMenu Label="@($"Sort by: {CurrentSortLabel}")"
                                 Variant="Variant.Outlined"
                                 Color="Color.Default"
                                 EndIcon="@Icons.Material.Filled.ExpandMore"
                                 AnchorOrigin="Origin.BottomLeft"
                                 TransformOrigin="Origin.TopLeft">
                            <MudMenuItem OnClick="@(() => SetSort(ShelterSortOption.NameAsc))">Name A-Z</MudMenuItem>
                            <MudMenuItem OnClick="@(() => SetSort(ShelterSortOption.NameDesc))">Name Z-A</MudMenuItem>
                            <MudMenuItem OnClick="@(() => SetSort(ShelterSortOption.CityAsc))">City A-Z</MudMenuItem>
                            @if (_nearbyOrigin is not null)
                            {
                                <MudMenuItem OnClick="@(() => SetSort(ShelterSortOption.NearestFirst))">Nearest first</MudMenuItem>
                            }
                        </MudMenu>
                        <MudSpacer />
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="result-count-text">@GetShelterResultCountText(filteredShelters.Count)</MudText>
                        @if (HasActiveFilters)
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearFiltersAsync">Clear all</MudButton>
                        }
                    </MudStack>

                    @if (ActiveFilterChips.Count > 0)
                    {
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="active-filter-chip-row">
                            @foreach (var chip in ActiveFilterChips)
                            {
                                <span class="active-filter-chip">
                                    <span>@chip.Label</span>
                                    <button type="button" @onclick="chip.ClearAsync" aria-label="@($"Remove {chip.Label}")">
                                        <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                                    </button>
                                </span>
                            }
                        </MudStack>
                    }
                </MudStack>
            </MudPaper>

            @if (_filtersOpen)
            {
                <MudPaper Elevation="0" Class="section-surface shelter-search-panel filter-panel pa-4">
                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="6">
                            <MudTextField Label="Search shelters"
                                          @bind-Value="_searchTerm"
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Search"
                                          Placeholder="Search by name, neighborhood, city, or address" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudAutocomplete T="AddressSuggestion"
                                             Label="Near"
                                             Text="@_nearbySearchTerm"
                                             TextChanged="OnNearbyTextChanged"
                                             Value="@_selectedNearbySuggestion"
                                             ValueChanged="OnNearbySuggestionSelected"
                                             SearchFunc="SearchNearbySuggestionsAsync"
                                             ToStringFunc="GetSuggestionDisplayText"
                                             Variant="Variant.Outlined"
                                             Adornment="Adornment.Start"
                                             AdornmentIcon="@Icons.Material.Filled.TravelExplore"
                                             Placeholder="Search near city or address"
                                             MinCharacters="3"
                                             DebounceInterval="650"
                                             MaxItems="5"
                                             Clearable="true"
                                             CoerceText="true"
                                             ResetValueOnEmptyText="true"
                                             ShowProgressIndicator="true"
                                             Class="nearby-autocomplete">
                                <ItemTemplate Context="suggestion">
                                    <div class="nearby-suggestion">
                                        <MudText Typo="Typo.body2" Class="nearby-suggestion-primary">@GetSuggestionDisplayText(suggestion)</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="nearby-suggestion-secondary">@suggestion.DisplayName</MudText>
                                    </div>
                                </ItemTemplate>
                                <NoItemsTemplate>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">No suggestions found. You can still use the search icon.</MudText>
                                </NoItemsTemplate>
                            </MudAutocomplete>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudSelect T="int" Label="Radius" Value="_selectedRadiusKm" ValueChanged="OnRadiusChangedAsync" Variant="Variant.Outlined">
                                @foreach (var radius in RadiusOptions)
                                {
                                    <MudSelectItem Value="@radius">@($"{radius} km")</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="9" Class="nearby-action-cell">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="nearby-actions">
                                @if (HasManualNearbyText)
                                {
                                    <MudTooltip Text="Search typed address">
                                        <MudIconButton Icon="@Icons.Material.Filled.NearMe"
                                                       Color="Color.Primary"
                                                       Size="Size.Medium"
                                                       Disabled="@(_isFindingNearby || _isUsingBrowserLocation)"
                                                       OnClick="FindNearbyAsync"
                                                       aria-label="Search typed address" />
                                    </MudTooltip>
                                }
                                <MudTooltip Text="Your location is used only to filter nearby results.">
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Secondary"
                                               StartIcon="@Icons.Material.Filled.MyLocation"
                                               Disabled="@(_isFindingNearby || _isUsingBrowserLocation)"
                                               OnClick="UseMyLocationAsync">
                                        @(_isUsingBrowserLocation ? "Locating..." : "Use my location")
                                    </MudButton>
                                </MudTooltip>
                                @if (_nearbyOrigin is not null)
                                {
                                    <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.LocationOff" OnClick="ClearNearbyAsync">Clear address</MudButton>
                                }
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12">
                            @if (!string.IsNullOrWhiteSpace(_nearbyError))
                            {
                                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">@_nearbyError</MudAlert>
                            }
                            else if (HasManualNearbyText)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="nearby-inline-hint">
                                    Choose a suggestion to apply nearby filtering, or use the search icon for this typed address.
                                </MudText>
                            }
                        </MudItem>
                        <MudItem xs="12">
                            <MudDivider Class="my-2" />
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="filter-panel-actions">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.FilterAlt" OnClick="ApplySearchFilterAsync">Apply Filters</MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearFiltersAsync">Reset Filters</MudButton>
                                <MudSpacer />
                                <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="ToggleFilters">Done</MudButton>
                            </MudStack>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            }

            @if (filteredShelters.Count == 0)
            {
                <MudPaper Elevation="0" Class="empty-state pa-5">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Color="Color.Secondary" Size="Size.Large" />
                        <MudText Typo="Typo.h6">@EmptyStateTitle</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@EmptyStateSubtitle</MudText>
                        @if (!string.IsNullOrWhiteSpace(NearestShelterText))
                        {
                            <MudText Typo="Typo.body2" Class="nearby-nearest-text">@NearestShelterText</MudText>
                        }
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="1" Class="empty-state-actions">
                            @if (_nearbyOrigin is not null && SuggestedRadiusKm.HasValue)
                            {
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ZoomOutMap" OnClick="@(() => IncreaseNearbyRadiusAsync(SuggestedRadiusKm.Value))">
                                    Increase radius to @SuggestedRadiusKm.Value km
                                </MudButton>
                            }
                            @if (_nearbyOrigin is not null)
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.LocationOff" OnClick="ClearNearbyAsync">Clear address</MudButton>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearFiltersAsync">Reset filters</MudButton>
                            }
                        </MudStack>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <div class="shelter-grid-host">
                    <MudGrid Spacing="3" Class="shelter-grid">
                        @foreach (var shelter in filteredShelters)
                        {
                            var publicDogCount = GetPublicDogCount(shelter);
                            var distanceText = GetDistanceText(shelter);
                            <MudItem xs="12" md="6" lg="4" Class="shelter-grid-item">
                                <div class="shelter-card-shell">
                                    <MudCard Class="shelter-card">
                                        <MudCardContent Class="shelter-card-content">
                                            <MudStack Spacing="2" Class="shelter-card-body">
                                                <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="2">
                                                    <span class="shelter-icon"><MudIcon Icon="@Icons.Material.Filled.Business" /></span>
                                                    <div class="shelter-heading">
                                                        <MudText Typo="Typo.h6" Class="shelter-name">@shelter.Name</MudText>
                                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@GetShelterLocationLine(shelter)</MudText>
                                                    </div>
                                                </MudStack>

                                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="shelter-address">
                                                    <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Small" Color="Color.Secondary" />
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@shelter.Address</MudText>
                                                </MudStack>

                                                @if (!string.IsNullOrWhiteSpace(shelter.Description))
                                                {
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="shelter-description">@shelter.Description</MudText>
                                                }

                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="shelter-chip-row">
                                                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">@GetDogCountText(publicDogCount)</MudChip>
                                                    @if (!string.IsNullOrWhiteSpace(distanceText))
                                                    {
                                                        <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">@distanceText</MudChip>
                                                    }
                                                    @if (HasMapLocation(shelter))
                                                    {
                                                        <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">Map available</MudChip>
                                                    }
                                                </MudStack>
                                            </MudStack>
                                        </MudCardContent>
                                        <MudCardActions Class="shelter-card-actions">
                                            <MudButton Href="@($"/shelters/{shelter.Id}")" Variant="Variant.Filled" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward" FullWidth="true">
                                                View Shelter
                                            </MudButton>
                                        </MudCardActions>
                                    </MudCard>
                                </div>
                            </MudItem>
                        }
                    </MudGrid>
                </div>
            }
        }
    </MudStack>
</MudContainer>

