@page "/dogs"
@inject IDogService DogService

<PageTitle>Dogs</PageTitle>

<MudStack Spacing="3">
    <div class="page-header">
        <MudText Typo="Typo.h4">Dogs</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Browse dogs currently registered in the shelter system.</MudText>
    </div>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
    }
    else if (_dogs.Count == 0)
    {
        <MudAlert Severity="Severity.Info">No dogs are available yet.</MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var dog in _dogs)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard>
                        <MudCardMedia Image="@GetImageUrl(dog)" Class="dog-image" />
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@dog.Name</MudText>
                            <MudText Typo="Typo.body2">@dog.Breed, @dog.Age years old</MudText>
                            <MudChip T="string" Color="@GetStatusColor(dog.Status)" Size="Size.Small" Class="mt-2">@dog.Status</MudChip>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Href="@($"/dogs/{dog.Id}")" Variant="Variant.Text" Color="Color.Primary">Details</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudStack>

@code {
    private List<Dog> _dogs = [];
    private bool _isLoading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _dogs = await DogService.GetAvailableDogsAsync();
        }
        catch
        {
            _error = "Dog data could not be loaded. Apply migrations and update the database, then try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string GetImageUrl(Dog dog)
    {
        return dog.Images.FirstOrDefault(i => i.IsMainImage)?.ImageUrl ?? "https://placehold.co/800x500?text=Dog";
    }

    private static Color GetStatusColor(DogStatus status)
    {
        return status switch
        {
            DogStatus.Available => Color.Success,
            DogStatus.Reserved => Color.Warning,
            DogStatus.Adopted => Color.Default,
            DogStatus.InTreatment => Color.Info,
            _ => Color.Default
        };
    }
}
