@page "/dogs"
@using Microsoft.AspNetCore.Identity
@using PawConnect.Data

<PageTitle>Dogs</PageTitle>

<div class="dogs-page">
<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Dogs</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Browse dogs currently available or reserved in the shelter system.</MudText>
        </div>

        <MudPaper Elevation="0" Class="section-surface filter-toolbar pa-3">
            <MudStack Spacing="2">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="filter-toolbar-row">
                    <MudButton Variant="@(_filtersOpen ? Variant.Filled : Variant.Outlined)"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.FilterList"
                               OnClick="ToggleFilters">
                        @FilterButtonText
                    </MudButton>
                    <MudMenu Label="@($"Sort by: {CurrentSortLabel}")"
                             Variant="Variant.Outlined"
                             Color="Color.Default"
                             EndIcon="@Icons.Material.Filled.ExpandMore"
                             AnchorOrigin="Origin.BottomLeft"
                             TransformOrigin="Origin.TopLeft">
                        <MudMenuItem OnClick="@(() => SetSortAsync(DogSortOption.NameAsc))">Name A-Z</MudMenuItem>
                        <MudMenuItem OnClick="@(() => SetSortAsync(DogSortOption.NameDesc))">Name Z-A</MudMenuItem>
                        <MudMenuItem OnClick="@(() => SetSortAsync(DogSortOption.AgeAsc))">Age ascending</MudMenuItem>
                        <MudMenuItem OnClick="@(() => SetSortAsync(DogSortOption.AgeDesc))">Age descending</MudMenuItem>
                        <MudMenuItem OnClick="@(() => SetSortAsync(DogSortOption.BreedAsc))">Breed A-Z</MudMenuItem>
                        <MudMenuItem OnClick="@(() => SetSortAsync(DogSortOption.LocationAsc))">Location A-Z</MudMenuItem>
                        <MudMenuItem OnClick="@(() => SetSortAsync(DogSortOption.Status))">Status</MudMenuItem>
                        <MudMenuItem OnClick="@(() => SetSortAsync(DogSortOption.NewestFirst))">Newest first</MudMenuItem>
                        @if (_nearbyOrigin is not null)
                        {
                            <MudMenuItem OnClick="@(() => SetSortAsync(DogSortOption.NearestFirst))">Nearest first</MudMenuItem>
                        }
                    </MudMenu>
                    @if (_currentUserIsAdopter)
                    {
                        <MudButton Href="/adopter/copilot"
                                   Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Assistant">
                            Ask Copilot
                        </MudButton>
                    }
                    <MudSpacer />
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="result-count-text">@ResultCountText</MudText>
                    @if (HasActiveFilters)
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearFiltersAsync">Clear all</MudButton>
                    }
                </MudStack>

                @if (ActiveFilterChips.Count > 0)
                {
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="active-filter-chip-row">
                        @foreach (var chip in ActiveFilterChips)
                        {
                            <span class="active-filter-chip">
                                <span>@chip.Label</span>
                                <button type="button" @onclick="chip.ClearAsync" aria-label="@($"Remove {chip.Label}")">
                                    <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                                </button>
                            </span>
                        }
                    </MudStack>
                }
            </MudStack>
        </MudPaper>

        @if (_filtersOpen)
        {
            <MudPaper Elevation="0" Class="section-surface filter-panel pa-4">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6" md="4">
                        <MudTextField Label="Search by name" @bind-Value="_searchTerm" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudSelect T="int?" Label="Shelter" @bind-Value="_selectedShelterId" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem T="int?" Value="@((int?)null)">All shelters</MudSelectItem>
                            @foreach (var shelter in _shelters)
                            {
                                <MudSelectItem T="int?" Value="@((int?)shelter.Id)">@shelter.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudSelect T="string" Label="Breed" @bind-Value="_selectedBreed" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="@string.Empty">All breeds</MudSelectItem>
                            @foreach (var breed in _breeds)
                            {
                                <MudSelectItem Value="@breed">@breed</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="string" Label="Coat color" @bind-Value="_selectedCoatColor" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="@string.Empty">All coat colors</MudSelectItem>
                            @foreach (var coatColor in _coatColors)
                            {
                                <MudSelectItem Value="@coatColor">@coatColor</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudNumericField T="int?" Label="Max age" @bind-Value="_maxAge" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Max="30" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="string" Label="Size" @bind-Value="_selectedSize" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="@string.Empty">All sizes</MudSelectItem>
                            @foreach (var size in Enum.GetValues<DogSize>())
                            {
                                <MudSelectItem Value="@size.ToString()">@size</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="string" Label="Location" @bind-Value="_selectedLocation" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="@string.Empty">All locations</MudSelectItem>
                            @foreach (var location in _locations)
                            {
                                <MudSelectItem Value="@location">@location</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="string" Label="Neighborhood" @bind-Value="_selectedNeighborhood" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="@string.Empty">All neighborhoods</MudSelectItem>
                            @foreach (var neighborhood in _neighborhoods)
                            {
                                <MudSelectItem Value="@neighborhood">@neighborhood</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="string" Label="Status" @bind-Value="_selectedStatus" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="@string.Empty">Available or reserved</MudSelectItem>
                            <MudSelectItem Value="@DogStatus.Available.ToString()">Available</MudSelectItem>
                            <MudSelectItem Value="@DogStatus.Reserved.ToString()">Reserved</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="string" Label="Cats" @bind-Value="_selectedCatCompatibility" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="@string.Empty">Any cat fit</MudSelectItem>
                            @foreach (var value in Enum.GetValues<CatCompatibility>().Where(value => value != CatCompatibility.Unknown))
                            {
                                <MudSelectItem Value="@value.ToString()">@DogCompatibilityFormatter.FormatCat(value)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="string" Label="Children" @bind-Value="_selectedChildrenCompatibility" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="@string.Empty">Any child fit</MudSelectItem>
                            @foreach (var value in Enum.GetValues<ChildrenCompatibility>().Where(value => value != ChildrenCompatibility.Unknown))
                            {
                                <MudSelectItem Value="@value.ToString()">@DogCompatibilityFormatter.FormatChildren(value)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="string" Label="Activity" @bind-Value="_selectedActivityLevel" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="@string.Empty">Any activity</MudSelectItem>
                            @foreach (var value in Enum.GetValues<DogActivityLevel>().Where(value => value != DogActivityLevel.Unknown))
                            {
                                <MudSelectItem Value="@value.ToString()">@DogCompatibilityFormatter.FormatActivity(value)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="string" Label="Apartment fit" @bind-Value="_selectedApartmentSuitability" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="@string.Empty">Any apartment fit</MudSelectItem>
                            @foreach (var value in Enum.GetValues<ApartmentSuitability>().Where(value => value != ApartmentSuitability.Unknown))
                            {
                                <MudSelectItem Value="@value.ToString()">@DogCompatibilityFormatter.FormatApartment(value)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudPaper Elevation="0" Class="nearby-filter-panel pa-3">
                            <MudGrid Spacing="2">
                                <MudItem xs="12" md="6">
                                    <MudAutocomplete T="AddressSuggestion"
                                                     Label="Near"
                                                     Text="@_nearbySearchTerm"
                                                     TextChanged="OnNearbyTextChanged"
                                                     Value="@_selectedNearbySuggestion"
                                                     ValueChanged="OnNearbySuggestionSelected"
                                                     SearchFunc="SearchNearbySuggestionsAsync"
                                                     ToStringFunc="GetSuggestionDisplayText"
                                                     Variant="Variant.Outlined"
                                                     Margin="Margin.Dense"
                                                     Adornment="Adornment.Start"
                                                     AdornmentIcon="@Icons.Material.Filled.TravelExplore"
                                                     Placeholder="Search near city or address"
                                                     MinCharacters="3"
                                                     DebounceInterval="650"
                                                     MaxItems="5"
                                                     Clearable="true"
                                                     CoerceText="true"
                                                     ResetValueOnEmptyText="true"
                                                     ShowProgressIndicator="true"
                                                     Class="nearby-autocomplete">
                                        <ItemTemplate Context="suggestion">
                                            <div class="nearby-suggestion">
                                                <MudText Typo="Typo.body2" Class="nearby-suggestion-primary">@GetSuggestionDisplayText(suggestion)</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="nearby-suggestion-secondary">@suggestion.DisplayName</MudText>
                                            </div>
                                        </ItemTemplate>
                                        <NoItemsTemplate>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">No suggestions found. You can still use the search icon.</MudText>
                                        </NoItemsTemplate>
                                    </MudAutocomplete>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="2">
                                    <MudSelect T="int" Label="Radius" Value="_selectedRadiusKm" ValueChanged="OnRadiusChangedAsync" Variant="Variant.Outlined" Margin="Margin.Dense">
                                        @foreach (var radius in RadiusOptions)
                                        {
                                            <MudSelectItem Value="@radius">@($"{radius} km")</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" sm="6" md="4" Class="nearby-action-cell">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="nearby-actions">
                                        @if (HasManualNearbyText)
                                        {
                                            <MudTooltip Text="Search typed address">
                                                <MudIconButton Icon="@Icons.Material.Filled.NearMe"
                                                               Color="Color.Primary"
                                                               Size="Size.Medium"
                                                               Disabled="@(_isFindingNearby || _isUsingBrowserLocation)"
                                                               OnClick="FindNearbyAsync"
                                                               aria-label="Search typed address" />
                                            </MudTooltip>
                                        }
                                        <MudTooltip Text="Your location is used only to filter nearby results.">
                                            <MudButton Variant="Variant.Outlined"
                                                       Color="Color.Secondary"
                                                       StartIcon="@Icons.Material.Filled.MyLocation"
                                                       Disabled="@(_isFindingNearby || _isUsingBrowserLocation)"
                                                       OnClick="UseMyLocationAsync">
                                                @(_isUsingBrowserLocation ? "Locating..." : "Use my location")
                                            </MudButton>
                                        </MudTooltip>
                                        @if (_nearbyOrigin is not null)
                                        {
                                            <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.LocationOff" OnClick="ClearNearbyAsync">Clear address</MudButton>
                                        }
                                    </MudStack>
                                </MudItem>
                            </MudGrid>

                            @if (!string.IsNullOrWhiteSpace(_nearbyError))
                            {
                                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mt-2">@_nearbyError</MudAlert>
                            }
                            else if (HasManualNearbyText)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="nearby-inline-hint">
                                    Choose a suggestion to apply nearby filtering, or use the search icon for this typed address.
                                </MudText>
                            }
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="filter-panel-actions">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.FilterAlt" OnClick="ApplyFiltersAndCloseAsync">Apply Filters</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="@Icons.Material.Filled.Clear" OnClick="ClearFiltersAsync">Reset Filters</MudButton>
                            <MudSpacer />
                            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="ToggleFilters">Done</MudButton>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        }

        @if (_isLoading)
        {
            <AppLoadingState Message="Loading dogs..." />
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <AppErrorState Title="Dogs could not be loaded" Message="@_error" OnRetry="ApplyFiltersAsync" />
        }
        else if (_dogs.Count == 0)
        {
            <AppEmptyState Title="@EmptyStateTitle"
                           Message="@EmptyStateSubtitle"
                           Icon="@Icons.Material.Filled.SearchOff"
                           Tips="@EmptyStateTips"
                           PrimaryActionText="@EmptyStatePrimaryActionText"
                           PrimaryActionIcon="@EmptyStatePrimaryActionIcon"
                           OnPrimaryAction="EmptyStatePrimaryActionAsync"
                           SecondaryActionText="@EmptyStateSecondaryActionText"
                           SecondaryActionIcon="@EmptyStateSecondaryActionIcon"
                           OnSecondaryAction="EmptyStateSecondaryActionAsync" />
        }
        else
        {
            <MudGrid Spacing="3">
                @foreach (var dog in _dogs)
                {
                    var imageUrl = GetMainImageUrl(dog);
                    var shelterLine = GetShelterLine(dog);
                    var distanceText = GetDistanceText(dog);

                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Class="dog-card">
                            <a class="dog-image-link" href="@($"/dogs/{dog.Id}")" aria-label="@($"View details for {dog.Name}")">
                                @if (imageUrl is null || _unavailableImageUrls.Contains(imageUrl))
                                {
                                    <div class="dog-image dog-image-placeholder">
                                        <MudIcon Icon="@Icons.Material.Filled.Pets" Color="Color.Primary" />
                                        <MudText Typo="Typo.caption">No image available</MudText>
                                    </div>
                                }
                                else
                                {
                                    <img src="@imageUrl"
                                         alt="@GetDogImageAlt(dog)"
                                         class="dog-image dog-card-image"
                                         loading="lazy"
                                         @onerror="@(() => MarkImageUnavailable(imageUrl))" />
                                }
                            </a>
                            <MudCardContent>
                                <MudStack Spacing="1">
                                    <MudStack Row="true" AlignItems="AlignItems.Start">
                                        <MudText Typo="Typo.h6">@dog.Name</MudText>
                                        <MudSpacer />
                                        @if (_currentUserIsAdopter || !_currentUserIsAuthenticated)
                                        {
                                            <MudIconButton Icon="@GetFavoriteIcon(dog.Id)" Color="@GetFavoriteColor(dog.Id)" Size="Size.Small" OnClick="@(() => ToggleFavoriteAsync(dog))" aria-label="@GetFavoriteTitle(dog.Id)" />
                                        }
                                        <MudChip T="string" Color="@GetStatusColor(dog.Status)" Size="Size.Small">@dog.Status</MudChip>
                                    </MudStack>
                                    <MudText Typo="Typo.body2">@DogBreedFormatter.Format(dog), @DogAgeFormatter.Format(dog)</MudText>
                                    @if (!string.IsNullOrWhiteSpace(shelterLine))
                                    {
                                        <MudText Typo="Typo.body2" Class="dog-shelter-line">@shelterLine</MudText>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(distanceText))
                                    {
                                        <MudText Typo="Typo.body2" Class="dog-distance-line">@distanceText</MudText>
                                    }
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@dog.Size dog in @dog.Location</MudText>
                                    @if (!string.IsNullOrWhiteSpace(dog.Description))
                                    {
                                        <MudText Typo="Typo.body2" Class="dog-card-description">@GetShortDescription(dog.Description)</MudText>
                                    }
                                </MudStack>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Href="@($"/dogs/{dog.Id}")" Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward">View Details</MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudStack>
</MudContainer>
</div>



