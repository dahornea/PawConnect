@page "/not-found"
@layout MainLayout

<PageTitle>Page not found</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="px-0">
    <MudPaper Elevation="0" Class="not-found-card pa-6">
        <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="text-center">
            <span class="not-found-icon"><MudIcon Icon="@Icons.Material.Filled.SearchOff" /></span>
            <div>
                <MudText Typo="Typo.h4">Page not found</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary">
                    The page you are looking for does not exist or may have moved.
                </MudText>
            </div>
            <MudStack Row="true" Spacing="2">
                <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Home">Go Home</MudButton>
                <MudButton Href="/dogs" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Pets">Browse Dogs</MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
</MudContainer>
