@page "/dogs/{Id:int}"
@using Microsoft.AspNetCore.Identity
@using PawConnect.Data

<PageTitle>Dog Details</PageTitle>

@if (_isLoading)
{
    <MudStack AlignItems="AlignItems.Center" Class="py-8">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.body2" Color="Color.Secondary">Loading dog details...</MudText>
    </MudStack>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else if (_dog is null)
{
    <MudAlert Severity="Severity.Warning">The selected dog was not found.</MudAlert>
}
else
{
    <div class="dog-details-page">
    <MudContainer MaxWidth="MaxWidth.False" Class="px-0">
        <MudStack Spacing="3">
            <div class="dog-details-nav">
                <MudButton Href="@BackHref"
                           Variant="Variant.Text"
                           Color="Color.Default"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           Class="back-to-dogs-button">
                    @BackButtonText
                </MudButton>
            </div>

            @{
                var validImages = GetValidImages(_dog);
                var selectedImageIndex = GetSafeSelectedImageIndex(validImages.Count);
                var selectedImage = validImages.Count == 0 ? null : validImages[selectedImageIndex];
            }

            <MudGrid Spacing="3" Class="details-hero-grid">
                <MudItem xs="12" md="5">
                    <MudPaper Elevation="0" Class="section-surface dog-gallery">
                        <div class="dog-gallery-main">
                        @if (selectedImage is null)
                        {
                            <div class="dog-gallery-placeholder">
                                <MudIcon Icon="@Icons.Material.Filled.Pets" Color="Color.Primary" />
                                <MudText Typo="Typo.subtitle2">No photo available</MudText>
                            </div>
                        }
                        else
                        {
                            <button type="button"
                                    class="dog-gallery-main-button"
                                    aria-label="@($"Open photo preview for {_dog.Name}")"
                                    @onclick="() => OpenImagePreviewAsync(validImages, selectedImageIndex)">
                                <img src="@selectedImage.ImageUrl"
                                     @key="selectedImage.ImageUrl"
                                     alt="@GetDogImageAlt(_dog)"
                                     class="dog-gallery-image"
                                     decoding="async"
                                     @onerror="@(() => MarkImageUnavailable(selectedImage.ImageUrl))" />
                                <span class="dog-gallery-zoom-overlay" aria-hidden="true">
                                    <MudIcon Icon="@Icons.Material.Filled.ZoomIn" />
                                    <span>View photo</span>
                                </span>

                                @if (validImages.Count > 1)
                                {
                                    <span class="dog-gallery-count">@($"{selectedImageIndex + 1} / {validImages.Count}")</span>
                                }
                            </button>
                        }
                        </div>

                        @if (validImages.Count > 1)
                        {
                            <div class="dog-gallery-thumbnails" role="list" aria-label="@($"{_dog.Name} photos")">
                            @for (var index = 0; index < validImages.Count; index++)
                            {
                                var thumbnailIndex = index;
                                var image = validImages[thumbnailIndex];
                                var isSelected = thumbnailIndex == selectedImageIndex;

                                <button type="button"
                                        class="dog-gallery-thumbnail @(isSelected ? "selected" : null)"
                                        role="listitem"
                                        aria-label="@($"Show photo {thumbnailIndex + 1} of {_dog.Name}")"
                                        aria-current="@(isSelected ? "true" : "false")"
                                        @onclick="() => SelectGalleryImage(thumbnailIndex)">
                                    <img src="@image.ImageUrl"
                                         alt=""
                                         loading="lazy"
                                         @onerror="@(() => MarkImageUnavailable(image.ImageUrl))" />
                                </button>
                            }
                            </div>
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="7">
                    <MudPaper Elevation="0" Class="section-surface dog-summary pa-4">
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Start" Class="summary-heading">
                                <div>
                                    <MudText Typo="Typo.h3" Class="dog-title">@_dog.Name</MudText>
                                    <MudText Typo="Typo.subtitle1" Class="dog-subtitle">@DogBreedFormatter.Format(_dog), @DogAgeFormatter.Format(_dog)</MudText>
                                </div>
                                <MudSpacer />
                                <MudChip T="string" Color="@GetStatusColor(_dog.Status)" Class="status-chip">@_dog.Status</MudChip>
                            </MudStack>

                            <MudDivider />

                            <MudGrid Class="fact-grid">
                                <MudItem xs="12" sm="6">
                                    <div class="fact-tile">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Size</MudText>
                                        <MudText Typo="Typo.body1">@_dog.Size</MudText>
                                    </div>
                                </MudItem>
                                <MudItem xs="12" sm="6">
                                    <div class="fact-tile">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Location</MudText>
                                        <MudText Typo="Typo.body1">@_dog.Location</MudText>
                                    </div>
                                </MudItem>
                                @if (!string.IsNullOrWhiteSpace(_dog.CoatColor))
                                {
                                    <MudItem xs="12" sm="6">
                                        <div class="fact-tile">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Coat color</MudText>
                                            <MudText Typo="Typo.body1">@_dog.CoatColor</MudText>
                                        </div>
                                    </MudItem>
                                }
                            </MudGrid>

                            @if (!string.IsNullOrWhiteSpace(_dog.Description))
                            {
                                <MudText Typo="Typo.body1" Class="dog-description">@_dog.Description</MudText>
                            }

                            @if (!string.IsNullOrWhiteSpace(_dog.BehaviorDescription))
                            {
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="detail-note">
                                    <MudText Typo="Typo.subtitle2">Behavior</MudText>
                                    <MudText Typo="Typo.body2">@_dog.BehaviorDescription</MudText>
                                </MudAlert>
                            }

                            @if (!string.IsNullOrWhiteSpace(_dog.MedicalStatus))
                            {
                                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="detail-note">
                                    <MudText Typo="Typo.subtitle2">Medical Status</MudText>
                                    <MudText Typo="Typo.body2">@_dog.MedicalStatus</MudText>
                                </MudAlert>
                            }

                            @if (IsAdopted)
                            {
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                                    This dog has already been adopted, so this profile is read-only.
                                </MudAlert>
                            }
                            else if (_currentUserIsAdopter)
                            {
                                <MudStack Row="true" Spacing="2" Class="mt-2">
                                    <MudButton Variant="@GetFavoriteVariant()" Color="@GetFavoriteColor()" StartIcon="@GetFavoriteIcon()" OnClick="ToggleFavoriteAsync">@GetFavoriteButtonText()</MudButton>
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Send" Disabled="@_hasPendingRequest" OnClick="StartAdoptionRequestAsync">@GetAdoptionButtonText()</MudButton>
                                </MudStack>
                            }
                            else if (!_currentUserIsAuthenticated)
                            {
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                                    Log in or register as an adopter to save this dog or submit an adoption request.
                                    <MudButton Href="@LoginUrl" Variant="Variant.Text" Color="Color.Primary" Class="ml-2">Log in</MudButton>
                                    <MudButton Href="/Account/Register" Variant="Variant.Text" Color="Color.Secondary">Register</MudButton>
                                </MudAlert>
                            }
                            else if (_currentUserIsShelter)
                            {
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="role-note">
                                    You are viewing this as a shelter account. Use your shelter workspace when you need to manage your own dog profiles.
                                    <MudButton Href="/shelter/dogs" Variant="Variant.Text" Color="Color.Primary" Class="ml-2">Manage Dogs</MudButton>
                                </MudAlert>
                            }
                            else if (_currentUserIsAdmin)
                            {
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="role-note">
                                    Admin accounts can review this dog from the public details view. Status changes remain in the shelter workflow, but status history is available here.
                                    <MudStack Row="true" Spacing="1" Class="mt-2 flex-wrap">
                                        <MudButton Href="/admin/dogs" Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AdminPanelSettings">Admin Dogs</MudButton>
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Info"
                                                   StartIcon="@Icons.Material.Filled.History"
                                                   Disabled="_isHistoryLoading"
                                                   OnClick="OpenStatusHistoryDialogAsync">
                                            View Status History
                                        </MudButton>
                                    </MudStack>
                                </MudAlert>
                            }

                            @if (_showAdoptionForm && !IsAdopted && _currentUserIsAdopter)
                            {
                                <MudPaper Elevation="0" Class="request-panel pa-3 mt-2">
                                    <MudStack Spacing="2">
                                        <MudText Typo="Typo.h6">Adoption Request</MudText>

                                        @if (_adopterProfile is null)
                                        {
                                            <MudAlert Severity="Severity.Info">
                                                You can complete your adopter profile to help shelters evaluate your request.
                                                <MudButton Href="/adopter/profile" Variant="Variant.Text" Color="Color.Primary" Class="ml-2">Edit Profile</MudButton>
                                            </MudAlert>
                                        }
                                        else
                                        {
                                            <MudCard Class="section-surface">
                                                <MudCardContent>
                                                    <MudText Typo="Typo.subtitle1">Your Profile Summary</MudText>
                                                    <MudDivider Class="my-2" />
                                                    <MudGrid>
                                                        <MudItem xs="12" sm="6"><MudText Typo="Typo.body2">Name: @_adopterProfile.FullName</MudText></MudItem>
                                                        <MudItem xs="12" sm="6"><MudText Typo="Typo.body2">City: @_adopterProfile.City</MudText></MudItem>
                                                        <MudItem xs="12" sm="6"><MudText Typo="Typo.body2">Phone: @(string.IsNullOrWhiteSpace(_adopterProfile.PhoneNumber) ? "-" : _adopterProfile.PhoneNumber)</MudText></MudItem>
                                                        <MudItem xs="12" sm="6"><MudText Typo="Typo.body2">Housing: @_adopterProfile.HousingType</MudText></MudItem>
                                                        <MudItem xs="12" sm="6"><MudText Typo="Typo.body2">Has yard: @FormatYesNo(_adopterProfile.HasYard)</MudText></MudItem>
                                                        <MudItem xs="12" sm="6"><MudText Typo="Typo.body2">Other pets: @FormatYesNo(_adopterProfile.HasOtherPets)</MudText></MudItem>
                                                        <MudItem xs="12" sm="6"><MudText Typo="Typo.body2">Children: @FormatYesNo(_adopterProfile.HasChildren)</MudText></MudItem>
                                                        @if (!string.IsNullOrWhiteSpace(_adopterProfile.ExperienceWithDogs))
                                                        {
                                                            <MudItem xs="12"><MudText Typo="Typo.body2">Experience: @_adopterProfile.ExperienceWithDogs</MudText></MudItem>
                                                        }
                                                    </MudGrid>
                                                </MudCardContent>
                                            </MudCard>
                                        }

                                        <MudForm @ref="_adoptionForm">
                                            <MudStack Spacing="2">
                                                <MudPaper Elevation="0" Class="section-surface pa-3">
                                                    <MudStack Spacing="2">
                                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                            <MudIcon Icon="@Icons.Material.Filled.EventAvailable" Color="Color.Primary" />
                                                            <MudText Typo="Typo.subtitle1">Preferred Visit Time</MudText>
                                                        </MudStack>
                                                        @if (!string.IsNullOrWhiteSpace(_visitSectionValidationError))
                                                        {
                                                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="visit-validation-alert">
                                                                @_visitSectionValidationError
                                                            </MudAlert>
                                                        }
                                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                            Shelter visiting hours: @GetShelterVisitingHours()
                                                        </MudText>
                                                        <MudGrid Spacing="2">
                                                            <MudItem xs="12" sm="6">
                                                                <MudDatePicker Label="Preferred visit date"
                                                                               @bind-Date="_preferredVisitDate"
                                                                               @bind-Date:after="ClearVisitValidationErrors"
                                                                               Required="true"
                                                                               RequiredError="Preferred visit date is required."
                                                                               Error="@HasPreferredVisitDateError"
                                                                               ErrorText="@_preferredVisitDateError"
                                                                               MinDate="DateTime.Today"
                                                                               Variant="Variant.Outlined" />
                                                            </MudItem>
                                                            <MudItem xs="12" sm="6">
                                                                <MudTimePicker Label="Preferred visit time"
                                                                               @bind-Time="_preferredVisitTime"
                                                                               @bind-Time:after="ClearVisitValidationErrors"
                                                                               Required="true"
                                                                               RequiredError="Preferred visit time is required."
                                                                               Error="@HasPreferredVisitTimeError"
                                                                               ErrorText="@_preferredVisitTimeError"
                                                                               Variant="Variant.Outlined" />
                                                            </MudItem>
                                                        </MudGrid>
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                            The shelter will review your request and confirm the visit before any final adoption decision.
                                                        </MudText>
                                                    </MudStack>
                                                </MudPaper>
                                                <MudTextField Label="Reason for adoption"
                                                              @bind-Value="_reasonForAdoption"
                                                              @bind-Value:after="ClearQuestionnaireValidationErrors"
                                                              Required="true"
                                                              RequiredError="Reason for adoption is required."
                                                              Error="@HasReasonForAdoptionError"
                                                              ErrorText="@_reasonForAdoptionError"
                                                              Lines="4"
                                                              Variant="Variant.Outlined" />
                                                <MudNumericField T="int?" Label="Hours per day the dog would be alone"
                                                                 @bind-Value="_hoursAlonePerDay"
                                                                 @bind-Value:after="ClearHoursAloneValidationError"
                                                                 Min="0"
                                                                 Max="24"
                                                                 Error="@HasHoursAloneError"
                                                                 ErrorText="@_hoursAloneError"
                                                                 Variant="Variant.Outlined" />
                                                <MudTextField Label="Additional information" @bind-Value="_additionalInformation" Lines="3" Variant="Variant.Outlined" />
                                            </MudStack>
                                        </MudForm>

                                        <MudStack Row="true" Spacing="2">
                                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Send" Disabled="@_isSubmittingRequest" OnClick="SubmitAdoptionRequestAsync">Submit</MudButton>
                                            <MudButton Variant="Variant.Text" Color="Color.Default" Disabled="@_isSubmittingRequest" OnClick="CancelAdoptionForm">Cancel</MudButton>
                                        </MudStack>
                                    </MudStack>
                                </MudPaper>
                            }
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudGrid Spacing="3">
                <MudItem xs="12">
                    <MudPaper Elevation="0" Class="section-surface breed-info-panel pa-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Pets" Color="Color.Primary" />
                            <MudText Typo="Typo.h6" Class="content-title">Breed Information</MudText>
                        </MudStack>
                        <MudDivider Class="my-2" />
                        <MudGrid Spacing="3" Class="breed-info-grid">
                            <MudItem xs="12" md="4">
                                <MudStack Spacing="1">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="flex-wrap">
                                        <MudText Typo="Typo.subtitle1" Class="breed-info-name">@DogBreedFormatter.Format(_dog)</MudText>
                                        @if (DogBreedInformationFormatter.IsMixedBreed(_dog))
                                        {
                                            <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Small">Mixed breed</MudChip>
                                        }
                                    </MudStack>
                                    <MudText Typo="Typo.body2" Class="breed-info-muted">
                                        @DogBreedInformationFormatter.GetDisclaimer(_dog)
                                    </MudText>
                                </MudStack>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudStack Spacing="2">
                                    <div class="breed-info-block">
                                        <MudText Typo="Typo.caption" Class="breed-info-label">Overview</MudText>
                                        @foreach (var overviewNote in DogBreedInformationFormatter.GetGeneralNotes(_dog))
                                        {
                                            <MudText Typo="Typo.body2">@overviewNote</MudText>
                                        }
                                    </div>
                                    @{
                                        var typicalTraitNotes = DogBreedInformationFormatter.GetTypicalTraitNotes(_dog);
                                    }
                                    @if (typicalTraitNotes.Count > 0)
                                    {
                                        <div class="breed-info-block">
                                            <MudText Typo="Typo.caption" Class="breed-info-label">Typical traits</MudText>
                                            @foreach (var traitNote in typicalTraitNotes)
                                            {
                                                <MudText Typo="Typo.body2">@traitNote</MudText>
                                            }
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(DogBreedInformationFormatter.GetCareContext(_dog)))
                                    {
                                        <div class="breed-info-block">
                                            <MudText Typo="Typo.caption" Class="breed-info-label">Care context</MudText>
                                            <MudText Typo="Typo.body2">@DogBreedInformationFormatter.GetCareContext(_dog)</MudText>
                                        </div>
                                    }
                                </MudStack>
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudStack Spacing="2">
                                    <div class="breed-info-health">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Color="Color.Info" Size="Size.Small" />
                                            <MudText Typo="Typo.caption" Class="breed-info-label">Common health considerations</MudText>
                                        </MudStack>
                                        @{
                                            var healthItems = DogBreedInformationFormatter.GetHealthConsiderationItems(_dog);
                                        }
                                        @if (healthItems.Count > 0)
                                        {
                                            <MudText Typo="Typo.body2" Class="breed-health-intro">@DogBreedInformationFormatter.GetHealthConsiderationsIntro(_dog)</MudText>
                                            <ul class="breed-health-list">
                                                @foreach (var healthItem in healthItems)
                                                {
                                                    <li>@healthItem</li>
                                                }
                                            </ul>
                                            <MudText Typo="Typo.body2" Class="breed-info-muted">@DogBreedInformationFormatter.GetHealthFollowUp(_dog)</MudText>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.body2" Class="breed-health-paragraph">@DogBreedInformationFormatter.GetHealthNote(_dog)</MudText>
                                        }
                                    </div>
                                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="breed-info-note">
                                        <MudText Typo="Typo.caption" Class="breed-info-label">Important note</MudText>
                                        <MudText Typo="Typo.body2">@DogBreedInformationFormatter.GetImportantNote(_dog)</MudText>
                                    </MudAlert>
                                </MudStack>
                            </MudItem>
                        </MudGrid>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Elevation="0" Class="section-surface info-panel pa-4 h-100">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Primary" />
                                    <MudText Typo="Typo.h6" Class="content-title">Shelter</MudText>
                        </MudStack>
                        <MudDivider Class="my-2" />
                        @if (_dog.Shelter is null)
                        {
                            <MudText Typo="Typo.body2">No shelter information is available.</MudText>
                        }
                        else
                        {
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.subtitle1">@_dog.Shelter.Name</MudText>
                                <MudText Typo="Typo.body2">@_dog.Shelter.Address, @_dog.Shelter.City</MudText>
                                @if (!string.IsNullOrWhiteSpace(_dog.Shelter.PhoneNumber))
                                {
                                    <MudText Typo="Typo.body2">Phone: @_dog.Shelter.PhoneNumber</MudText>
                                }
                                @if (!string.IsNullOrWhiteSpace(_dog.Shelter.Email))
                                {
                                    <MudText Typo="Typo.body2">Email: @_dog.Shelter.Email</MudText>
                                }
                                <MudButton Href="@($"/shelters/{_dog.Shelter.Id}")" Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.LocationOn" Class="mt-1">
                                    View shelter location
                                </MudButton>
                            </MudStack>
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Elevation="0" Class="section-surface info-panel pa-4 h-100">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Restaurant" Color="Color.Secondary" />
                            <MudText Typo="Typo.h6" Class="content-title">Food</MudText>
                        </MudStack>
                        <MudDivider Class="my-2" />
                        @if (_dog.PreferredFoodType is null && _dog.DailyFoodAmountGrams is null)
                        {
                            <MudText Typo="Typo.body2">No food preference has been recorded.</MudText>
                        }
                        else
                        {
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2">Preferred food: @_dog.PreferredFoodType?.Name</MudText>
                                @if (_dog.DailyFoodAmountGrams.HasValue)
                                {
                                    <MudText Typo="Typo.body2">Daily amount: @_dog.DailyFoodAmountGrams.Value grams</MudText>
                                }
                            </MudStack>
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Elevation="0" Class="section-surface info-panel pa-4 h-100">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.MedicalServices" Color="Color.Info" />
                            <MudText Typo="Typo.h6" Class="content-title">Medical Records</MudText>
                        </MudStack>
                        <MudDivider Class="my-2" />
                        @if (_dog.MedicalRecords.Count == 0)
                        {
                            <MudText Typo="Typo.body2">No medical records are available.</MudText>
                        }
                        else
                        {
                            <MudStack Spacing="2">
                                @foreach (var record in _dog.MedicalRecords.OrderByDescending(r => r.RecordDate))
                                {
                                    <MudPaper Elevation="0" Class="medical-record pa-2">
                                        <MudText Typo="Typo.subtitle2">@record.RecordDate.ToString("dd MMM yyyy")</MudText>
                                        @if (!string.IsNullOrWhiteSpace(record.VaccineName))
                                        {
                                            <MudText Typo="Typo.body2">Vaccine: @record.VaccineName</MudText>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(record.TreatmentDescription))
                                        {
                                            <MudText Typo="Typo.body2">Treatment: @record.TreatmentDescription</MudText>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(record.Notes))
                                        {
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">@record.Notes</MudText>
                                        }
                                    </MudPaper>
                                }
                            </MudStack>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudStack>
    </MudContainer>
    </div>
}

