@page "/admin/users"
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using PawConnect.Data
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Users</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Users</MudText>
            <MudText Typo="Typo.body2">View registered users and their assigned roles.</MudText>
        </div>

        <MudPaper Elevation="0" Class="section-surface pa-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2" Class="flex-wrap">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Export all admin user rows without Identity security fields.</MudText>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.FileDownload"
                           Disabled="_isLoading || _isExporting"
                           OnClick="ExportUsersCsvAsync">
                    Export CSV
                </MudButton>
            </MudStack>
        </MudPaper>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading users...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_users.Count == 0)
        {
            <MudPaper Elevation="0" Class="empty-state pa-5">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h6">No users found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Registered users will appear here.</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudTable Items="_users" Dense="true" Hover="true" Class="table-shell">
                <HeaderContent>
                    <MudTh>Email</MudTh>
                    <MudTh>Full Name</MudTh>
                    <MudTh>User Name</MudTh>
                    <MudTh>Phone</MudTh>
                    <MudTh>Roles</MudTh>
                    <MudTh>Adopter Profile</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Email">@context.Email</MudTd>
                    <MudTd DataLabel="Full Name">@(string.IsNullOrWhiteSpace(context.FullName) ? "-" : context.FullName)</MudTd>
                    <MudTd DataLabel="User Name">@(string.IsNullOrWhiteSpace(context.UserName) ? "-" : context.UserName)</MudTd>
                    <MudTd DataLabel="Phone">@(string.IsNullOrWhiteSpace(context.PhoneNumber) ? "-" : context.PhoneNumber)</MudTd>
                    <MudTd DataLabel="Roles">
                        <MudStack Row="true" Spacing="1">
                            @foreach (var role in context.Roles)
                            {
                                <MudChip T="string" Color="Color.Primary" Size="Size.Small">@role</MudChip>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Adopter Profile">
                        @if (context.HasAdopterProfile)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudAvatar Size="Size.Medium">
                                    @if (string.IsNullOrWhiteSpace(context.ProfileImageUrl))
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Person" />
                                    }
                                    else
                                    {
                                        <MudImage Src="@context.ProfileImageUrl" Alt="@context.ProfileFullName" />
                                    }
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.body2">@context.ProfileFullName</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.ProfileCity | @(string.IsNullOrWhiteSpace(context.ProfilePhoneNumber) ? "-" : context.ProfilePhoneNumber)</MudText>
                                </div>
                            </MudStack>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Default" Size="Size.Small">No profile</MudChip>
                        }
                    </MudTd>
                    <MudTd>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" OnClick="@(() => EditUser(context))">Edit</MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            @if (_editUser is not null)
            {
                <MudPaper Elevation="0" Class="section-surface edit-panel pa-4 mt-3">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.h6">Edit User</MudText>
                        <MudForm @ref="_userForm">
                            <MudGrid Spacing="2">
                                <MudItem xs="12" md="4">
                                    <MudTextField Label="Full Name" @bind-Value="_editUser.FullName" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField Label="Email" @bind-Value="_editUser.Email" Required="true" RequiredError="Email is required." Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudTextField Label="Phone Number" @bind-Value="_editUser.PhoneNumber" Variant="Variant.Outlined" />
                                </MudItem>
                            </MudGrid>
                        </MudForm>
                        <MudStack Row="true" Spacing="2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" Disabled="_isSaving" OnClick="SaveUserAsync">Save</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Default" Disabled="_isSaving" OnClick="CancelEdit">Cancel</MudButton>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            }
        }
    </MudStack>
</MudContainer>

