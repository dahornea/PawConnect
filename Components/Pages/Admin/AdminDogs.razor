@page "/admin/dogs"
@attribute [Authorize(Roles = "Admin")]
@inject IDogService DogService
@inject ISnackbar Snackbar

<PageTitle>Admin Dogs</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div>
            <MudText Typo="Typo.h4">Dogs</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">View dogs from all shelters and safely remove unused records.</MudText>
        </div>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading dogs...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_dogs.Count == 0)
        {
            <MudPaper Elevation="0" Class="empty-state pa-5">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Pets" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h6">No dogs found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Dog profiles from all shelters will appear here.</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudTable Items="_dogs" Dense="true" Hover="true" Class="table-shell">
                <HeaderContent>
                    <MudTh>Dog</MudTh>
                    <MudTh>Breed</MudTh>
                    <MudTh>Age</MudTh>
                    <MudTh>Size</MudTh>
                    <MudTh>Location</MudTh>
                    <MudTh>Shelter</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Success Story</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Dog">
                        @{
                            var imageUrl = GetImageUrl(context);
                        }
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Size="Size.Large">
                                @if (imageUrl is null)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Pets" />
                                }
                                else
                                {
                                    <MudImage Src="@imageUrl" Alt="@context.Name" />
                                }
                            </MudAvatar>
                            <MudText Typo="Typo.body2">@context.Name</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Breed">@context.Breed</MudTd>
                    <MudTd DataLabel="Age">@context.Age</MudTd>
                    <MudTd DataLabel="Size">@context.Size</MudTd>
                    <MudTd DataLabel="Location">@context.Location</MudTd>
                    <MudTd DataLabel="Shelter">@(context.Shelter?.Name ?? "-")</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Success Story">
                        @if (context.Status == DogStatus.Adopted)
                        {
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Adopted: @(context.AdoptedAt.HasValue ? context.AdoptedAt.Value.ToLocalTime().ToString("dd MMM yyyy") : "-")</MudText>
                                <MudText Typo="Typo.caption">@(string.IsNullOrWhiteSpace(context.SuccessStoryText) ? "No story text yet." : context.SuccessStoryText)</MudText>
                            </MudStack>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">-</MudText>
                        }
                    </MudTd>
                    <MudTd>
                        <MudStack Row="true" Spacing="1">
                            <MudButton Href="@($"/dogs/{context.Id}")" Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Visibility">View</MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Info" StartIcon="@Icons.Material.Filled.History" Disabled="_isHistoryLoading" OnClick="@(() => LoadStatusHistoryAsync(context))">History</MudButton>
                            @if (_deleteConfirmDogId == context.Id)
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever" Disabled="_isDeleting" OnClick="@(() => DeleteDogAsync(context))">Confirm</MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Default" Disabled="_isDeleting" OnClick="CancelDelete">Cancel</MudButton>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" Disabled="_isDeleting" OnClick="@(() => AskDeleteConfirmation(context))">Delete</MudButton>
                            }
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            @if (_selectedHistoryDog is not null)
            {
                <MudPaper Elevation="0" Class="section-surface history-panel pa-4">
                    <MudStack Spacing="3">
                        <div>
                            <MudText Typo="Typo.h5">Status History: @_selectedHistoryDog.Name</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Internal status changes recorded for this dog.</MudText>
                        </div>

                        @if (_isHistoryLoading)
                        {
                            <MudStack AlignItems="AlignItems.Center" Class="py-4">
                                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading status history...</MudText>
                            </MudStack>
                        }
                        else if (!string.IsNullOrWhiteSpace(_historyError))
                        {
                            <MudAlert Severity="Severity.Error">@_historyError</MudAlert>
                        }
                        else if (_statusHistory.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info">No status changes have been recorded for this dog yet.</MudAlert>
                        }
                        else
                        {
                            <MudTable Items="_statusHistory" Dense="true" Hover="true" Class="table-shell">
                                <HeaderContent>
                                    <MudTh>From</MudTh>
                                    <MudTh>To</MudTh>
                                    <MudTh>Changed</MudTh>
                                    <MudTh>Changed By</MudTh>
                                    <MudTh>Notes</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="From">
                                        <MudChip T="string" Color="@GetStatusColor(context.OldStatus)" Size="Size.Small">@context.OldStatus</MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="To">
                                        <MudChip T="string" Color="@GetStatusColor(context.NewStatus)" Size="Size.Small">@context.NewStatus</MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Changed">@context.ChangedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</MudTd>
                                    <MudTd DataLabel="Changed By">@(context.ChangedByUser?.Email ?? "-")</MudTd>
                                    <MudTd DataLabel="Notes">@(string.IsNullOrWhiteSpace(context.Notes) ? "-" : context.Notes)</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudStack>
                </MudPaper>
            }
        }
    </MudStack>
</MudContainer>

@code {
    private List<Dog> _dogs = [];
    private bool _isLoading = true;
    private bool _isDeleting;
    private bool _isHistoryLoading;
    private string? _error;
    private string? _historyError;
    private int? _deleteConfirmDogId;
    private Dog? _selectedHistoryDog;
    private List<DogStatusHistory> _statusHistory = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _dogs = await DogService.GetAllDogsForAdminAsync();
        }
        catch
        {
            _error = "Dog data could not be loaded. Check migrations and database connection.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void AskDeleteConfirmation(Dog dog)
    {
        _deleteConfirmDogId = dog.Id;
        Snackbar.Add($"Click Confirm to delete {dog.Name}. Dogs with favorites or adoption requests cannot be deleted.", Severity.Info);
    }

    private void CancelDelete()
    {
        _deleteConfirmDogId = null;
    }

    private async Task DeleteDogAsync(Dog dog)
    {
        _isDeleting = true;

        try
        {
            await DogService.DeleteDogForAdminAsync(dog.Id);
            _dogs.Remove(dog);
            _deleteConfirmDogId = null;
            Snackbar.Add($"{dog.Name} was deleted.", Severity.Success);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
        catch
        {
            Snackbar.Add("Dog could not be deleted right now.", Severity.Error);
        }
        finally
        {
            _isDeleting = false;
        }
    }

    private async Task LoadStatusHistoryAsync(Dog dog)
    {
        _selectedHistoryDog = dog;
        _statusHistory = [];
        _historyError = null;
        _isHistoryLoading = true;

        try
        {
            _statusHistory = await DogService.GetStatusHistoryForDogAsync(dog.Id);
        }
        catch
        {
            _historyError = "Status history could not be loaded right now.";
        }
        finally
        {
            _isHistoryLoading = false;
        }
    }

    private static string? GetImageUrl(Dog dog)
    {
        return dog.Images
            .Where(i => IsValidImageUrl(i.ImageUrl))
            .OrderByDescending(i => i.IsMainImage)
            .ThenBy(i => i.Id)
            .Select(i => i.ImageUrl)
            .FirstOrDefault();
    }

    private static bool IsValidImageUrl(string? imageUrl)
    {
        if (string.IsNullOrWhiteSpace(imageUrl) ||
            imageUrl.Contains("placehold.co", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        return Uri.TryCreate(imageUrl, UriKind.Absolute, out var uri) &&
            (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);
    }

    private static Color GetStatusColor(DogStatus status)
    {
        return status switch
        {
            DogStatus.Available => Color.Success,
            DogStatus.Reserved => Color.Warning,
            DogStatus.Adopted => Color.Default,
            DogStatus.InTreatment => Color.Info,
            _ => Color.Default
        };
    }
}
