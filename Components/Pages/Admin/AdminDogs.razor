@page "/admin/dogs"
@attribute [Authorize(Roles = "Admin")]
@inject IDogService DogService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Admin Dogs</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Dogs</MudText>
            <MudText Typo="Typo.body2">View dogs from all shelters and safely remove unused records.</MudText>
        </div>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading dogs...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_dogs.Count == 0)
        {
            <MudPaper Elevation="0" Class="empty-state pa-5">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Pets" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h6">No dogs found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Dog profiles from all shelters will appear here.</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudTable Items="_dogs" Dense="true" Hover="true" Class="table-shell admin-dogs-table">
                <HeaderContent>
                    <MudTh>Dog</MudTh>
                    <MudTh>Breed</MudTh>
                    <MudTh>Age</MudTh>
                    <MudTh>Size</MudTh>
                    <MudTh>Location</MudTh>
                    <MudTh>Shelter</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Success Story</MudTh>
                    <MudTh Class="actions-heading">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Dog" Class="dog-cell">
                        @{
                            var imageUrl = GetImageUrl(context);
                        }
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Size="Size.Large" Class="dog-avatar">
                                @if (imageUrl is null)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Pets" />
                                }
                                else
                                {
                                    <MudImage Src="@imageUrl" Alt="@context.Name" />
                                }
                            </MudAvatar>
                            <MudText Typo="Typo.body2" Class="dog-name">@context.Name</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Breed" Class="nowrap-cell">@context.Breed</MudTd>
                    <MudTd DataLabel="Age" Class="nowrap-cell">@FormatAge(context)</MudTd>
                    <MudTd DataLabel="Size" Class="nowrap-cell">@context.Size</MudTd>
                    <MudTd DataLabel="Location" Class="nowrap-cell">@context.Location</MudTd>
                    <MudTd DataLabel="Shelter" Class="nowrap-cell">@(context.Shelter?.Name ?? "-")</MudTd>
                    <MudTd DataLabel="Status" Class="nowrap-cell">
                        <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Success Story" Class="success-story-cell">
                        <MudStack Spacing="1">
                            @if (HasSuccessStory(context))
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Success"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.EmojiEvents"
                                           Class="story-button"
                                           OnClick="@(() => OpenSuccessStoryDialogAsync(context))">
                                    Has story
                                </MudButton>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">No story</MudChip>
                            }
                            @if (context.AdoptedAt.HasValue)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Adopted: @context.AdoptedAt.Value.ToLocalTime().ToString("dd MMM yyyy")</MudText>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Actions" Class="actions-cell">
                        <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd" Class="actions-stack">
                            <MudTooltip Text="View dog details">
                                <MudIconButton Href="@($"/dogs/{context.Id}")" Icon="@Icons.Material.Filled.Visibility" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" aria-label="View dog details" />
                            </MudTooltip>
                            <MudTooltip Text="View status history">
                                <MudIconButton Icon="@Icons.Material.Filled.History" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Disabled="_isHistoryLoading" OnClick="@(() => LoadStatusHistoryAsync(context))" aria-label="View status history" />
                            </MudTooltip>
                            <MudTooltip Text="Delete dog">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Disabled="_isDeleting" OnClick="@(() => ConfirmDeleteDogAsync(context))" aria-label="Delete dog" />
                            </MudTooltip>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            @if (_selectedHistoryDog is not null)
            {
                <MudPaper Elevation="0" Class="section-surface history-panel pa-4">
                    <MudStack Spacing="3">
                        <div>
                            <MudText Typo="Typo.h5">Status History: @_selectedHistoryDog.Name</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Internal status changes recorded for this dog.</MudText>
                        </div>

                        @if (_isHistoryLoading)
                        {
                            <MudStack AlignItems="AlignItems.Center" Class="py-4">
                                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading status history...</MudText>
                            </MudStack>
                        }
                        else if (!string.IsNullOrWhiteSpace(_historyError))
                        {
                            <MudAlert Severity="Severity.Error">@_historyError</MudAlert>
                        }
                        else if (_statusHistory.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info">No status changes have been recorded for this dog yet.</MudAlert>
                        }
                        else
                        {
                            <MudTable Items="_statusHistory" Dense="true" Hover="true" Class="table-shell">
                                <HeaderContent>
                                    <MudTh>From</MudTh>
                                    <MudTh>To</MudTh>
                                    <MudTh>Changed</MudTh>
                                    <MudTh>Changed By</MudTh>
                                    <MudTh>Notes</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="From">
                                        <MudChip T="string" Color="@GetStatusColor(context.OldStatus)" Size="Size.Small">@context.OldStatus</MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="To">
                                        <MudChip T="string" Color="@GetStatusColor(context.NewStatus)" Size="Size.Small">@context.NewStatus</MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Changed">@context.ChangedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</MudTd>
                                    <MudTd DataLabel="Changed By">@(context.ChangedByUser?.Email ?? "-")</MudTd>
                                    <MudTd DataLabel="Notes">@(string.IsNullOrWhiteSpace(context.Notes) ? "-" : context.Notes)</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudStack>
                </MudPaper>
            }
        }
    </MudStack>
</MudContainer>

@code {
    private List<Dog> _dogs = [];
    private bool _isLoading = true;
    private bool _isDeleting;
    private bool _isHistoryLoading;
    private string? _error;
    private string? _historyError;
    private Dog? _selectedHistoryDog;
    private List<DogStatusHistory> _statusHistory = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _dogs = await DogService.GetAllDogsForAdminAsync();
        }
        catch
        {
            _error = "Dog data could not be loaded. Check migrations and database connection.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ConfirmDeleteDogAsync(Dog dog)
    {
        if (!await ConfirmAsync(
            "Delete dog",
            "Are you sure you want to delete this dog? This action cannot easily be undone.",
            "Delete",
            Color.Error,
            Icons.Material.Filled.DeleteForever))
        {
            return;
        }

        await DeleteDogAsync(dog);
    }

    private async Task DeleteDogAsync(Dog dog)
    {
        _isDeleting = true;

        try
        {
            await DogService.DeleteDogForAdminAsync(dog.Id);
            _dogs.Remove(dog);
            Snackbar.Add("Dog deleted.", Severity.Success);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
        catch
        {
            Snackbar.Add("Could not delete dog. Please try again.", Severity.Error);
        }
        finally
        {
            _isDeleting = false;
        }
    }

    private async Task LoadStatusHistoryAsync(Dog dog)
    {
        _selectedHistoryDog = dog;
        _statusHistory = [];
        _historyError = null;
        _isHistoryLoading = true;

        try
        {
            _statusHistory = await DogService.GetStatusHistoryForDogAsync(dog.Id);
        }
        catch
        {
            _historyError = "Status history could not be loaded right now.";
        }
        finally
        {
            _isHistoryLoading = false;
        }
    }

    private static string? GetImageUrl(Dog dog)
    {
        return dog.Images
            .Where(i => IsValidImageUrl(i.ImageUrl))
            .OrderByDescending(i => i.IsMainImage)
            .ThenBy(i => i.Id)
            .Select(i => i.ImageUrl)
            .FirstOrDefault();
    }

    private static bool IsValidImageUrl(string? imageUrl)
    {
        if (string.IsNullOrWhiteSpace(imageUrl) ||
            imageUrl.Contains("placehold.co", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        return Uri.TryCreate(imageUrl, UriKind.Absolute, out var uri) &&
            (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);
    }

    private static Color GetStatusColor(DogStatus status)
    {
        return status switch
        {
            DogStatus.Available => Color.Success,
            DogStatus.Reserved => Color.Warning,
            DogStatus.Adopted => Color.Default,
            DogStatus.InTreatment => Color.Info,
            _ => Color.Default
        };
    }

    private static string FormatAge(Dog dog) => DogAgeFormatter.Format(dog);

    private static bool HasSuccessStory(Dog dog)
    {
        return !string.IsNullOrWhiteSpace(dog.SuccessStoryText) || dog.AdoptedAt.HasValue;
    }

    private async Task OpenSuccessStoryDialogAsync(Dog dog)
    {
        var parameters = new DialogParameters
        {
            ["DogName"] = dog.Name,
            ["Breed"] = dog.Breed,
            ["ShelterName"] = dog.Shelter?.Name,
            ["AdoptedAt"] = dog.AdoptedAt,
            ["SuccessStoryText"] = dog.SuccessStoryText
        };

        await DialogService.ShowAsync<SuccessStoryDetailsDialog>("Success Story", parameters);
    }

    private async Task<bool> ConfirmAsync(string title, string message, string confirmText, Color confirmColor, string icon)
    {
        var parameters = new DialogParameters
        {
            ["Title"] = title,
            ["Message"] = message,
            ["ConfirmText"] = confirmText,
            ["ConfirmColor"] = confirmColor,
            ["IconColor"] = confirmColor,
            ["Icon"] = icon
        };

        var dialog = await DialogService.ShowAsync<ConfirmationDialog>(title, parameters);
        var result = await dialog.Result;
        return result is not null && !result.Canceled;
    }
}
