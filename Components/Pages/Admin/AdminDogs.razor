@page "/admin/dogs"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Admin Dogs</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Dogs</MudText>
            <MudText Typo="Typo.body2">View dogs from all shelters and safely remove unused records.</MudText>
        </div>

        <MudPaper Elevation="0" Class="section-surface pa-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2" Class="flex-wrap">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Export dog records or rebuild the semantic search index for public-safe dog discovery.</MudText>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="flex-wrap">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.ManageSearch"
                               Disabled="_isLoading || _isRebuildingSearchIndex"
                               OnClick="RebuildDogSearchIndexAsync">
                        @(_isRebuildingSearchIndex ? "Rebuilding..." : "Rebuild Dog Search Index")
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.FileDownload"
                               Disabled="_isLoading || _isExporting"
                               OnClick="ExportDogsCsvAsync">
                        Export CSV
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>

        @if (!string.IsNullOrWhiteSpace(_searchIndexMessage))
        {
            <MudAlert Severity="_searchIndexSeverity" Variant="Variant.Outlined" Dense="true">@_searchIndexMessage</MudAlert>
        }

        @if (_completenessSummary is not null)
        {
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="section-surface pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Average completeness</MudText>
                        <MudText Typo="Typo.h5">@_completenessSummary.AverageScorePercent.ToString("0.#")%</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="section-surface pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Excellent profiles</MudText>
                        <MudText Typo="Typo.h5">@_completenessSummary.ExcellentCount</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="section-surface pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Need work</MudText>
                        <MudText Typo="Typo.h5">@(_completenessSummary.NeedsWorkCount + _completenessSummary.IncompleteCount)</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="section-surface pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Profiles reviewed</MudText>
                        <MudText Typo="Typo.h5">@_completenessSummary.TotalDogs</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading dogs...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_dogs.Count == 0)
        {
            <MudPaper Elevation="0" Class="empty-state pa-5">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Pets" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h6">No dogs found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Dog profiles from all shelters will appear here.</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudTable Items="_dogs" Dense="true" Hover="true" Class="table-shell admin-dogs-table">
                <HeaderContent>
                    <MudTh>Dog</MudTh>
                    <MudTh>Breed</MudTh>
                    <MudTh>Age</MudTh>
                    <MudTh>Size</MudTh>
                    <MudTh>Location</MudTh>
                    <MudTh>Shelter</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Profile Quality</MudTh>
                    <MudTh>Success Story</MudTh>
                    <MudTh Class="actions-heading">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Dog" Class="dog-cell">
                        @{
                            var imageUrl = GetImageUrl(context);
                        }
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Size="Size.Large" Class="dog-avatar">
                                @if (imageUrl is null)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Pets" />
                                }
                                else
                                {
                                    <MudImage Src="@imageUrl" Alt="@context.Name" />
                                }
                            </MudAvatar>
                            <MudText Typo="Typo.body2" Class="dog-name">@context.Name</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Breed" Class="nowrap-cell">@DogBreedFormatter.Format(context)</MudTd>
                    <MudTd DataLabel="Age" Class="nowrap-cell">@FormatAge(context)</MudTd>
                    <MudTd DataLabel="Size" Class="nowrap-cell">@context.Size</MudTd>
                    <MudTd DataLabel="Location" Class="nowrap-cell">@context.Location</MudTd>
                    <MudTd DataLabel="Shelter" Class="nowrap-cell">@(context.Shelter?.Name ?? "-")</MudTd>
                    <MudTd DataLabel="Status" Class="nowrap-cell">
                        <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Profile Quality" Class="nowrap-cell">
                        @if (TryGetCompleteness(context.Id, out var completeness))
                        {
                            <DogProfileCompletenessBadge Result="completeness" />
                            @if (completeness.ScorePercent < 70)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-1">
                                    @completeness.MissingItems.FirstOrDefault()?.Label
                                </MudText>
                            }
                        }
                    </MudTd>
                    <MudTd DataLabel="Success Story" Class="success-story-cell">
                        <MudStack Spacing="1">
                            @if (HasSuccessStory(context))
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Success"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.EmojiEvents"
                                           Class="story-button"
                                           OnClick="@(() => OpenSuccessStoryDialogAsync(context))">
                                    Has story
                                </MudButton>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">No story</MudChip>
                            }
                            @if (context.AdoptedAt.HasValue)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Adopted: @context.AdoptedAt.Value.ToLocalTime().ToString("dd MMM yyyy")</MudText>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Actions" Class="actions-cell">
                        <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd" Class="actions-stack">
                            <MudTooltip Text="View dog details">
                                <MudIconButton Href="@GetAdminDogDetailsUrl(context.Id)" Icon="@Icons.Material.Filled.Visibility" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" aria-label="View dog details" />
                            </MudTooltip>
                            <MudTooltip Text="View status history">
                                <MudIconButton Icon="@Icons.Material.Filled.History" Variant="Variant.Text" Color="Color.Info" Size="Size.Small" Disabled="_isHistoryLoading" OnClick="@(() => LoadStatusHistoryAsync(context))" aria-label="View status history" />
                            </MudTooltip>
                            <MudTooltip Text="Delete dog">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Disabled="_isDeleting" OnClick="@(() => ConfirmDeleteDogAsync(context))" aria-label="Delete dog" />
                            </MudTooltip>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>

        }
    </MudStack>
</MudContainer>

