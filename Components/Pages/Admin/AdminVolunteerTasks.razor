@page "/admin/volunteer-tasks"
@attribute [Authorize(Roles = "Admin")]
@using PawConnect.Entities
@using PawConnect.Services

<PageTitle>Admin Volunteer Tasks</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Volunteer Tasks</MudText>
            <MudText Typo="Typo.body2">Monitor volunteer scheduling across shelters.</MudText>
        </div>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading volunteer task oversight...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else
        {
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6" md="2">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Open</MudText>
                        <MudText Typo="Typo.h5">@_stats?.OpenTasks</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Assigned</MudText>
                        <MudText Typo="Typo.h5">@_stats?.AssignedTasks</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">In progress</MudText>
                        <MudText Typo="Typo.h5">@_stats?.InProgressTasks</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Overdue</MudText>
                        <MudText Typo="Typo.h5">@_stats?.OverdueTasks</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Active volunteers</MudText>
                        <MudText Typo="Typo.h5">@_stats?.ActiveVolunteers</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total</MudText>
                        <MudText Typo="Typo.h5">@_stats?.TotalTasks</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudPaper Elevation="0" Class="section-surface pa-3">
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="2">
                        <MudSelect T="VolunteerTaskStatus?" Label="Status" @bind-Value="_statusFilter" Variant="Variant.Outlined" Dense="true" Clearable="true">
                            @foreach (var status in Enum.GetValues<VolunteerTaskStatus>())
                            {
                                <MudSelectItem T="VolunteerTaskStatus?" Value="@((VolunteerTaskStatus?)status)">@FormatStatus(status)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudSelect T="VolunteerTaskCategory?" Label="Category" @bind-Value="_categoryFilter" Variant="Variant.Outlined" Dense="true" Clearable="true">
                            @foreach (var category in Enum.GetValues<VolunteerTaskCategory>())
                            {
                                <MudSelectItem T="VolunteerTaskCategory?" Value="@((VolunteerTaskCategory?)category)">@FormatCategory(category)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudSelect T="VolunteerTaskPriority?" Label="Priority" @bind-Value="_priorityFilter" Variant="Variant.Outlined" Dense="true" Clearable="true">
                            @foreach (var priority in Enum.GetValues<VolunteerTaskPriority>())
                            {
                                <MudSelectItem T="VolunteerTaskPriority?" Value="@((VolunteerTaskPriority?)priority)">@priority</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudSelect T="int?" Label="Shelter" @bind-Value="_shelterFilter" Variant="Variant.Outlined" Dense="true" Clearable="true">
                            @foreach (var shelter in _shelters)
                            {
                                <MudSelectItem T="int?" Value="@((int?)shelter.Id)">@shelter.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField T="string" Label="Search task, shelter, dog, volunteer" @bind-Value="_search" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="1">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Disabled="_isSaving" OnClick="LoadTasksAsync">Apply</MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            @if (_tasks.Count == 0)
            {
                <MudPaper Elevation="0" Class="empty-state pa-5">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.EventNote" Color="Color.Secondary" Size="Size.Large" />
                        <MudText Typo="Typo.h6">No volunteer tasks found</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Try changing filters or wait for shelters to create tasks.</MudText>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudPaper Elevation="0" Class="section-surface pa-3">
                    <MudTable Items="_tasks" Dense="true" Hover="true" Class="table-shell" RowsPerPage="12">
                        <HeaderContent>
                            <MudTh>Task</MudTh>
                            <MudTh>Shelter</MudTh>
                            <MudTh>Volunteer</MudTh>
                            <MudTh>Schedule</MudTh>
                            <MudTh>Priority</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate Context="task">
                            <MudTd DataLabel="Task">
                                <MudText Typo="Typo.body2">@task.Title</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatCategory(task.Category) @(!string.IsNullOrWhiteSpace(task.DogName) ? $"for {task.DogName}" : string.Empty)</MudText>
                            </MudTd>
                            <MudTd DataLabel="Shelter">@task.ShelterName</MudTd>
                            <MudTd DataLabel="Volunteer">@(task.AssignedVolunteerName ?? "Unassigned")</MudTd>
                            <MudTd DataLabel="Schedule">@FormatDateTime(task.ScheduledStartUtc) - @FormatTime(task.ScheduledEndUtc)</MudTd>
                            <MudTd DataLabel="Priority">
                                <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(task.Priority)" Variant="Variant.Outlined">@task.Priority</MudChip>
                            </MudTd>
                            <MudTd DataLabel="Status">
                                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(task.Status)">@FormatStatus(task.Status)</MudChip>
                            </MudTd>
                            <MudTd>
                                <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd" Class="flex-wrap">
                                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => ViewTaskAsync(task.Id))">View</MudButton>
                                    @if (task.CanCancel)
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" Disabled="_isSaving" OnClick="@(() => CancelAsync(task.Id))">Cancel</MudButton>
                                    }
                                </MudStack>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent><MudTablePager /></PagerContent>
                    </MudTable>
                </MudPaper>
            }
        }
    </MudStack>
</MudContainer>
