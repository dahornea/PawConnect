@page "/admin/shelters"
@attribute [Authorize(Roles = "Admin")]
@inject IShelterService ShelterService
@inject IGeocodingService GeocodingService
@inject ISnackbar Snackbar

<PageTitle>Shelters</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Shelters</MudText>
            <MudText Typo="Typo.body2">View registered shelter profiles and their dog counts.</MudText>
        </div>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading shelters...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_shelters.Count == 0)
        {
            <MudPaper Elevation="0" Class="empty-state pa-5">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h6">No shelters found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Shelter profiles will appear here when they are created.</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudTable Items="_shelters" Dense="true" Hover="true" Class="table-shell">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>City</MudTh>
                    <MudTh>Address</MudTh>
                    <MudTh>Email</MudTh>
                    <MudTh>Phone</MudTh>
                    <MudTh>Map</MudTh>
                    <MudTh>Dogs</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">@context.Name</MudTd>
                    <MudTd DataLabel="City">@context.City</MudTd>
                    <MudTd DataLabel="Address">@context.Address</MudTd>
                    <MudTd DataLabel="Email">@context.Email</MudTd>
                    <MudTd DataLabel="Phone">@(string.IsNullOrWhiteSpace(context.PhoneNumber) ? "-" : context.PhoneNumber)</MudTd>
                    <MudTd DataLabel="Map">
                        @if (context.Latitude.HasValue && context.Longitude.HasValue)
                        {
                            <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">Coordinates</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small">Missing</MudChip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Dogs">@context.Dogs.Count</MudTd>
                    <MudTd>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" OnClick="@(() => EditShelter(context))">Edit</MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            @if (_editShelter is not null)
            {
                <MudPaper Elevation="0" Class="section-surface edit-panel pa-4 mt-3">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.h6">Edit Shelter</MudText>
                        <MudForm @ref="_shelterForm">
                            <MudGrid Spacing="2">
                                <MudItem xs="12" md="6">
                                    <MudTextField Label="Name" @bind-Value="_editShelter.Name" Required="true" RequiredError="Shelter name is required." Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField Label="Email" @bind-Value="_editShelter.Email" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField Label="City" @bind-Value="_editShelter.City" Required="true" RequiredError="City is required." Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField Label="Phone Number" @bind-Value="_editShelter.PhoneNumber" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField Label="Address" @bind-Value="_editShelter.Address" Required="true" RequiredError="Address is required." Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField Label="Description" @bind-Value="_editShelter.Description" Lines="3" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudNumericField T="double?" Label="Latitude" @bind-Value="_editShelter.Latitude" Min="-90" Max="90" Variant="Variant.Outlined" HelperText="Optional. Use -90 to 90." />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudNumericField T="double?" Label="Longitude" @bind-Value="_editShelter.Longitude" Min="-180" Max="180" Variant="Variant.Outlined" HelperText="Optional. Use -180 to 180." />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Use address lookup first, then drag the pin or click the map to adjust the location.</MudText>
                                    <ShelterMap @bind-Latitude="_editShelter.Latitude"
                                                @bind-Longitude="_editShelter.Longitude"
                                                ShelterName="@_editShelter.Name"
                                                Address="@_editShelter.Address"
                                                City="@_editShelter.City"
                                                Height="300px"
                                                Editable="true"
                                                CoordinatesChanged="OnMapCoordinatesChangedAsync" />
                                    @if (_suggestedAddress is not null)
                                    {
                                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">
                                            <MudStack Spacing="1">
                                                <MudText Typo="Typo.subtitle2">Suggested address found from the selected map location.</MudText>
                                                <MudText Typo="Typo.body2">@_suggestedAddress.DisplayName</MudText>
                                                <MudStack Row="true" Spacing="1">
                                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="UseSuggestedAddress">Use suggested address</MudButton>
                                                    <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small" OnClick="ClearSuggestedAddress">Dismiss</MudButton>
                                                </MudStack>
                                            </MudStack>
                                        </MudAlert>
                                    }
                                </MudItem>
                            </MudGrid>
                        </MudForm>
                        <MudStack Row="true" Spacing="2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" Disabled="_isSaving" OnClick="SaveShelterAsync">Save</MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.TravelExplore" Disabled="_isSaving || _isGeocoding" OnClick="FindCoordinatesAsync">
                                @(_isGeocoding ? "Searching..." : "Find coordinates")
                            </MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Place" Disabled="@(_isSaving || !_editShelter.Latitude.HasValue || !_editShelter.Longitude.HasValue || _isReverseGeocoding)" OnClick="SuggestAddressFromCoordinatesAsync">
                                @(_isReverseGeocoding ? "Looking up..." : "Suggest address")
                            </MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Default" Disabled="_isSaving" OnClick="CancelEdit">Cancel</MudButton>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            }
        }
    </MudStack>
</MudContainer>

@code {
    private List<Shelter> _shelters = [];
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _isGeocoding;
    private bool _isReverseGeocoding;
    private string? _error;
    private Shelter? _editShelter;
    private MudForm? _shelterForm;
    private ReverseGeocodingResult? _suggestedAddress;

    protected override async Task OnInitializedAsync()
    {
        await LoadSheltersAsync();
    }

    private async Task LoadSheltersAsync()
    {
        try
        {
            _shelters = await ShelterService.GetAllSheltersAsync();
        }
        catch
        {
            _error = "Shelter data could not be loaded. Check migrations and database connection.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void EditShelter(Shelter shelter)
    {
        _editShelter = new Shelter
        {
            Id = shelter.Id,
            Name = shelter.Name,
            Description = shelter.Description,
            Address = shelter.Address,
            City = shelter.City,
            PhoneNumber = shelter.PhoneNumber,
            Email = shelter.Email,
            Latitude = shelter.Latitude,
            Longitude = shelter.Longitude
        };
    }

    private void CancelEdit()
    {
        _editShelter = null;
        _suggestedAddress = null;
    }

    private async Task SaveShelterAsync()
    {
        if (_editShelter is null)
        {
            return;
        }

        if (_shelterForm is not null)
        {
            await _shelterForm.ValidateAsync();
            if (!_shelterForm.IsValid)
            {
                return;
            }
        }

        _isSaving = true;

        try
        {
            await ShelterService.UpdateShelterProfileAsync(_editShelter);
            Snackbar.Add("Shelter profile saved.", Severity.Success);
            _editShelter = null;
            await LoadSheltersAsync();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Warning);
        }
        catch
        {
            Snackbar.Add("Could not save shelter profile. Please try again.", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task FindCoordinatesAsync()
    {
        if (_editShelter is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_editShelter.Address) || string.IsNullOrWhiteSpace(_editShelter.City))
        {
            Snackbar.Add("Enter shelter address and city before searching for coordinates.", Severity.Warning);
            return;
        }

        _isGeocoding = true;
        try
        {
            var result = await GeocodingService.FindCoordinatesAsync(_editShelter.Address, _editShelter.City);
            if (result is null)
            {
                Snackbar.Add("Could not find coordinates for this address. Please check the address or enter coordinates manually.", Severity.Warning);
                return;
            }

            _editShelter.Latitude = result.Latitude;
            _editShelter.Longitude = result.Longitude;
            _suggestedAddress = null;
            Snackbar.Add("Coordinates found. Save the shelter profile to keep them.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Could not search for coordinates right now. You can enter them manually.", Severity.Error);
        }
        finally
        {
            _isGeocoding = false;
        }
    }

    private async Task OnMapCoordinatesChangedAsync((double Latitude, double Longitude) coordinates)
    {
        if (_editShelter is null)
        {
            return;
        }

        _editShelter.Latitude = coordinates.Latitude;
        _editShelter.Longitude = coordinates.Longitude;
        await SuggestAddressFromCoordinatesAsync(showFailureMessage: false);
    }

    private async Task SuggestAddressFromCoordinatesAsync()
    {
        await SuggestAddressFromCoordinatesAsync(showFailureMessage: true);
    }

    private async Task SuggestAddressFromCoordinatesAsync(bool showFailureMessage)
    {
        if (_editShelter is null)
        {
            return;
        }

        if (!_editShelter.Latitude.HasValue || !_editShelter.Longitude.HasValue)
        {
            if (showFailureMessage)
            {
                Snackbar.Add("Choose coordinates before asking for an address suggestion.", Severity.Warning);
            }
            return;
        }

        _isReverseGeocoding = true;
        try
        {
            _suggestedAddress = await GeocodingService.ReverseGeocodeAsync(_editShelter.Latitude.Value, _editShelter.Longitude.Value);
            if (_suggestedAddress is null && showFailureMessage)
            {
                Snackbar.Add("Could not suggest an address for this location.", Severity.Info);
            }
        }
        catch
        {
            _suggestedAddress = null;
            if (showFailureMessage)
            {
                Snackbar.Add("Could not suggest an address for this location.", Severity.Info);
            }
        }
        finally
        {
            _isReverseGeocoding = false;
        }
    }

    private void UseSuggestedAddress()
    {
        if (_editShelter is null || _suggestedAddress is null)
        {
            return;
        }

        if (!string.IsNullOrWhiteSpace(_suggestedAddress.SuggestedAddress))
        {
            _editShelter.Address = _suggestedAddress.SuggestedAddress;
        }

        if (!string.IsNullOrWhiteSpace(_suggestedAddress.City))
        {
            _editShelter.City = _suggestedAddress.City;
        }

        _suggestedAddress = null;
        Snackbar.Add("Suggested address applied. Save the shelter profile to keep it.", Severity.Success);
    }

    private void ClearSuggestedAddress()
    {
        _suggestedAddress = null;
    }
}
