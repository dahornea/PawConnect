@page "/admin/shelters"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Shelters</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Shelters</MudText>
            <MudText Typo="Typo.body2">View registered shelter profiles and their dog counts.</MudText>
        </div>

        <MudPaper Elevation="0" Class="section-surface import-export-card pa-4">
            <MudStack Spacing="3">
                <div>
                    <MudText Typo="Typo.h6" Class="content-title">Shelter records</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Import shelter applications as pending requests, or export approved shelter profiles.</MudText>
                </div>
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="7">
                        <MudStack Spacing="2" Class="tool-section">
                            <div>
                                <MudText Typo="Typo.subtitle2" Class="tool-section-title">Import CSV</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Preview shelter rows and create pending registration requests for admin approval.</MudText>
                            </div>
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="tool-actions">
                                <div class="file-picker-shell">
                                    <InputFile @key="_shelterRequestImportInputKey" OnChange="OnShelterRequestCsvSelectedAsync" accept=".csv" />
                                </div>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.FileUpload"
                                           Disabled="@(_isLoading || _isImporting)"
                                           OnClick="PreviewSelectedShelterRequestFileAsync">
                                    Preview Import
                                </MudButton>
                                <MudButton Variant="Variant.Text"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Download"
                                           OnClick="DownloadShelterRequestsTemplateAsync">
                                    Download Template
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" md="5">
                        <MudStack Spacing="2" Class="tool-section">
                            <div>
                                <MudText Typo="Typo.subtitle2" Class="tool-section-title">Export</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Download approved shelter profiles and dog counts.</MudText>
                            </div>
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="tool-actions">
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.FileDownload"
                                           Disabled="_isLoading || _isExporting"
                                           OnClick="ExportSheltersCsvAsync">
                                    Export CSV
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudStack>
        </MudPaper>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading shelters...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else
        {
            @if (_importResult is not null)
            {
                <MudPaper Elevation="0" Class="section-surface pa-4">
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="flex-wrap">
                            <div>
                                <MudText Typo="Typo.h6">Shelter Request CSV Preview</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @_importResult.TotalRows rows found, @_importResult.ValidRows valid, @_importResult.InvalidRows invalid.
                                </MudText>
                            </div>
                            <MudSpacer />
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Check"
                                       Disabled="@(_isImporting || _importResult.HasErrors || _importResult.ValidRows == 0 || _shelterRequestImportFile is null)"
                                       OnClick="ConfirmShelterRequestImportAsync">
                                Confirm Import
                            </MudButton>
                            <MudButton Variant="Variant.Text" Color="Color.Default" Disabled="_isImporting" OnClick="ClearShelterRequestImportPreview">
                                Clear
                            </MudButton>
                        </MudStack>

                        @if (_importResult.HasErrors)
                        {
                            <MudAlert Severity="Severity.Warning">CSV contains validation errors. Please review the rows below.</MudAlert>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Valid rows will be created as pending shelter registration requests. No user accounts or shelter profiles are created until an admin approves them.</MudAlert>
                        }

                        <MudTable Items="_importResult.RowResults" Dense="true" Hover="true" Class="table-shell">
                            <HeaderContent>
                                <MudTh>Row</MudTh>
                                <MudTh>Shelter</MudTh>
                                <MudTh>Email</MudTh>
                                <MudTh>City</MudTh>
                                <MudTh>Action</MudTh>
                                <MudTh>Status</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="row">
                                <MudTd DataLabel="Row">@row.RowNumber</MudTd>
                                <MudTd DataLabel="Shelter">@GetImportValue(row, "ShelterName")</MudTd>
                                <MudTd DataLabel="Email">@GetImportValue(row, "Email")</MudTd>
                                <MudTd DataLabel="City">@GetImportValue(row, "City")</MudTd>
                                <MudTd DataLabel="Action">@row.Action</MudTd>
                                <MudTd DataLabel="Status">
                                    @if (row.IsValid)
                                    {
                                        <MudChip T="string" Color="Color.Success" Size="Size.Small">Valid</MudChip>
                                    }
                                    else
                                    {
                                        <MudTooltip Text="@FormatImportErrors(row)">
                                            <MudChip T="string" Color="Color.Error" Size="Size.Small">Invalid</MudChip>
                                        </MudTooltip>
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudStack>
                </MudPaper>
            }

            @if (_shelters.Count == 0)
            {
                <MudPaper Elevation="0" Class="empty-state pa-5">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Secondary" Size="Size.Large" />
                        <MudText Typo="Typo.h6">No shelters found</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Shelter profiles will appear here when they are created.</MudText>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudTable Items="_shelters" Dense="true" Hover="true" Class="table-shell">
                    <HeaderContent>
                        <MudTh>Name</MudTh>
                        <MudTh>City</MudTh>
                        <MudTh>Neighborhood</MudTh>
                        <MudTh>Address</MudTh>
                        <MudTh>Email</MudTh>
                        <MudTh>Phone</MudTh>
                        <MudTh>Map</MudTh>
                        <MudTh>Dogs</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Name">@context.Name</MudTd>
                        <MudTd DataLabel="City">@context.City</MudTd>
                        <MudTd DataLabel="Neighborhood">@(string.IsNullOrWhiteSpace(context.Neighborhood) ? "-" : context.Neighborhood)</MudTd>
                        <MudTd DataLabel="Address">@context.Address</MudTd>
                        <MudTd DataLabel="Email">@context.Email</MudTd>
                        <MudTd DataLabel="Phone">@(string.IsNullOrWhiteSpace(context.PhoneNumber) ? "-" : context.PhoneNumber)</MudTd>
                        <MudTd DataLabel="Map">
                            @if (context.Latitude.HasValue && context.Longitude.HasValue)
                            {
                                <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">Map location selected</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small">No map location</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Dogs">@context.Dogs.Count</MudTd>
                        <MudTd>
                            <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" OnClick="@(() => EditShelter(context))">Edit</MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }

            @if (_editShelter is not null)
            {
                <MudPaper Elevation="0" Class="section-surface edit-panel pa-4 mt-3">
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.h6">Edit Shelter</MudText>
                        @if (!string.IsNullOrWhiteSpace(_shelterFormError))
                        {
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                                @_shelterFormError
                            </MudAlert>
                        }
                        <MudForm @ref="_shelterForm">
                            <MudGrid Spacing="2">
                                <MudItem xs="12" md="6">
                                    <MudTextField Label="Name" @bind-Value="_editShelter.Name" Required="true" RequiredError="Shelter name is required." Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField Label="Email"
                                                  @bind-Value="_editShelter.Email"
                                                  @bind-Value:after="ClearShelterEmailError"
                                                  Error="@HasShelterEmailError"
                                                  ErrorText="@_shelterEmailError"
                                                  Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField Label="City"
                                                  @bind-Value="_editShelter.City"
                                                  @bind-Value:after="OnShelterLocationFieldChanged"
                                                  Required="true"
                                                  RequiredError="City is required."
                                                  Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField Label="Phone Number" @bind-Value="_editShelter.PhoneNumber" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField Label="Neighborhood"
                                                  @bind-Value="_editShelter.Neighborhood"
                                                  @bind-Value:after="OnShelterLocationFieldChanged"
                                                  HelperText="Optional. Used to help adopters find nearby shelters and dogs."
                                                  Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField Label="Address"
                                                  @bind-Value="_editShelter.Address"
                                                  @bind-Value:after="OnShelterLocationFieldChanged"
                                                  Required="true"
                                                  RequiredError="Address is required."
                                                  Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField Label="Description" @bind-Value="_editShelter.Description" Lines="3" Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudNumericField T="int" Label="Dog capacity" @bind-Value="_editShelter.DogCapacity" Min="1" Max="1000" Required="true" HelperText="Total safe dog spaces used by the scenario simulator." Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudNumericField T="int" Label="Reserved emergency spaces" @bind-Value="_editShelter.ReservedEmergencySpaces" Min="0" Max="1000" Required="true" HelperText="Spaces kept outside normal intake capacity." Variant="Variant.Outlined" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudPaper Elevation="0" Class="section-surface pa-3">
                                        <MudStack Spacing="2">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudIcon Icon="@Icons.Material.Filled.Schedule" Color="Color.Primary" />
                                                <MudText Typo="Typo.subtitle1">Visiting Hours</MudText>
                                            </MudStack>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">These hours are used to validate adopter-selected visit times.</MudText>
                                            @if (!string.IsNullOrWhiteSpace(_visitHoursError))
                                            {
                                                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                                                    @_visitHoursError
                                                </MudAlert>
                                            }
                                            <MudGrid Spacing="2">
                                                <MudItem xs="12" sm="6">
                                                    <MudTimePicker Label="Visit start time"
                                                                   @bind-Time="_editShelter.VisitStartTime"
                                                                   @bind-Time:after="ClearVisitHoursError"
                                                                   Variant="Variant.Outlined" />
                                                </MudItem>
                                                <MudItem xs="12" sm="6">
                                                    <MudTimePicker Label="Visit end time"
                                                                   @bind-Time="_editShelter.VisitEndTime"
                                                                   @bind-Time:after="ClearVisitHoursError"
                                                                   Variant="Variant.Outlined" />
                                                </MudItem>
                                            </MudGrid>
                                            <MudStack Row="true" Spacing="1" Class="flex-wrap">
                                                <MudCheckBox T="bool" Label="Mon" @bind-Value="_editShelter.VisitsAllowedMonday" />
                                                <MudCheckBox T="bool" Label="Tue" @bind-Value="_editShelter.VisitsAllowedTuesday" />
                                                <MudCheckBox T="bool" Label="Wed" @bind-Value="_editShelter.VisitsAllowedWednesday" />
                                                <MudCheckBox T="bool" Label="Thu" @bind-Value="_editShelter.VisitsAllowedThursday" />
                                                <MudCheckBox T="bool" Label="Fri" @bind-Value="_editShelter.VisitsAllowedFriday" />
                                                <MudCheckBox T="bool" Label="Sat" @bind-Value="_editShelter.VisitsAllowedSaturday" />
                                                <MudCheckBox T="bool" Label="Sun" @bind-Value="_editShelter.VisitsAllowedSunday" />
                                            </MudStack>
                                        </MudStack>
                                    </MudPaper>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Use address lookup first, then drag the pin or click the map to adjust the location.</MudText>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="flex-wrap my-2">
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.TravelExplore"
                                                   Disabled="@(_isSaving || _isGeocoding)"
                                                   OnClick="FindShelterCoordinatesAsync">
                                            @(_isGeocoding ? "Searching..." : "Find location")
                                        </MudButton>
                                        @if (_isGeocoding)
                                        {
                                            <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary" />
                                        }
                                    </MudStack>
                                    <ShelterMap @bind-Latitude="_editShelter.Latitude"
                                                @bind-Longitude="_editShelter.Longitude"
                                                ShelterName="@_editShelter.Name"
                                                Address="@_editShelter.Address"
                                                City="@_editShelter.City"
                                                Height="300px"
                                                Editable="true"
                                                CoordinatesChanged="OnMapCoordinatesChangedAsync" />
                                    @if (!string.IsNullOrWhiteSpace(_shelterLocationError))
                                    {
                                        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mt-2">
                                            @_shelterLocationError
                                        </MudAlert>
                                    }
                                    @if (!_editShelter.Latitude.HasValue || !_editShelter.Longitude.HasValue)
                                    {
                                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">No map location selected. The shelter can still be saved without map coordinates.</MudAlert>
                                    }
                                    else
                                    {
                                        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mt-2">Map location selected. Drag the pin or click the map to adjust it.</MudAlert>
                                    }
                                    @if (_suggestedAddress is not null)
                                    {
                                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">
                                            <MudStack Spacing="1">
                                                <MudText Typo="Typo.subtitle2">Suggested address</MudText>
                                                <MudText Typo="Typo.body2">@GetSuggestedAddressPreview(_suggestedAddress)</MudText>
                                            </MudStack>
                                        </MudAlert>
                                    }
                                    else if (_suggestedAddressUnavailable)
                                    {
                                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">No suggested address found for this pin. You can still save the map location.</MudAlert>
                                    }
                                </MudItem>
                            </MudGrid>
                        </MudForm>
                        <MudStack Row="true" Spacing="2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" Disabled="_isSaving" OnClick="SaveShelterAsync">Save</MudButton>
                            @if (IsLocationDirty)
                            {
                                <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Restore" Disabled="_isSaving" OnClick="RevertToSavedLocation">
                                    Revert to saved location
                                </MudButton>
                            }
                            @if (_editShelter.Latitude.HasValue && _editShelter.Longitude.HasValue)
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.EditLocationAlt" Disabled="_isSaving || _isReverseGeocoding || _suggestedAddress is null" OnClick="UpdateAddressFromPin">
                                    Update address from pin
                                </MudButton>
                            }
                            <MudButton Variant="Variant.Text" Color="Color.Default" Disabled="_isSaving" OnClick="CancelEdit">Cancel</MudButton>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            }
        }
    </MudStack>
</MudContainer>

