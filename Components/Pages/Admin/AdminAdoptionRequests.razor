@page "/admin/adoption-requests"
@using PawConnect.Data
@attribute [Authorize(Roles = "Admin")]
@inject IAdoptionRequestService AdoptionRequestService

<PageTitle>Admin Adoption Requests</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div>
            <MudText Typo="Typo.h4">Adoption Requests</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">View adoption request activity across all shelters.</MudText>
        </div>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading adoption requests...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_requests.Count == 0)
        {
            <MudPaper Elevation="0" Class="empty-state pa-5">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.FactCheck" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h6">No adoption requests found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Submitted adoption requests across shelters will appear here.</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudTable Items="_requests" Dense="true" Hover="true" Class="table-shell">
                <HeaderContent>
                    <MudTh>Dog</MudTh>
                    <MudTh>Shelter</MudTh>
                    <MudTh>Adopter</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Questionnaire</MudTh>
                    <MudTh>Internal Notes</MudTh>
                    <MudTh>Profile</MudTh>
                    <MudTh>Created</MudTh>
                    <MudTh>Updated</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Dog">@context.Dog?.Name</MudTd>
                    <MudTd DataLabel="Shelter">@(context.Dog?.Shelter?.Name ?? "-")</MudTd>
                    <MudTd DataLabel="Adopter">@GetAdopterName(context.Adopter)</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Questionnaire">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body2">@context.ReasonForAdoption</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Hours alone: @(context.HoursAlonePerDay.HasValue ? context.HoursAlonePerDay.Value : "-")</MudText>
                            @if (!string.IsNullOrWhiteSpace(context.AdditionalInformation))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.AdditionalInformation</MudText>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Internal Notes">
                        <MudStack Spacing="1">
                            <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Outlined">Private</MudChip>
                            @if (string.IsNullOrWhiteSpace(context.ShelterInternalNotes))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">No internal notes</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption">@context.ShelterInternalNotes</MudText>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Profile">
                        @if (context.Adopter?.AdopterProfile is null)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">No profile</MudText>
                        }
                        else
                        {
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2">@context.Adopter.AdopterProfile.FullName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Adopter.AdopterProfile.City | @context.Adopter.AdopterProfile.HousingType</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Yard: @FormatYesNo(context.Adopter.AdopterProfile.HasYard) |
                                    Pets: @FormatYesNo(context.Adopter.AdopterProfile.HasOtherPets) |
                                    Children: @FormatYesNo(context.Adopter.AdopterProfile.HasChildren)
                                </MudText>
                            </MudStack>
                        }
                    </MudTd>
                    <MudTd DataLabel="Created">@context.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</MudTd>
                    <MudTd DataLabel="Updated">@context.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudStack>
</MudContainer>

@code {
    private List<AdoptionRequest> _requests = [];
    private bool _isLoading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _requests = await AdoptionRequestService.GetAllAsync();
        }
        catch
        {
            _error = "Adoption request data could not be loaded right now.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string GetAdopterName(ApplicationUser? adopter)
    {
        if (adopter is null)
        {
            return "Unknown adopter";
        }

        return string.IsNullOrWhiteSpace(adopter.FullName)
            ? adopter.Email ?? adopter.UserName ?? "Unknown adopter"
            : $"{adopter.FullName} ({adopter.Email})";
    }

    private static Color GetStatusColor(AdoptionRequestStatus status)
    {
        return status switch
        {
            AdoptionRequestStatus.Pending => Color.Warning,
            AdoptionRequestStatus.Accepted => Color.Success,
            AdoptionRequestStatus.Rejected => Color.Error,
            AdoptionRequestStatus.Cancelled => Color.Default,
            _ => Color.Default
        };
    }

    private static string FormatYesNo(bool value)
    {
        return value ? "Yes" : "No";
    }
}
