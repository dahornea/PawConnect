@page "/admin/adoption-requests"
@using PawConnect.Data
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Admin Adoption Requests</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0 adoption-requests-page">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Adoption Requests</MudText>
            <MudText Typo="Typo.body2">View adoption request activity across all shelters.</MudText>
        </div>

        <MudPaper Elevation="0" Class="section-surface pa-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2" Class="flex-wrap">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Export all adoption request records as CSV or a formatted PDF summary.</MudText>
                <MudStack Row="true" Spacing="1" Class="flex-wrap">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.FileDownload"
                               Disabled="_isLoading || _isExporting"
                               OnClick="ExportAdoptionRequestsCsvAsync">
                        Export CSV
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.PictureAsPdf"
                               Disabled="_isLoading || _isExporting"
                               OnClick="ExportAdoptionRequestsPdfAsync">
                        Export PDF
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading adoption requests...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_requests.Count == 0)
        {
            <MudPaper Elevation="0" Class="empty-state pa-5">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.FactCheck" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h6">No adoption requests found</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Submitted adoption requests across shelters will appear here.</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudGrid Spacing="2" Class="request-summary-grid">
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="summary-card pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total</MudText>
                        <MudText Typo="Typo.h5">@_requests.Count</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="summary-card pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Pending</MudText>
                        <MudText Typo="Typo.h5">@PendingRequestCount</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="summary-card pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Visits Confirmed</MudText>
                        <MudText Typo="Typo.h5">@VisitConfirmedCount</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Elevation="0" Class="summary-card pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Adopted</MudText>
                        <MudText Typo="Typo.h5">@AcceptedRequestCount</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudPaper Elevation="0" Class="section-surface requests-shell pa-3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="requests-toolbar">
                    <div>
                        <MudText Typo="Typo.h6" Class="content-title">Requests</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_requests.Count request(s) across all shelters</MudText>
                    </div>
                    <MudSpacer />
                    <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">@PendingRequestCount pending</MudChip>
                </MudStack>

                <MudTable Items="_requests" Dense="true" Hover="true" Class="table-shell admin-adoption-table">
                    <HeaderContent>
                        <MudTh>Dog</MudTh>
                        <MudTh>Shelter</MudTh>
                        <MudTh>Adopter</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Visit</MudTh>
                        <MudTh>Created</MudTh>
                        <MudTh>Updated</MudTh>
                        <MudTh Class="actions-heading">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Dog">
                            <MudStack Spacing="0" Class="request-primary-cell">
                                <MudText Typo="Typo.body2" Class="request-primary-text">@DisplayOrFallback(context.Dog?.Name)</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@DisplayOrFallback(DogBreedFormatter.Format(context.Dog))</MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Shelter">@DisplayOrFallback(context.Dog?.Shelter?.Name)</MudTd>
                        <MudTd DataLabel="Adopter">
                            <MudStack Spacing="0" Class="request-primary-cell">
                                <MudText Typo="Typo.body2" Class="request-primary-text">@GetAdopterName(context.Adopter)</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@DisplayOrFallback(context.Adopter?.AdopterProfile?.City)</MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@GetRequestStatusText(context.Status)</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Visit">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.caption">@FormatTableVisitDateTime(context.PreferredVisitDateTime)</MudText>
                                @if (ShouldShowVisitChip(context.VisitStatus))
                                {
                                    <MudChip T="string" Color="@GetVisitStatusColor(context.VisitStatus)" Size="Size.Small" Variant="Variant.Outlined">@GetVisitChipText(context.VisitStatus)</MudChip>
                                }
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Created" Class="request-date-cell">
                            <MudStack Spacing="0" Class="request-date">
                                <MudText Typo="Typo.body2">@FormatTableDate(context.CreatedAt)</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatTableTime(context.CreatedAt)</MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Updated" Class="request-date-cell">
                            <MudStack Spacing="0" Class="request-date">
                                <MudText Typo="Typo.body2">@FormatTableDate(context.UpdatedAt)</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatTableTime(context.UpdatedAt)</MudText>
                            </MudStack>
                        </MudTd>
                        <MudTd DataLabel="Actions" Class="actions-cell">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Visibility"
                                       Class="request-details-button"
                                       OnClick="@(() => OpenRequestDetailsAsync(context))">
                                Details
                            </MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }
    </MudStack>
</MudContainer>

