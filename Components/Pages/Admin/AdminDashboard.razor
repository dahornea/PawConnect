@page "/admin/dashboard"
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using PawConnect.Data
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Admin Dashboard</PageTitle>

<div class="admin-dashboard">
<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <section class="admin-hero pa-5">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <span class="hero-icon"><MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" /></span>
                <div>
                    <MudText Typo="Typo.caption" Class="dashboard-kicker">System overview</MudText>
                    <MudText Typo="Typo.h4">Admin Dashboard</MudText>
                    <MudText Typo="Typo.body1">Review users, shelters, dogs, and pending adoption activity.</MudText>
                </div>
            </MudStack>
        </section>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading admin dashboard...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Class="stat-card"><MudCardContent><MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"><span class="stat-icon"><MudIcon Icon="@Icons.Material.Filled.People" /></span><div><MudText Typo="Typo.caption" Color="Color.Secondary">Users</MudText><MudText Typo="Typo.h4">@_totalUsers</MudText></div></MudStack></MudCardContent></MudCard>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Class="stat-card"><MudCardContent><MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"><span class="stat-icon"><MudIcon Icon="@Icons.Material.Filled.Business" /></span><div><MudText Typo="Typo.caption" Color="Color.Secondary">Shelters</MudText><MudText Typo="Typo.h4">@_totalShelters</MudText></div></MudStack></MudCardContent></MudCard>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Class="stat-card"><MudCardContent><MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"><span class="stat-icon"><MudIcon Icon="@Icons.Material.Filled.Pets" /></span><div><MudText Typo="Typo.caption" Color="Color.Secondary">Dogs</MudText><MudText Typo="Typo.h4">@_totalDogs</MudText></div></MudStack></MudCardContent></MudCard>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Class="stat-card"><MudCardContent><MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"><span class="stat-icon warning"><MudIcon Icon="@Icons.Material.Filled.HourglassTop" /></span><div><MudText Typo="Typo.caption" Color="Color.Secondary">Pending requests</MudText><MudText Typo="Typo.h4">@_pendingRequests</MudText></div></MudStack></MudCardContent></MudCard>
                </MudItem>
            </MudGrid>

            <MudPaper Elevation="0" Class="section-surface secondary-overview pa-3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.subtitle2">Secondary overview</MudText>
                    <MudSpacer />
                    <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small">@_availableDogs available dogs</MudChip>
                    <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small">@_adoptedDogs adopted dogs</MudChip>
                    <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">@_lowStockResources low-stock shelter resources</MudChip>
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="0" Class="section-surface pa-4">
                <MudText Typo="Typo.h5" Class="section-title mb-3">Quick Navigation</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Href="/admin/users" Class="quick-action-button" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.People">Users</MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Href="/admin/shelters" Class="quick-action-button" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Business">Shelters</MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Href="/admin/dogs" Class="quick-action-button" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Pets">Dogs</MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Href="/admin/adoption-requests" Class="quick-action-button" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Assignment">Adoption Requests</MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <IntelligenceDashboardWidget AudienceType="IntelligenceAudienceType.Admin" WidgetTitle="Platform risk overview" />
        }
    </MudStack>
</MudContainer>
</div>

