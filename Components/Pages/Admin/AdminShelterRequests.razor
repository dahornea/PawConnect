@page "/admin/shelter-requests"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Identity
@using PawConnect.Data

<PageTitle>Shelter Requests</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Shelter Requests</MudText>
            <MudText Typo="Typo.body2">Review public shelter applications before creating shelter accounts.</MudText>
        </div>

        <MudPaper Elevation="0" Class="section-surface pa-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2" Class="flex-wrap">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Export all shelter applications as CSV or a formatted PDF summary.</MudText>
                <MudStack Row="true" Spacing="1" Class="flex-wrap">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.FileDownload"
                               Disabled="_isLoading || _isExporting"
                               OnClick="ExportShelterRequestsCsvAsync">
                        Export CSV
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.PictureAsPdf"
                               Disabled="_isLoading || _isExporting"
                               OnClick="ExportShelterRequestsPdfAsync">
                        Export PDF
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading shelter applications...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_requests.Count == 0)
        {
            <MudPaper Elevation="0" Class="empty-state pa-5">
                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.MarkEmailUnread" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h6">No shelter applications yet</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Applications submitted from /shelters/apply will appear here.</MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudGrid Spacing="2">
                <MudItem xs="12" md="3">
                    <MudCard Class="stat-card"><MudCardContent><MudText Typo="Typo.caption" Color="Color.Secondary">Total</MudText><MudText Typo="Typo.h5">@_requests.Count</MudText></MudCardContent></MudCard>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudCard Class="stat-card"><MudCardContent><MudText Typo="Typo.caption" Color="Color.Secondary">Pending</MudText><MudText Typo="Typo.h5">@CountStatus(ShelterRegistrationRequestStatus.Pending)</MudText></MudCardContent></MudCard>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudCard Class="stat-card"><MudCardContent><MudText Typo="Typo.caption" Color="Color.Secondary">Accepted</MudText><MudText Typo="Typo.h5">@CountStatus(ShelterRegistrationRequestStatus.Accepted)</MudText></MudCardContent></MudCard>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudCard Class="stat-card"><MudCardContent><MudText Typo="Typo.caption" Color="Color.Secondary">Rejected</MudText><MudText Typo="Typo.h5">@CountStatus(ShelterRegistrationRequestStatus.Rejected)</MudText></MudCardContent></MudCard>
                </MudItem>
            </MudGrid>

            <MudTable Items="_requests" Dense="true" Hover="true" Class="table-shell">
                <HeaderContent>
                    <MudTh>Shelter</MudTh>
                    <MudTh>Contact</MudTh>
                    <MudTh>Location</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Submitted</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Shelter">
                        <MudText Typo="Typo.subtitle2">@context.ShelterName</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@context.Description</MudText>
                    </MudTd>
                    <MudTd DataLabel="Contact">
                        <MudText Typo="Typo.body2">@context.ContactPersonName</MudText>
                        <MudText Typo="Typo.caption">@context.Email</MudText>
                        <MudText Typo="Typo.caption">@context.PhoneNumber</MudText>
                    </MudTd>
                    <MudTd DataLabel="Location">
                        <MudText Typo="Typo.body2">@context.Address</MudText>
                        <MudText Typo="Typo.caption">@context.City</MudText>
                        @if (context.Latitude.HasValue && context.Longitude.HasValue)
                        {
                            <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Outlined">Map location selected</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">No map location</MudChip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Submitted">@context.SubmittedAt.ToLocalTime().ToString("dd MMM yyyy")</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudStack Row="true" Spacing="1" Class="action-cell">
                            <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Visibility" OnClick="@(() => ViewRequest(context))">Details</MudButton>
                            @if (context.Status == ShelterRegistrationRequestStatus.Pending)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" OnClick="@(() => AcceptAsync(context.Id))">Accept</MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" OnClick="@(() => RejectAsync(context.Id))">Reject</MudButton>
                            }
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudStack>
</MudContainer>

