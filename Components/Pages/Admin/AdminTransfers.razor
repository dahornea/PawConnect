@page "/admin/transfers"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Admin Transfers</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <MudStack Spacing="3">
        <div class="page-header">
            <MudText Typo="Typo.h4">Dog Transfers</MudText>
            <MudText Typo="Typo.body2">Monitor shelter-to-shelter transfer requests and operational handovers.</MudText>
        </div>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="py-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading transfer oversight...</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else
        {
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6" md="2">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Pending</MudText>
                        <MudText Typo="Typo.h5">@_stats?.IncomingPending</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Approved</MudText>
                        <MudText Typo="Typo.h5">@_stats?.ApprovedWaitingCompletion</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Completed</MudText>
                        <MudText Typo="Typo.h5">@_stats?.Completed</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Urgent active</MudText>
                        <MudText Typo="Typo.h5">@_stats?.UrgentRequests</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="2">
                    <MudPaper Elevation="0" Class="section-surface pa-3 h-100">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total</MudText>
                        <MudText Typo="Typo.h5">@_stats?.Total</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudPaper Elevation="0" Class="section-surface pa-3">
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="2">
                        <MudSelect T="DogTransferStatus?" Label="Status" @bind-Value="_statusFilter" Variant="Variant.Outlined" Dense="true" Clearable="true">
                            @foreach (var status in Enum.GetValues<DogTransferStatus>())
                            {
                                <MudSelectItem T="DogTransferStatus?" Value="@((DogTransferStatus?)status)">@status</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudSelect T="DogTransferPriority?" Label="Priority" @bind-Value="_priorityFilter" Variant="Variant.Outlined" Dense="true" Clearable="true">
                            @foreach (var priority in Enum.GetValues<DogTransferPriority>())
                            {
                                <MudSelectItem T="DogTransferPriority?" Value="@((DogTransferPriority?)priority)">@priority</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudSelect T="int?" Label="Source" @bind-Value="_sourceShelterFilter" Variant="Variant.Outlined" Dense="true" Clearable="true">
                            @foreach (var shelter in _shelters)
                            {
                                <MudSelectItem T="int?" Value="@((int?)shelter.Id)">@shelter.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudSelect T="int?" Label="Destination" @bind-Value="_destinationShelterFilter" Variant="Variant.Outlined" Dense="true" Clearable="true">
                            @foreach (var shelter in _shelters)
                            {
                                <MudSelectItem T="int?" Value="@((int?)shelter.Id)">@shelter.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField T="string" Label="Search dog, shelter, or reason" @bind-Value="_search" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="1">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Disabled="_isSaving" OnClick="LoadTransfersAsync">Apply</MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            @if (_transfers.Count == 0)
            {
                <MudPaper Elevation="0" Class="empty-state pa-5">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Color="Color.Secondary" Size="Size.Large" />
                        <MudText Typo="Typo.h6">No transfer requests found</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Try changing filters or wait for shelters to request transfers.</MudText>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudPaper Elevation="0" Class="section-surface pa-3">
                    <MudTable Items="_transfers" Dense="true" Hover="true" Class="table-shell" RowsPerPage="12">
                        <HeaderContent>
                            <MudTh>Dog</MudTh>
                            <MudTh>Route</MudTh>
                            <MudTh>Priority</MudTh>
                            <MudTh>Reason</MudTh>
                            <MudTh>Requested</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh Class="actions-heading">Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate Context="transfer">
                            <MudTd DataLabel="Dog">
                                <MudText Typo="Typo.body2">@transfer.DogName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@transfer.DogBreed</MudText>
                            </MudTd>
                            <MudTd DataLabel="Route">
                                <MudText Typo="Typo.body2">@transfer.SourceShelterName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">to @transfer.DestinationShelterName</MudText>
                            </MudTd>
                            <MudTd DataLabel="Priority">
                                <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(transfer.Priority)" Variant="Variant.Outlined">@transfer.Priority</MudChip>
                            </MudTd>
                            <MudTd DataLabel="Reason">@transfer.ReasonPreview</MudTd>
                            <MudTd DataLabel="Requested">@FormatDateTime(transfer.RequestedAtUtc)</MudTd>
                            <MudTd DataLabel="Status">
                                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(transfer.Status)">@FormatStatus(transfer.Status)</MudChip>
                            </MudTd>
                            <MudTd DataLabel="Actions" Class="actions-cell">
                                <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd" Class="flex-wrap">
                                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => ViewTransferAsync(transfer.Id))">View</MudButton>
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Disabled="_isSaving" OnClick="@(() => UpdateAdminNoteAsync(transfer.Id))">Admin note</MudButton>
                                    @if (transfer.CanCancel)
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" Disabled="_isSaving" OnClick="@(() => CancelAsync(transfer.Id))">Cancel</MudButton>
                                    }
                                    @if (transfer.CanComplete)
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Disabled="_isSaving" OnClick="@(() => CompleteAsync(transfer.Id))">Complete</MudButton>
                                    }
                                </MudStack>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent><MudTablePager /></PagerContent>
                    </MudTable>
                </MudPaper>
            }
        }
    </MudStack>
</MudContainer>
