@page "/"
@using PawConnect.Data
@inject IDogService DogService
@inject ISnackbar Snackbar

<PageTitle>PawConnect: A Web Platform for Stray Dog Adoption and Shelter Management</PageTitle>

<div class="home-page">
    <MudStack Spacing="3">
        <section class="hero-surface pa-4">
            <MudGrid Class="hero-grid" Spacing="4">
                <MudItem xs="12" md="7">
                    <div class="hero-content">
                        <MudText Typo="Typo.caption" Class="page-kicker">Stray dog adoption and shelter care</MudText>
                        <MudText Typo="Typo.h2" Class="mt-1 hero-title" GutterBottom="true">PawConnect</MudText>
                        <MudText Typo="Typo.subtitle1" Class="mb-3 hero-subtitle">
                            Match stray dogs with adopters and keep shelter work organized in one place.
                        </MudText>
                        <MudStack Row="true" Spacing="2" Class="hero-actions">
                            <MudButton Href="/dogs" Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Pets">Browse Dogs</MudButton>
                            <MudButton Href="/success-stories" Variant="Variant.Outlined" Color="Color.Inherit" Size="Size.Large" StartIcon="@Icons.Material.Filled.EmojiEvents">View Success Stories</MudButton>
                            <AuthorizeView>
                                <NotAuthorized>
                                    <MudButton Href="/Account/Login" Variant="Variant.Text" Color="Color.Inherit" Size="Size.Large" StartIcon="@Icons.Material.Filled.Login">Login</MudButton>
                                </NotAuthorized>
                            </AuthorizeView>
                        </MudStack>
                    </div>
                </MudItem>
                <MudItem xs="12" md="5">
                    <div class="hero-visual-panel">
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <span class="hero-panel-icon"><MudIcon Icon="@Icons.Material.Filled.Pets" /></span>
                                <div>
                                    <MudText Typo="Typo.h6">Adoption workflow</MudText>
                                    <MudText Typo="Typo.body2">Browse, request, review.</MudText>
                                </div>
                            </MudStack>
                            <MudDivider />
                            <div class="hero-mini-row">
                                <span>1</span>
                                <MudText Typo="Typo.body2">Browse public dog profiles</MudText>
                            </div>
                            <div class="hero-mini-row">
                                <span>2</span>
                                <MudText Typo="Typo.body2">Send a clear adoption request</MudText>
                            </div>
                            <div class="hero-mini-row">
                                <span>3</span>
                                <MudText Typo="Typo.body2">Shelters review and follow up</MudText>
                            </div>
                        </MudStack>
                    </div>
                </MudItem>
            </MudGrid>
        </section>

        <section class="home-section">
            <MudText Typo="Typo.h5" Class="section-title">How PawConnect Works</MudText>
            <MudText Typo="Typo.body2" Class="section-subtitle mb-2">Three simple steps from discovery to shelter follow-up.</MudText>
            <MudGrid Spacing="2">
                <MudItem xs="12" md="4">
                    <MudCard Class="step-card">
                        <MudCardContent>
                            <span class="step-number">1</span>
                            <MudIcon Icon="@Icons.Material.Filled.Search" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.h6" Class="mt-2">Browse available dogs</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Search and filter public dog profiles.</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudCard Class="step-card">
                        <MudCardContent>
                            <span class="step-number">2</span>
                            <MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn" Color="Color.Secondary" Size="Size.Large" />
                            <MudText Typo="Typo.h6" Class="mt-2">Submit an adoption request</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Share request details and profile context.</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudCard Class="step-card">
                        <MudCardContent>
                            <span class="step-number">3</span>
                            <MudIcon Icon="@Icons.Material.Filled.MarkEmailRead" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.h6" Class="mt-2">Shelter reviews and contacts adopter</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Respond using organized request details.</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </section>

        <section class="home-section">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="section-heading">
                <div>
                    <MudText Typo="Typo.h5" Class="section-title">Featured Dogs</MudText>
                    <MudText Typo="Typo.body2" Class="section-subtitle">A small preview from the public adoption list.</MudText>
                </div>
                <MudSpacer />
                <MudButton Href="/dogs" Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward">See all dogs</MudButton>
            </MudStack>

            @if (_isLoadingFeaturedDogs)
            {
                <MudPaper Elevation="0" Class="empty-state pa-5">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                        <MudText Typo="Typo.h6">Loading featured dogs...</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Fetching available and reserved dogs.</MudText>
                    </MudStack>
                </MudPaper>
            }
            else if (_featuredDogs.Count == 0)
            {
                <MudPaper Elevation="0" Class="empty-state pa-5">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Pets" Color="Color.Secondary" Size="Size.Large" />
                        <MudText Typo="Typo.h6">No featured dogs yet</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Available and reserved dogs will appear here after the database has dog records.</MudText>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudGrid Spacing="3">
                    @foreach (var dog in _featuredDogs)
                    {
                        var imageUrl = GetDogImageUrl(dog);

                        <MudItem xs="12" sm="6" md="3">
                            <MudCard Class="featured-dog-card">
                                <a class="dog-image-link" href="@($"/dogs/{dog.Id}")" aria-label="@($"View details for {dog.Name}")">
                                    @if (imageUrl is null)
                                    {
                                        <div class="featured-dog-image dog-image-placeholder">
                                            <MudIcon Icon="@Icons.Material.Filled.Pets" Color="Color.Primary" />
                                            <MudText Typo="Typo.caption">No image available</MudText>
                                        </div>
                                    }
                                    else
                                    {
                                        <MudCardMedia Image="@imageUrl" Class="featured-dog-image" />
                                    }
                                </a>
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" AlignItems="AlignItems.Start">
                                            <MudText Typo="Typo.h6">@dog.Name</MudText>
                                            <MudSpacer />
                                            <MudChip T="string" Color="@GetStatusColor(dog.Status)" Size="Size.Small">@dog.Status</MudChip>
                                        </MudStack>
                                        <MudText Typo="Typo.body2">@DogBreedFormatter.Format(dog)</MudText>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@dog.Location</MudText>
                                    </MudStack>
                                </MudCardContent>
                                <MudCardActions>
                                    <MudButton Href="@($"/dogs/{dog.Id}")" Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward">View Details</MudButton>
                                </MudCardActions>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            }
        </section>

        <section class="home-section shelter-section pa-4">
            <MudStack Spacing="3">
                <div class="shelter-section-heading">
                    <MudText Typo="Typo.caption" Class="page-kicker">For shelters</MudText>
                    <MudText Typo="Typo.h5" Class="section-title">Simple tools for daily shelter work</MudText>
                    <MudText Typo="Typo.body2" Class="section-subtitle">Manage dogs, requests, resources, and reports without extra complexity.</MudText>
                    <AuthorizeView Context="shelterApplyContext">
                        <Authorized>
                            @if (!shelterApplyContext.User.IsInRole(IdentitySeedData.AdminRole) &&
                                                        !shelterApplyContext.User.IsInRole(IdentitySeedData.ShelterRole))
                            {
                                <MudButton Href="/shelters/apply" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Business" Class="mt-2">Apply as a Shelter</MudButton>
                            }
                        </Authorized>
                        <NotAuthorized>
                            <MudButton Href="/shelters/apply" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Business" Class="mt-2">Apply as a Shelter</MudButton>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>

                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6" md="3">
                        <MudCard Class="feature-card compact-feature-card">
                            <MudCardContent>
                                <MudIcon Icon="@Icons.Material.Filled.Pets" Color="Color.Primary" />
                                <MudText Typo="Typo.subtitle1" Class="mt-1">Manage dogs</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Profiles and records.</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudCard Class="feature-card compact-feature-card">
                            <MudCardContent>
                                <MudIcon Icon="@Icons.Material.Filled.FactCheck" Color="Color.Secondary" />
                                <MudText Typo="Typo.subtitle1" Class="mt-1">Track requests</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Profiles and answers.</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudCard Class="feature-card compact-feature-card">
                            <MudCardContent>
                                <MudIcon Icon="@Icons.Material.Filled.Inventory" Color="Color.Primary" />
                                <MudText Typo="Typo.subtitle1" Class="mt-1">Monitor stock</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Low-resource warnings.</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudCard Class="feature-card compact-feature-card">
                            <MudCardContent>
                                <MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Info" />
                                <MudText Typo="Typo.subtitle1" Class="mt-1">Reports</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Email PDF summaries.</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                </MudGrid>
            </MudStack>
        </section>
    </MudStack>
</div>

@code {
    private List<Dog> _featuredDogs = [];
    private bool _isLoadingFeaturedDogs = true;
    private bool _hasRetriedFeaturedDogsLoad;

    [SupplyParameterFromQuery(Name = "loggedOut")]
    private bool LoggedOut { get; set; }

    private bool _logoutMessageShown;

    protected override async Task OnInitializedAsync()
    {
        await LoadFeaturedDogsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _featuredDogs.Count > 0 || _hasRetriedFeaturedDogsLoad)
        {
            return;
        }

        _hasRetriedFeaturedDogsLoad = true;
        await Task.Delay(300);
        await LoadFeaturedDogsAsync();
        StateHasChanged();
    }

    protected override void OnParametersSet()
    {
        if (LoggedOut && !_logoutMessageShown)
        {
            _logoutMessageShown = true;
            Snackbar.Add("You have been logged out successfully.", Severity.Success);
        }
    }

    private async Task LoadFeaturedDogsAsync()
    {
        _isLoadingFeaturedDogs = true;

        try
        {
            _featuredDogs = (await DogService.GetAvailableDogsAsync()).Take(4).ToList();
        }
        catch
        {
            _featuredDogs = [];
        }
        finally
        {
            _isLoadingFeaturedDogs = false;
        }
    }

    private static string? GetDogImageUrl(Dog dog)
    {
        return dog.Images
            .Where(i => IsValidImageUrl(i.ImageUrl))
            .OrderByDescending(i => i.IsMainImage)
            .ThenBy(i => i.Id)
            .Select(i => i.ImageUrl)
            .FirstOrDefault();
    }

    private static bool IsValidImageUrl(string? imageUrl)
    {
        if (string.IsNullOrWhiteSpace(imageUrl) ||
            imageUrl.Contains("placehold.co", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        return Uri.TryCreate(imageUrl, UriKind.Absolute, out var uri) &&
            (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);
    }

    private static Color GetStatusColor(DogStatus status)
    {
        return status switch
        {
            DogStatus.Available => Color.Success,
            DogStatus.Reserved => Color.Warning,
            DogStatus.Adopted => Color.Default,
            DogStatus.InTreatment => Color.Info,
            _ => Color.Default
        };
    }
}
