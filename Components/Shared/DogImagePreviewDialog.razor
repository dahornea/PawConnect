<MudDialog Class="dog-image-lightbox-dialog">
    <DialogContent>
        <div class="dog-image-preview"
             @ref="_previewElement"
             tabindex="0"
             role="group"
             aria-label="@($"Image preview for {DogName}")"
             @onkeydown="HandleKeyDown">
            @{
                var displayImages = GetDisplayImages();
                var selectedIndex = GetSafeSelectedImageIndex(displayImages.Count);
                var selectedImage = displayImages.Count == 0 ? null : displayImages[selectedIndex];
                var hasMultipleImages = displayImages.Count > 1;
                var currentPhotoNumber = displayImages.Count == 0 ? 0 : selectedIndex + 1;
            }

            @if (selectedImage is not null)
            {
                <div class="preview-image-stage">
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Color="Color.Default"
                                   Size="Size.Medium"
                                   OnClick="Close"
                                   Class="preview-close-button"
                                   aria-label="Close image preview" />

                    @if (hasMultipleImages)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                       Color="Color.Default"
                                       Size="Size.Large"
                                       OnClick="ShowPreviousImage"
                                       Class="preview-nav previous"
                                       aria-label="Previous photo" />
                    }

                    <div class="preview-image-frame" aria-live="polite">
                        <img src="@selectedImage.ImageUrl"
                             @key="selectedImage.ImageUrl"
                             alt="@GetSelectedImageAlt(currentPhotoNumber)"
                             class="preview-image"
                             decoding="async"
                             @onerror="@(() => MarkImageUnavailable(selectedImage.ImageUrl))" />
                        <div class="preview-caption">
                            <span>@DogName</span>
                            <span aria-hidden="true">&middot;</span>
                            <span>@FormattedBreed</span>
                            @if (hasMultipleImages)
                            {
                                <span aria-hidden="true">&middot;</span>
                                <span>@currentPhotoNumber / @displayImages.Count</span>
                            }
                        </div>
                    </div>

                    @if (hasMultipleImages)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                       Color="Color.Default"
                                       Size="Size.Large"
                                       OnClick="ShowNextImage"
                                       Class="preview-nav next"
                                       aria-label="Next photo" />
                    }
                </div>

                @if (hasMultipleImages)
                {
                    <div class="preview-thumbnail-row" role="list" aria-label="@($"{DogName} photo thumbnails")">
                        @for (var index = 0; index < displayImages.Count; index++)
                        {
                            var thumbnailIndex = index;
                            var image = displayImages[thumbnailIndex];
                            var isSelected = thumbnailIndex == selectedIndex;

                            <button type="button"
                                    class="preview-thumbnail @(isSelected ? "selected" : null)"
                                    role="listitem"
                                    aria-label="@($"Show photo {thumbnailIndex + 1} of {DogName}")"
                                    aria-current="@(isSelected ? "true" : "false")"
                                    @onclick="() => SelectImage(thumbnailIndex)">
                                <img src="@image.ImageUrl"
                                     alt=""
                                     loading="lazy"
                                     @onerror="@(() => MarkImageUnavailable(image.ImageUrl))" />
                            </button>
                        }
                    </div>
                }
            }
            else
            {
                <div class="preview-empty-state">
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Color="Color.Default"
                                   Size="Size.Medium"
                                   OnClick="Close"
                                   Class="preview-close-button"
                                   aria-label="Close image preview" />
                    <MudIcon Icon="@Icons.Material.Filled.Pets" />
                    <MudText Typo="Typo.subtitle1">No photo available</MudText>
                </div>
            }
        </div>
    </DialogContent>
</MudDialog>

