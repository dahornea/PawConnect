@implements IDisposable

<MudPaper Elevation="0" Class="conversation-panel">
    @if (_isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">Loading messages...</MudText>
        </MudStack>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_error</MudAlert>
    }
    else if (_conversation is not null)
    {
        <div class="conversation-header">
            <MudButton Href="@BackHref"
                       Variant="Variant.Text"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.ArrowBack">
                @BackText
            </MudButton>
            <div class="conversation-title-copy">
                <MudText Typo="Typo.h5">Messages about @_conversation.DogName</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Conversation with @_conversation.OtherParticipantName
                </MudText>
            </div>
        </div>

        <div class="conversation-messages" role="log" aria-label="Adoption request messages">
            @if (_messages.Count == 0)
            {
                <div class="conversation-empty">
                    <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h6">No messages yet</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Start the conversation with a clear question or update.</MudText>
                </div>
            }
            else
            {
                @foreach (var message in _messages)
                {
                    <article class="message-bubble @(message.IsOwnMessage ? "is-own" : "is-other")">
                        <div class="message-meta">
                            <span>@message.SenderDisplayName</span>
                            <span>@message.SenderRole</span>
                            <span>@FormatMessageTime(message.CreatedAt)</span>
                            @if (message.IsEdited)
                            {
                                <span>edited</span>
                            }
                            @if (CanEditMessage(message) && _editingMessageId != message.Id)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Size="Size.Small"
                                               Color="Color.Inherit"
                                               Class="message-edit-button"
                                               aria-label="Edit message"
                                               OnClick="() => StartEditingMessage(message)" />
                            }
                            @if (CanReportMessage(message))
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Report"
                                               Size="Size.Small"
                                               Color="Color.Inherit"
                                               Class="message-report-button"
                                               aria-label="Report message"
                                               OnClick="() => OpenReportMessageDialogAsync(message)" />
                            }
                        </div>
                        @if (_editingMessageId == message.Id)
                        {
                            <div class="message-edit-form">
                                <MudTextField Label="Edit message"
                                              @bind-Value="_editingBody"
                                              Variant="Variant.Outlined"
                                              Lines="3"
                                              MaxLength="@MaxMessageLength"
                                              Counter="@MaxMessageLength"
                                              Disabled="_isEditingMessage"
                                              Immediate="true" />
                                @if (!string.IsNullOrWhiteSpace(_editError))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Error">@_editError</MudText>
                                }
                                <MudStack Row="true" Justify="Justify.FlexEnd" Class="message-edit-actions">
                                    <MudButton Variant="Variant.Text"
                                               Color="Color.Default"
                                               Disabled="_isEditingMessage"
                                               OnClick="CancelEditingMessage">
                                        Cancel
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Disabled="_isEditingMessage"
                                               OnClick="SaveEditedMessageAsync">
                                        Save
                                    </MudButton>
                                </MudStack>
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(message.Body))
                        {
                            <div class="message-body">@message.Body</div>
                        }
                        @if (message.Attachments.Count > 0)
                        {
                            <div class="message-attachments">
                                @foreach (var attachment in message.Attachments)
                                {
                                    @if (attachment.IsImage)
                                    {
                                        <a class="message-attachment image-attachment"
                                           href="@attachment.DownloadUrl"
                                           target="_blank"
                                           rel="noopener noreferrer"
                                           aria-label="Open @attachment.OriginalFileName">
                                            <img src="@attachment.DownloadUrl" alt="@attachment.OriginalFileName" />
                                            <span>@attachment.OriginalFileName</span>
                                        </a>
                                    }
                                    else
                                    {
                                        <a class="message-attachment file-attachment"
                                           href="@attachment.DownloadUrl"
                                           target="_blank"
                                           download="@attachment.OriginalFileName"
                                           rel="noopener noreferrer">
                                            <MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Size="Size.Small" />
                                            <span>@attachment.OriginalFileName</span>
                                            <small>@FormatFileSize(attachment.FileSizeBytes)</small>
                                        </a>
                                    }
                                }
                            </div>
                        }
                        <div class="message-reactions" aria-label="Message reactions">
                            @foreach (var reaction in AvailableReactions)
                            {
                                var summary = GetReactionSummary(message, reaction.ReactionType);
                                var isSelected = summary?.ReactedByCurrentUser == true;
                                var count = summary?.Count ?? 0;

                                <button type="button"
                                        class="reaction-button @(isSelected ? "is-selected" : string.Empty)"
                                        disabled="@IsReactionBusy(message.Id)"
                                        @onclick="() => ToggleReactionAsync(message.Id, reaction.ReactionType)"
                                        aria-pressed="@isSelected"
                                        aria-label="@($"React with {reaction.DisplayText}")">
                                    <span>@reaction.DisplayText</span>
                                    @if (count > 0)
                                    {
                                        <strong>@count</strong>
                                    }
                                </button>
                            }
                        </div>
                    </article>
                }
            }
        </div>

        @if (_otherParticipantTyping)
        {
            <div class="typing-indicator" aria-live="polite">
                @_typingIndicatorText
            </div>
        }

        <EditForm Model="_sendModel" OnSubmit="@(_ => SendMessageAsync())">
            <div class="conversation-composer">
                <MudTextField T="string"
                              Label="Write a message"
                              Value="@(_sendModel.Body ?? string.Empty)"
                              ValueChanged="OnComposerBodyChangedAsync"
                              Variant="Variant.Outlined"
                              Lines="3"
                              MaxLength="@MaxMessageLength"
                              Counter="@MaxMessageLength"
                              Disabled="_isSending"
                              Immediate="true" />
                <div class="attachment-composer">
                    <label class="attachment-picker @( _isSending ? "is-disabled" : string.Empty )">
                        <InputFile OnChange="OnAttachmentSelected"
                                   accept=".jpg,.jpeg,.png,.webp,.pdf"
                                   disabled="@_isSending" />
                        <MudIcon Icon="@Icons.Material.Filled.AttachFile" Size="Size.Small" />
                        <span>Attach file</span>
                    </label>
                    @if (_selectedFile is not null)
                    {
                        <div class="selected-attachment">
                            <MudIcon Icon="@GetSelectedFileIcon()" Size="Size.Small" />
                            <span>@_selectedFile.Name</span>
                            <small>@FormatFileSize(_selectedFile.Size)</small>
                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           Size="Size.Small"
                                           Color="Color.Default"
                                           Disabled="_isSending"
                                           aria-label="Remove selected attachment"
                                           OnClick="RemoveSelectedAttachment" />
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_selectedFileError))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Error">@_selectedFileError</MudText>
                    }
                </div>
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="composer-actions">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Messages and attachments are visible only to the adopter and the shelter for this request.
                    </MudText>
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Send"
                               Disabled="@(!CanSendMessage)">
                        Send
                    </MudButton>
                </MudStack>
            </div>
        </EditForm>
    }
</MudPaper>
