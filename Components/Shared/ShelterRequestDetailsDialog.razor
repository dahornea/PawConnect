<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Shelter Application</MudText>
    </TitleContent>
    <DialogContent>
        @if (Request is not null)
        {
            <MudStack Spacing="2">
                <MudText Typo="Typo.subtitle1">@Request.ShelterName</MudText>
                <MudText Typo="Typo.body2"><strong>Contact:</strong> @Request.ContactPersonName</MudText>
                <MudText Typo="Typo.body2"><strong>Email:</strong> @Request.Email</MudText>
                <MudText Typo="Typo.body2"><strong>Phone:</strong> @Request.PhoneNumber</MudText>
                <MudText Typo="Typo.body2"><strong>Address:</strong> @Request.Address, @Request.City</MudText>
                @if (!string.IsNullOrWhiteSpace(Request.Neighborhood))
                {
                    <MudText Typo="Typo.body2"><strong>Neighborhood:</strong> @Request.Neighborhood</MudText>
                }
                <MudText Typo="Typo.body2"><strong>Description:</strong> @Request.Description</MudText>
                @if (!string.IsNullOrWhiteSpace(Request.Website))
                {
                    <MudText Typo="Typo.body2"><strong>Website:</strong> @Request.Website</MudText>
                }
                @if (!string.IsNullOrWhiteSpace(Request.OpeningHours))
                {
                    <MudText Typo="Typo.body2"><strong>Opening hours:</strong> @Request.OpeningHours</MudText>
                }
                @if (!string.IsNullOrWhiteSpace(Request.ReasonForJoining))
                {
                    <MudText Typo="Typo.body2"><strong>Reason:</strong> @Request.ReasonForJoining</MudText>
                }
                <MudText Typo="Typo.body2"><strong>Map location:</strong> @FormatMapLocation(Request)</MudText>
                @if (HasMapLocation(Request))
                {
                    <ShelterMap Latitude="Request.Latitude"
                                Longitude="Request.Longitude"
                                ShelterName="@Request.ShelterName"
                                Address="@Request.Address"
                                City="@Request.City"
                                Height="240px" />
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

