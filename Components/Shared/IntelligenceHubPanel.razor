@inject IIntelligenceInsightService InsightService
@inject ISnackbar Snackbar
@using System.Text.Json

<MudStack Spacing="3" Class="intelligence-hub">
    <header class="intelligence-workspace-header">
        <div>
            <MudText Typo="Typo.caption" Class="dashboard-kicker">Explainable decision support</MudText>
            <MudText Typo="Typo.h4">@Title</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">@Subtitle</MudText>
        </div>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="intelligence-header-actions">
            <MudText Typo="Typo.caption" Color="Color.Secondary">Last refreshed @FormatRefreshTime(_summary.LastRefreshedAtUtc)</MudText>
            @if (!string.IsNullOrWhiteSpace(MethodologyRoute))
            {
                <MudIconButton Href="@MethodologyRoute" Icon="@Icons.Material.Outlined.Info" aria-label="View intelligence methodology" />
            }
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" Disabled="_isRefreshing" OnClick="RefreshAsync">
                @(_isRefreshing ? "Refreshing..." : "Refresh")
            </MudButton>
        </MudStack>
    </header>

    @if (_isLoading)
    {
        <div class="intelligence-loading-shell">
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="88px" />
            <MudGrid Spacing="2">
                @for (var index = 0; index < 4; index++)
                {
                    <MudItem xs="6" md="3"><MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="82px" /></MudItem>
                }
            </MudGrid>
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="420px" />
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <AppErrorState Title="Intelligence Hub could not be loaded" Message="@_error" OnRetry="LoadAsync" />
    }
    else
    {
        <IntelligenceSummaryCards Summary="_summary" IsAdopterView="IsAdopterView" />

        <MudPaper Elevation="0" Class="intelligence-control-surface pa-3">
            <IntelligenceFilterToolbar Search="_search"
                                       SearchChanged="OnSearchChanged"
                                       Severity="_severity"
                                       SeverityChanged="OnSeverityChanged"
                                       Category="_category"
                                       CategoryChanged="OnCategoryChanged"
                                       ActiveLabels="ActiveFilterLabels"
                                       OnApply="ApplyFiltersAsync"
                                       OnClear="ClearFiltersAsync" />
            <MudDivider Class="my-2" />
            <SavedViewControls PageKey="@SavedViewPageKey"
                               RoleScope="@SavedViewRoleScope"
                               CurrentFilterStateJson="@SavedViewFilterStateJson"
                               CurrentSummaryLabels="@SavedViewSummaryLabels"
                               Disabled="@(_isLoading || _isRefreshing)"
                               Compact="true"
                               OnApply="ApplySavedViewAsync"
                               OnClear="ClearFiltersAsync" />
        </MudPaper>

        <section class="intelligence-workspace">
            <div class="intelligence-master">
                <div class="intelligence-lifecycle-tabs" role="tablist" aria-label="Priority lifecycle">
                    @foreach (var tab in LifecycleTabs)
                    {
                        <button type="button"
                                role="tab"
                                aria-selected="@(_status == tab.Status ? "true" : "false")"
                                class="@(_status == tab.Status ? "active" : null)"
                                @onclick="@(() => ChangeLifecycleAsync(tab.Status))">
                            <span>@tab.Label</span>
                            <strong>@GetLifecycleCount(tab.Status)</strong>
                        </button>
                    }
                </div>

                @if (_status == IntelligenceInsightStatus.Active)
                {
                    <div class="intelligence-quick-filters" aria-label="Quick severity filters">
                        <MudButton Variant="@(_urgentOnly ? Variant.Filled : Variant.Text)" Color="Color.Primary" Size="Size.Small" OnClick="ShowUrgentAsync">Critical + High</MudButton>
                        <MudButton Variant="@(!_urgentOnly && !_severity.HasValue ? Variant.Filled : Variant.Text)" Color="Color.Primary" Size="Size.Small" OnClick="ShowAllSeveritiesAsync">All</MudButton>
                        @foreach (var severity in new[] { IntelligenceSeverity.Critical, IntelligenceSeverity.High, IntelligenceSeverity.Medium, IntelligenceSeverity.Low })
                        {
                            <MudButton Variant="@(!_urgentOnly && _severity == severity ? Variant.Filled : Variant.Text)"
                                       Color="@IntelligenceUi.SeverityColor(severity)"
                                       Size="Size.Small"
                                       OnClick="@(() => ShowSeverityAsync(severity))">
                                @IntelligenceUi.SeverityLabel(severity)
                            </MudButton>
                        }
                    </div>
                }

                <div class="intelligence-list-summary">
                    <div>
                        <MudText Typo="Typo.h6">@CurrentListTitle</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@FilteredInsights.Count @Pluralize(FilteredInsights.Count, "priority", "priorities")</MudText>
                    </div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Sorted by urgency, then age</MudText>
                </div>

                @if (FilteredInsights.Count == 0)
                {
                    <AppEmptyState Title="@CurrentEmptyTitle"
                                   Message="@CurrentEmptyMessage"
                                   Icon="@Icons.Material.Filled.TaskAlt"
                                   IconColor="Color.Success"
                                   PrimaryActionText="Clear filters"
                                   PrimaryActionIcon="@Icons.Material.Filled.FilterAltOff"
                                   OnPrimaryAction="ClearFiltersAsync" />
                }
                else
                {
                    <IntelligenceInsightList Insights="FilteredInsights"
                                             SelectedId="_selected?.Id"
                                             IsAdopterView="IsAdopterView"
                                             OnSelect="SelectInsightAsync"
                                             OnAcknowledge="AcknowledgeAsync"
                                             OnSnooze="SnoozeAsync"
                                             OnReopen="ReopenAsync" />
                }
            </div>

            <IntelligenceInsightDetailsPanel Insight="_selected"
                                                     IsLoading="_isLoadingDetails"
                                                     IsAdopterView="IsAdopterView"
                                                     MobileOpen="_mobileDetailsOpen"
                                                     ResolutionReason="_resolutionReason"
                                                     ResolutionReasonChanged="OnResolutionReasonChanged"
                                                     OnClose="CloseDetails"
                                                     OnAcknowledge="AcknowledgeAsync"
                                                     OnSnooze="SnoozeAsync"
                                                     OnReopen="ReopenAsync"
                                                     OnResolve="ResolveAsync" />
        </section>
    }
</MudStack>

@code {
    [Parameter, EditorRequired] public IntelligenceScope Scope { get; set; } = default!;
    [Parameter, EditorRequired] public string ActorUserId { get; set; } = string.Empty;
    [Parameter] public string Title { get; set; } = "Operations Intelligence";
    [Parameter] public string Subtitle { get; set; } = "What needs attention, why it matters, and what to do next.";
    [Parameter] public string? MethodologyRoute { get; set; }
    [Parameter] public string EmptyTitle { get; set; } = "All urgent priorities are under control";
    [Parameter] public string EmptyMessage { get; set; } = "No active operational issues were detected during the latest evaluation.";

    private bool _isLoading = true;
    private bool _isRefreshing;
    private bool _isLoadingDetails;
    private bool _mobileDetailsOpen;
    private bool _urgentOnly = true;
    private string? _error;
    private string? _search;
    private IntelligenceSeverity? _severity;
    private IntelligenceCategory? _category;
    private IntelligenceInsightStatus _status = IntelligenceInsightStatus.Active;
    private List<OperationalInsightListItemDto> _insights = [];
    private OperationalInsightDto? _selected;
    private string? _resolutionReason;
    private CancellationTokenSource? _detailsCts;
    private IntelligenceSummaryDto _summary = new(0, 0, 0, 0, 0, 0, 0, null, "Normal", new Dictionary<IntelligenceCategory, int>());

    private bool IsAdopterView => Scope.AudienceType == IntelligenceAudienceType.Adopter;
    private IReadOnlyList<OperationalInsightListItemDto> FilteredInsights => _urgentOnly && _status == IntelligenceInsightStatus.Active
        ? _insights.Where(insight => insight.Severity is IntelligenceSeverity.Critical or IntelligenceSeverity.High).ToList()
        : _insights;
    private string SavedViewPageKey => Scope.AudienceType switch
    {
        IntelligenceAudienceType.Shelter => "Shelter.Intelligence",
        IntelligenceAudienceType.Adopter => "Adopter.Insights",
        _ => "Admin.Intelligence"
    };
    private SavedViewRoleScope SavedViewRoleScope => Scope.AudienceType switch
    {
        IntelligenceAudienceType.Shelter => SavedViewRoleScope.Shelter,
        IntelligenceAudienceType.Adopter => SavedViewRoleScope.Adopter,
        _ => SavedViewRoleScope.Admin
    };
    private static readonly JsonSerializerOptions SavedViewJsonOptions = new(JsonSerializerDefaults.Web);
    private string SavedViewFilterStateJson => JsonSerializer.Serialize(new IntelligenceSavedViewState(_search, _severity, _category, _status, _urgentOnly), SavedViewJsonOptions);
    private IReadOnlyList<string> SavedViewSummaryLabels => ActiveFilterLabels;
    private IReadOnlyList<string> ActiveFilterLabels =>
    [
        .. string.IsNullOrWhiteSpace(_search) ? [] : new[] { $"Search: {_search}" },
        .. _urgentOnly && _status == IntelligenceInsightStatus.Active ? new[] { "Priority: Critical + High" } : [],
        .. _severity.HasValue ? new[] { $"Severity: {IntelligenceUi.SeverityLabel(_severity.Value)}" } : [],
        .. _category.HasValue ? new[] { $"Category: {IntelligenceUi.CategoryLabel(_category.Value)}" } : [],
        .. _status != IntelligenceInsightStatus.Active ? new[] { $"Lifecycle: {IntelligenceUi.StatusLabel(_status)}" } : []
    ];
    private IReadOnlyList<LifecycleTab> LifecycleTabs =>
    [
        new("Needs attention", IntelligenceInsightStatus.Active),
        new("Acknowledged", IntelligenceInsightStatus.Acknowledged),
        new("Snoozed", IntelligenceInsightStatus.Snoozed),
        new("Resolved", IntelligenceInsightStatus.Resolved)
    ];
    private string CurrentListTitle => _status switch
    {
        IntelligenceInsightStatus.Active when _urgentOnly => "Urgent priorities",
        _ => IntelligenceUi.StatusLabel(_status)
    };
    private string CurrentEmptyTitle => HasExplicitFilters ? "No priorities match the selected filters" : _status == IntelligenceInsightStatus.Active ? EmptyTitle : $"No {IntelligenceUi.StatusLabel(_status).ToLowerInvariant()} priorities";
    private string CurrentEmptyMessage => HasExplicitFilters ? "Clear or change the current filters to widen the results." : _status == IntelligenceInsightStatus.Active ? EmptyMessage : "There are no priorities in this lifecycle state.";
    private bool HasExplicitFilters => !string.IsNullOrWhiteSpace(_search) || _category.HasValue || _severity.HasValue || !_urgentOnly || _status != IntelligenceInsightStatus.Active;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        try
        {
            _isLoading = true;
            _error = null;
            _summary = await InsightService.GetSummaryAsync(Scope);
            if (_summary.LastRefreshedAtUtc is null)
            {
                await InsightService.RefreshAsync(Scope, ActorUserId);
                _summary = await InsightService.GetSummaryAsync(Scope);
            }

            var includeSnoozed = _status == IntelligenceInsightStatus.Snoozed;
            var result = await InsightService.GetInsightSummariesAsync(
                Scope,
                new IntelligenceInsightQuery(_severity, _category, _status, Search: _search, IncludeSnoozed: includeSnoozed, PageSize: 50));
            _insights = result.Items.ToList();

            var visible = FilteredInsights;
            var selectedSummary = _selected is null ? null : visible.FirstOrDefault(item => item.Id == _selected.Id);
            selectedSummary ??= visible.FirstOrDefault();
            if (selectedSummary is null)
            {
                _selected = null;
                _mobileDetailsOpen = false;
            }
            else
            {
                await LoadDetailsAsync(selectedSummary.Id, openMobile: false);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message.Contains("Invalid object name", StringComparison.OrdinalIgnoreCase)
                ? "Apply the latest EF Core migration, then reload this page."
                : "Operational insights could not be loaded right now.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadDetailsAsync(int insightId, bool openMobile)
    {
        _detailsCts?.Cancel();
        _detailsCts?.Dispose();
        _detailsCts = new CancellationTokenSource();
        var token = _detailsCts.Token;

        try
        {
            _isLoadingDetails = true;
            if (openMobile) _mobileDetailsOpen = true;
            var details = await InsightService.GetInsightDetailsAsync(insightId, Scope, token);
            if (!token.IsCancellationRequested)
            {
                _selected = details;
                _resolutionReason = null;
            }
        }
        catch (OperationCanceledException) when (token.IsCancellationRequested)
        {
        }
        finally
        {
            if (!token.IsCancellationRequested) _isLoadingDetails = false;
        }
    }

    private async Task SelectInsightAsync(OperationalInsightListItemDto insight) => await LoadDetailsAsync(insight.Id, openMobile: true);

    private async Task RefreshAsync()
    {
        try
        {
            _isRefreshing = true;
            await InsightService.RefreshAsync(Scope, ActorUserId);
            await LoadAsync();
            Snackbar.Add("Operational insights refreshed.", Severity.Success);
        }
        catch (InvalidOperationException ex) { Snackbar.Add(ex.Message, Severity.Info); }
        catch { Snackbar.Add("Insights could not be refreshed right now.", Severity.Error); }
        finally { _isRefreshing = false; }
    }

    private Task OnSearchChanged(string? value) { _search = value; return Task.CompletedTask; }
    private Task OnCategoryChanged(IntelligenceCategory? value) { _category = value; return Task.CompletedTask; }
    private Task OnResolutionReasonChanged(string? value) { _resolutionReason = value; return Task.CompletedTask; }
    private Task OnSeverityChanged(IntelligenceSeverity? value) { _severity = value; _urgentOnly = false; return Task.CompletedTask; }
    private Task ApplyFiltersAsync() => LoadAsync();

    private async Task ClearFiltersAsync()
    {
        _search = null;
        _severity = null;
        _category = null;
        _status = IntelligenceInsightStatus.Active;
        _urgentOnly = true;
        await LoadAsync();
    }

    private async Task ChangeLifecycleAsync(IntelligenceInsightStatus status)
    {
        _status = status;
        _urgentOnly = status == IntelligenceInsightStatus.Active;
        _severity = null;
        await LoadAsync();
    }

    private async Task ShowUrgentAsync() { _urgentOnly = true; _severity = null; await LoadAsync(); }
    private async Task ShowAllSeveritiesAsync() { _urgentOnly = false; _severity = null; await LoadAsync(); }
    private async Task ShowSeverityAsync(IntelligenceSeverity severity) { _urgentOnly = false; _severity = severity; await LoadAsync(); }

    private async Task ApplySavedViewAsync(SavedViewDto view)
    {
        try
        {
            var state = JsonSerializer.Deserialize<IntelligenceSavedViewState>(view.FilterStateJson, SavedViewJsonOptions);
            _search = state?.Search;
            _severity = state?.Severity;
            _category = state?.Category;
            _status = state?.Status ?? IntelligenceInsightStatus.Active;
            _urgentOnly = state?.UrgentOnly ?? false;
            await LoadAsync();
        }
        catch (JsonException)
        {
            Snackbar.Add("This saved intelligence view is no longer valid.", Severity.Warning);
        }
    }

    private Task AcknowledgeAsync(int id) => RunLifecycleAsync(() => InsightService.AcknowledgeAsync(id, Scope, ActorUserId), "Priority acknowledged.");
    private Task SnoozeAsync(IntelligenceSnoozeRequest request) => RunLifecycleAsync(
        () => InsightService.SnoozeAsync(request.InsightId, Scope, ActorUserId, request.Duration),
        request.Duration < TimeSpan.FromDays(1) ? "Priority snoozed for one hour." : $"Priority snoozed for {(int)request.Duration.TotalDays} day{(request.Duration.TotalDays == 1 ? string.Empty : "s")}.");
    private Task ReopenAsync(int id) => RunLifecycleAsync(() => InsightService.ReopenAsync(id, Scope, ActorUserId), "Priority reopened.");

    private async Task ResolveAsync(IntelligenceResolveRequest request)
    {
        await RunLifecycleAsync(() => InsightService.ResolveAsync(request.InsightId, Scope, ActorUserId, request.Reason), "Priority marked as resolved.");
        _resolutionReason = null;
    }

    private async Task RunLifecycleAsync(Func<Task> action, string success)
    {
        try
        {
            await action();
            _mobileDetailsOpen = false;
            await LoadAsync();
            Snackbar.Add(success, Severity.Success);
        }
        catch (InvalidOperationException ex) { Snackbar.Add(ex.Message, Severity.Warning); }
        catch { Snackbar.Add("The priority could not be updated.", Severity.Error); }
    }

    private void CloseDetails()
    {
        _mobileDetailsOpen = false;
        _selected = null;
    }

    private int GetLifecycleCount(IntelligenceInsightStatus status) => status switch
    {
        IntelligenceInsightStatus.Active => Math.Max(0, _summary.Total - _summary.Acknowledged - _summary.Snoozed),
        IntelligenceInsightStatus.Acknowledged => _summary.Acknowledged,
        IntelligenceInsightStatus.Snoozed => _summary.Snoozed,
        IntelligenceInsightStatus.Resolved => _summary.Resolved,
        _ => 0
    };

    private static string FormatRefreshTime(DateTime? value) => value.HasValue ? value.Value.ToLocalTime().ToString("dd MMM, HH:mm") : "not yet";
    private static string Pluralize(int count, string singular, string plural) => count == 1 ? singular : plural;

    private sealed record LifecycleTab(string Label, IntelligenceInsightStatus Status);
    private sealed record IntelligenceSavedViewState(string? Search, IntelligenceSeverity? Severity, IntelligenceCategory? Category, IntelligenceInsightStatus? Status, bool? UrgentOnly = null);
}
