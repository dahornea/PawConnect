{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=PawConnect;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "EmailSettings": {
    "Enabled": true,
    "SmtpHost": "localhost",
    "SmtpPort": 2525,
    "SmtpUser": "",
    "SmtpPassword": "",
    "SenderEmail": "no-reply@pawconnect.local",
    "SenderName": "PawConnect",
    "EnableSsl": false,
    "OpenLocalInboxOnStartup": false,
    "LocalInboxUrl": "http://localhost:3000"
  },
  "NotificationOutbox": {
    "Enabled": true,
    "PollIntervalSeconds": 60,
    "BatchSize": 20
  },
  "ScheduledReports": {
    "Enabled": true,
    "RunOnStartupInDevelopment": false,
    "ShelterReportIntervalMinutes": 60
  },
  "VisitReminders": {
    "Enabled": true,
    "CheckIntervalMinutes": 60,
    "ReminderHoursBeforeVisit": 24
  },
  "IntelligenceHub": {
    "Enabled": true,
    "ApplicationReviewWarningHours": 48,
    "ApplicationReviewCriticalHours": 120,
    "DogNoApplicationWarningDays": 21,
    "DogNoApplicationCriticalDays": 45,
    "LowProfileCompletenessThreshold": 70,
    "CriticalProfileCompletenessThreshold": 45,
    "VolunteerTaskOverdueWarningHours": 12,
    "TransferPendingWarningHours": 48,
    "OutboxFailedWarningCount": 3,
    "OutboxDeadLetterCriticalCount": 1,
    "InsightRefreshMinutes": 15,
    "ManualRefreshCooldownSeconds": 30,
    "MaximumInsightsPerDashboard": 50,
    "HighPriorityNotificationThreshold": 80
  },
  "DogImageStorage": {
    "Provider": "Local",
    "MaxFileSizeBytes": 5242880,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ],
    "LocalRoot": "uploads/dogs"
  },
  "OpenAI": {
    "Enabled": true,
    "ApiKey": "",
    "Model": "gpt-5.4-mini",
    "ChatModel": "gpt-5.4-mini",
    "EmbeddingModel": "text-embedding-3-small",
    "ShelterOperationsAssistantEnabled": true,
    "ShelterOperationsAssistantModel": ""
  },
  "AllowedHosts": "*"
}
